#!/usr/bin/env python3
"""Initialize and validate the file protocol for a Codex–Claude cowork session."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import stat
import sys
import tempfile
from datetime import datetime, timezone
from pathlib import Path

SCHEMA_VERSION = 1
STAGE_SCHEMA_VERSION = 1
CLIENTS = {"codex", "claude"}
COPILOT_OWNED = "copilot-evidence.md"
COPILOT_CANDIDATE = "candidate-copilot-evidence.md"
MAX_CANDIDATE_BYTES = 64 * 1024
PHASES = (
    "planning",
    "discussing",
    "ready-for-execution",
    "executing",
    "validating",
    "complete",
)

TEMPLATES = {
    "charter.md": """# Charter

## Task

TODO

## Boundaries

TODO

## Baseline and sandboxes

TODO

## Acceptance

TODO
""",
    "plan.md": """# Initial plan

## Confirmed facts and assumptions

TODO

## Steps

TODO

## Evidence questions

TODO

## Risks and recovery

TODO
""",
    "driver-evidence.md": """# Driver evidence

## Sandbox and baseline

TODO

## Commands and results

TODO

## Critique

TODO

## Proposed plan changes

TODO
""",
    "copilot-evidence.md": """# Co-pilot evidence

## Sandbox and baseline

TODO

## Commands and results

TODO

## Critique

TODO

## Proposed plan changes

TODO
""",
    "reconciliation.md": """# Reconciliation

## Evidence accepted

TODO

## Disagreements and uncertainty

TODO

## Frozen plan

TODO

## Acceptance gates

TODO
""",
    "execution.md": """# Driver execution

## Steps and results

TODO

## Deviations

TODO
""",
    "validation.md": """# Validation

## Checks

TODO

## Outcome

TODO

## Residual risks

TODO
""",
}

ALLOWED_TOP_LEVEL = set(TEMPLATES) | {"state.json", "artifacts"}

# The protected set is every top-level entry the co-pilot does not own: the
# driver-owned Markdown plus state.json. `copilot-evidence.md` and the shared,
# bounded `artifacts/` directory are intentionally excluded because the co-pilot
# legitimately writes them. The driver seals digests of this set outside the
# session directory before granting the co-pilot write and re-checks afterward.
PROTECTED_ENTRIES = tuple(
    sorted(["state.json"] + [name for name in TEMPLATES if name != COPILOT_OWNED])
)
STAGE_INPUTS = {
    "independent": ("state.json", "charter.md", "plan.md"),
    "reciprocal": (
        "state.json",
        "charter.md",
        "plan.md",
        "driver-evidence.md",
        "copilot-evidence.md",
    ),
}

REQUIRED_BY_PHASE = {
    "planning": (),
    "discussing": ("charter.md", "plan.md"),
    "ready-for-execution": (
        "charter.md",
        "plan.md",
        "driver-evidence.md",
        "copilot-evidence.md",
        "reconciliation.md",
    ),
    "executing": (
        "charter.md",
        "plan.md",
        "driver-evidence.md",
        "copilot-evidence.md",
        "reconciliation.md",
    ),
    "validating": tuple(TEMPLATES)[:-1],
    "complete": tuple(TEMPLATES),
}


def fail(message: str) -> "NoReturn":
    print(f"cowork-session: {message}", file=sys.stderr)
    raise SystemExit(1)


def now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()


def session_path(raw: str) -> Path:
    path = Path(os.path.abspath(os.path.expanduser(raw)))
    if path == Path(path.anchor):
        fail("refusing a filesystem root as the session directory")
    return path


def write_json_atomic(path: Path, value: dict) -> None:
    temporary = path.with_name(f".{path.name}.{os.getpid()}.tmp")
    temporary.write_text(json.dumps(value, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    os.replace(temporary, path)


def sha256_bytes(value: bytes) -> str:
    return hashlib.sha256(value).hexdigest()


STATE_TOP_LEVEL_KEYS = (
    "schema_version",
    "driver",
    "copilot",
    "phase",
    "created_at",
    "updated_at",
)
STATE_PREDECESSOR_KEYS = ("driver", "path", "phase", "state_sha256")


def project_stage_state(raw: bytes) -> bytes:
    """Project state.json for staging: a fail-closed, path-free view.

    A blinded co-pilot needs the roles, phase, timestamps, and schema version
    but never an absolute path. `predecessor.path` is a local filesystem path
    (and a future field could add another), so whitelist exactly the schema-1
    fields, drop `predecessor.path`, and refuse any unknown or missing key. This
    is fail-closed by design: a legitimate additive state field cannot stage
    until this projection classifies it, which prevents silently exporting a new
    path and prevents silently dropping a field from the staleness comparison.
    """
    value = json.loads(raw.decode("utf-8"))
    if not isinstance(value, dict):
        fail("state is not a JSON object")
    allowed = set(STATE_TOP_LEVEL_KEYS) | {"predecessor"}
    if not set(STATE_TOP_LEVEL_KEYS) <= set(value) or not set(value) <= allowed:
        fail("state has unexpected or missing keys for staging")
    projected = {name: value[name] for name in STATE_TOP_LEVEL_KEYS}
    if "predecessor" in value:
        predecessor = value["predecessor"]
        if not isinstance(predecessor, dict) or set(predecessor) != set(
            STATE_PREDECESSOR_KEYS
        ):
            fail("predecessor has unexpected or missing keys for staging")
        projected["predecessor"] = {
            name: predecessor[name]
            for name in STATE_PREDECESSOR_KEYS
            if name != "path"
        }
    return (json.dumps(projected, indent=2, sort_keys=True) + "\n").encode("utf-8")


def write_new_file(path: Path, value: bytes, mode: int = 0o600) -> None:
    descriptor = os.open(path, os.O_WRONLY | os.O_CREAT | os.O_EXCL, mode)
    try:
        os.fchmod(descriptor, mode)
        handle = os.fdopen(descriptor, "wb")
        descriptor = -1
        with handle:
            handle.write(value)
            handle.flush()
            os.fsync(handle.fileno())
    finally:
        if descriptor >= 0:
            os.close(descriptor)


def require_owned_kind(path: Path, kind: str) -> None:
    try:
        metadata = path.lstat()
    except FileNotFoundError:
        fail(f"missing protocol entry: {path}")
    expected = stat.S_ISDIR if kind == "directory" else stat.S_ISREG
    if not expected(metadata.st_mode):
        fail(f"protocol {kind} must be real and not a symlink: {path}")
    if metadata.st_uid != os.getuid():
        fail(f"protocol {kind} is owned by another uid: {path}")
    if kind != "directory" and metadata.st_nlink != 1:
        fail(
            f"protocol file must not be a hard link: {path} "
            f"(link count {metadata.st_nlink})"
        )


def validate_layout(root: Path) -> None:
    require_owned_kind(root, "directory")
    names = {entry.name for entry in root.iterdir()}
    missing = sorted(ALLOWED_TOP_LEVEL - names)
    unexpected = sorted(names - ALLOWED_TOP_LEVEL)
    if missing:
        fail(f"missing top-level protocol entries: {', '.join(missing)}")
    if unexpected:
        fail(f"unexpected top-level protocol entries: {', '.join(unexpected)}")
    require_owned_kind(root / "artifacts", "directory")
    require_owned_kind(root / "state.json", "file")
    for name in TEMPLATES:
        require_owned_kind(root / name, "file")


def load_state(root: Path) -> dict:
    validate_layout(root)
    state_path = root / "state.json"
    try:
        value = json.loads(state_path.read_text(encoding="utf-8"))
    except FileNotFoundError:
        fail(f"missing state file: {state_path}")
    except json.JSONDecodeError as exc:
        fail(f"invalid state JSON: {exc}")
    if value.get("schema_version") != SCHEMA_VERSION:
        fail("unsupported schema version")
    driver = value.get("driver")
    copilot = value.get("copilot")
    if driver not in CLIENTS or copilot not in CLIENTS or driver == copilot:
        fail("state must name different codex and claude roles")
    if value.get("phase") not in PHASES:
        fail("state has an unknown phase")
    return value


def has_todo(text: str) -> bool:
    return re.search(r"(?m)^\s*TODO\s*$", text) is not None


def validate_named_text(name: str, text: str) -> None:
    if has_todo(text):
        fail(f"{name} still contains an unresolved TODO marker")
    position = -1
    for heading in re.findall(r"(?m)^##? .+$", TEMPLATES[name]):
        match = re.search(rf"(?m)^{re.escape(heading)}$", text)
        if match is None:
            fail(f"{name} is missing required heading: {heading}")
        if match.start() <= position:
            fail(f"{name} has required headings out of order: {heading}")
        position = match.start()


def validate_files(root: Path, phase: str) -> None:
    for name in REQUIRED_BY_PHASE[phase]:
        path = root / name
        try:
            text = path.read_text(encoding="utf-8")
        except FileNotFoundError:
            fail(f"{phase} requires {name}")
        validate_named_text(name, text)


def predecessor_record(raw: str) -> dict:
    """Snapshot a prior session's provenance without inheriting its authority."""
    pred_root = session_path(raw)
    pred_state = load_state(pred_root)
    # Validate the predecessor's phase-required content before snapshotting its
    # provenance, so a recorded phase cannot describe a session whose Markdown
    # never satisfied it. This runs before any successor directory is created.
    validate_files(pred_root, pred_state["phase"])
    pred_bytes = (pred_root / "state.json").read_bytes()
    return {
        "path": str(pred_root),
        "driver": pred_state["driver"],
        "phase": pred_state["phase"],
        "state_sha256": hashlib.sha256(pred_bytes).hexdigest(),
    }


def stage_path_outside_session(root: Path, raw: str) -> Path:
    stage_root = session_path(raw)
    if stage_root.exists() or stage_root.is_symlink():
        fail(f"stage path already exists: {stage_root}")
    require_owned_kind(stage_root.parent, "directory")
    root_real = root.resolve()
    stage_real = stage_root.parent.resolve() / stage_root.name
    try:
        stage_real.relative_to(root_real)
    except ValueError:
        return stage_root
    fail("stage directory must be outside the live session")


def stage_session(args: argparse.Namespace) -> None:
    root = session_path(args.session_dir)
    state = load_state(root)
    if state["phase"] != "discussing":
        fail("staging requires a discussing session")
    validate_files(root, "discussing")
    inputs = STAGE_INPUTS[args.mode]
    if args.mode == "reciprocal":
        for name in ("driver-evidence.md", COPILOT_OWNED):
            validate_named_text(name, (root / name).read_text(encoding="utf-8"))

    # Project state.json before creating the stage so a fail-closed refusal
    # (unknown/missing key) leaves no partial stage directory.
    projected_state = project_stage_state((root / "state.json").read_bytes())
    stage_root = stage_path_outside_session(root, args.stage_dir)
    stage_root.mkdir(mode=0o700)
    stage_root.chmod(0o700)
    (stage_root / "artifacts").mkdir(mode=0o700)
    (stage_root / "artifacts").chmod(0o700)
    input_hashes = {}
    for name in inputs:
        data = projected_state if name == "state.json" else (root / name).read_bytes()
        write_new_file(stage_root / name, data)
        input_hashes[name] = sha256_bytes(data)
    candidate = (
        TEMPLATES[COPILOT_OWNED].encode("utf-8")
        if args.mode == "independent"
        else (root / COPILOT_OWNED).read_bytes()
    )
    write_new_file(stage_root / COPILOT_CANDIDATE, candidate)
    stage_state = {
        "schema_version": STAGE_SCHEMA_VERSION,
        "mode": args.mode,
        "driver": state["driver"],
        "copilot": state["copilot"],
        "phase": state["phase"],
        "inputs": input_hashes,
    }
    write_new_file(
        stage_root / "stage.json",
        (json.dumps(stage_state, indent=2, sort_keys=True) + "\n").encode("utf-8"),
    )
    print(f"staged {args.mode} exchange: {stage_root}")


def load_stage(stage_root: Path) -> dict:
    require_owned_kind(stage_root, "directory")
    require_owned_kind(stage_root / "stage.json", "file")
    try:
        stage_state = json.loads((stage_root / "stage.json").read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        fail(f"invalid stage JSON: {exc}")
    if stage_state.get("schema_version") != STAGE_SCHEMA_VERSION:
        fail("unsupported stage schema version")
    mode = stage_state.get("mode")
    if mode not in STAGE_INPUTS:
        fail("stage has an unknown mode")
    expected_keys = {"schema_version", "mode", "driver", "copilot", "phase", "inputs"}
    if set(stage_state) != expected_keys:
        fail("stage metadata has unexpected or missing keys")
    inputs = STAGE_INPUTS[mode]
    if set(stage_state.get("inputs", {})) != set(inputs):
        fail("stage metadata has unexpected or missing input hashes")
    expected_entries = set(inputs) | {
        "stage.json",
        "artifacts",
        COPILOT_CANDIDATE,
    }
    names = {entry.name for entry in stage_root.iterdir()}
    if names != expected_entries:
        missing = sorted(expected_entries - names)
        unexpected = sorted(names - expected_entries)
        details = []
        if missing:
            details.append(f"missing: {', '.join(missing)}")
        if unexpected:
            details.append(f"unexpected: {', '.join(unexpected)}")
        fail(f"invalid stage layout ({'; '.join(details)})")
    require_owned_kind(stage_root / "artifacts", "directory")
    require_owned_kind(stage_root / COPILOT_CANDIDATE, "file")
    for name in inputs:
        require_owned_kind(stage_root / name, "file")
    return stage_state


def atomic_replace_bytes(path: Path, value: bytes) -> None:
    descriptor, temporary_raw = tempfile.mkstemp(
        prefix=f".{path.name}.", suffix=".tmp", dir=path.parent
    )
    temporary = Path(temporary_raw)
    replaced = False
    try:
        os.fchmod(descriptor, 0o600)
        with os.fdopen(descriptor, "wb") as handle:
            descriptor = -1
            handle.write(value)
            handle.flush()
            os.fsync(handle.fileno())
            if os.fstat(handle.fileno()).st_dev != path.parent.stat().st_dev:
                fail("import temporary file is not on the session filesystem")
        os.replace(temporary, path)
        replaced = True
        directory_descriptor = os.open(path.parent, os.O_RDONLY | os.O_DIRECTORY)
        try:
            os.fsync(directory_descriptor)
        finally:
            os.close(directory_descriptor)
    finally:
        if descriptor >= 0:
            os.close(descriptor)
        if not replaced and (temporary.exists() or temporary.is_symlink()):
            temporary.unlink()


def import_copilot(args: argparse.Namespace) -> None:
    root = session_path(args.session_dir)
    state = load_state(root)
    if state["phase"] != "discussing":
        fail("co-pilot import requires a discussing session")
    validate_files(root, "discussing")
    stage_root = session_path(args.stage_dir)
    root_real = root.resolve()
    stage_real = stage_root.resolve()
    try:
        stage_real.relative_to(root_real)
    except ValueError:
        pass
    else:
        fail("stage directory must be outside the live session")
    stage_state = load_stage(stage_root)
    if stage_state["driver"] != state["driver"] or stage_state["copilot"] != state["copilot"]:
        fail("stage roles no longer match the live session")
    if stage_state["phase"] != "discussing":
        fail("stage phase is not discussing")

    for name in STAGE_INPUTS[stage_state["mode"]]:
        staged = (stage_root / name).read_bytes()
        expected = stage_state["inputs"][name]
        if sha256_bytes(staged) != expected:
            fail(f"staged input digest mismatch: {name}")
        live = (root / name).read_bytes()
        if name == "state.json":
            live = project_stage_state(live)
        if live != staged or sha256_bytes(live) != expected:
            fail(f"staged input is stale relative to the live session: {name}")

    candidate_path = stage_root / COPILOT_CANDIDATE
    if candidate_path.stat().st_size > MAX_CANDIDATE_BYTES:
        fail(f"co-pilot candidate exceeds {MAX_CANDIDATE_BYTES} bytes")
    candidate = candidate_path.read_bytes()
    try:
        candidate_text = candidate.decode("utf-8")
    except UnicodeDecodeError:
        fail("co-pilot candidate is not valid UTF-8")
    validate_named_text(COPILOT_OWNED, candidate_text)

    destination = root / COPILOT_OWNED
    previous = destination.read_bytes()
    try:
        atomic_replace_bytes(destination, candidate)
        require_owned_kind(destination, "file")
        validate_files(root, "discussing")
    except BaseException:
        if destination.read_bytes() != previous:
            atomic_replace_bytes(destination, previous)
        raise
    print(
        f"imported {stage_state['mode']} co-pilot evidence "
        f"sha256={sha256_bytes(candidate)}"
    )


def init(args: argparse.Namespace) -> None:
    root = session_path(args.session_dir)
    if root.exists():
        fail(f"session path already exists: {root}")
    copilot = (CLIENTS - {args.driver}).pop()
    predecessor = predecessor_record(args.predecessor) if args.predecessor else None
    root.mkdir(parents=True, mode=0o700)
    timestamp = now()
    state = {
        "schema_version": SCHEMA_VERSION,
        "driver": args.driver,
        "copilot": copilot,
        "phase": "planning",
        "created_at": timestamp,
        "updated_at": timestamp,
    }
    if predecessor is not None:
        state["predecessor"] = predecessor
    write_json_atomic(root / "state.json", state)
    for name, content in TEMPLATES.items():
        (root / name).write_text(content, encoding="utf-8")
    (root / "artifacts").mkdir(mode=0o700)
    message = f"initialized {root} with {args.driver} driving {copilot}"
    if predecessor is not None:
        message += (
            f" (predecessor {predecessor['driver']} at {predecessor['phase']})"
        )
    print(message)


def check(args: argparse.Namespace) -> None:
    root = session_path(args.session_dir)
    state = load_state(root)
    phase = args.phase or state["phase"]
    if phase not in PHASES:
        fail(f"unknown phase: {phase}")
    validate_files(root, phase)
    print(f"valid {phase} session: {root}")


def digests(args: argparse.Namespace) -> None:
    root = session_path(args.session_dir)
    validate_layout(root)
    for name in PROTECTED_ENTRIES:
        data = (root / name).read_bytes()
        print(f"{hashlib.sha256(data).hexdigest()}  {name}")


def advance(args: argparse.Namespace) -> None:
    root = session_path(args.session_dir)
    state = load_state(root)
    current_index = PHASES.index(state["phase"])
    target_index = PHASES.index(args.phase)
    if target_index == current_index:
        validate_files(root, args.phase)
        print(f"already at valid phase {args.phase}: {root}")
        return
    if target_index != current_index + 1:
        fail(f"invalid transition {state['phase']} -> {args.phase}")
    validate_files(root, args.phase)
    state["phase"] = args.phase
    state["updated_at"] = now()
    write_json_atomic(root / "state.json", state)
    print(f"advanced {root} to {args.phase}")


def parser() -> argparse.ArgumentParser:
    result = argparse.ArgumentParser(description=__doc__)
    commands = result.add_subparsers(dest="command", required=True)
    init_parser = commands.add_parser("init", help="create a new exchange directory")
    init_parser.add_argument("session_dir")
    init_parser.add_argument("--driver", required=True, choices=sorted(CLIENTS))
    init_parser.add_argument(
        "--predecessor",
        help="record a prior session's provenance for a cross-product takeover",
    )
    init_parser.set_defaults(handler=init)
    check_parser = commands.add_parser("check", help="validate current or named phase")
    check_parser.add_argument("session_dir")
    check_parser.add_argument("--phase", choices=PHASES)
    check_parser.set_defaults(handler=check)
    digests_parser = commands.add_parser(
        "digests", help="print sha256 of the protected (non-co-pilot) entries"
    )
    digests_parser.add_argument("session_dir")
    digests_parser.set_defaults(handler=digests)
    stage_parser = commands.add_parser(
        "stage", help="copy bounded session inputs into a fresh co-pilot stage"
    )
    stage_parser.add_argument("session_dir")
    stage_parser.add_argument("stage_dir")
    stage_parser.add_argument("--mode", required=True, choices=sorted(STAGE_INPUTS))
    stage_parser.set_defaults(handler=stage_session)
    import_parser = commands.add_parser(
        "import-copilot", help="validate and atomically import staged co-pilot evidence"
    )
    import_parser.add_argument("session_dir")
    import_parser.add_argument("stage_dir")
    import_parser.set_defaults(handler=import_copilot)
    advance_parser = commands.add_parser("advance", help="validate and advance one phase")
    advance_parser.add_argument("session_dir")
    advance_parser.add_argument("phase", choices=PHASES[1:])
    advance_parser.set_defaults(handler=advance)
    return result


def main() -> None:
    args = parser().parse_args()
    args.handler(args)


if __name__ == "__main__":
    main()
