{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "status",
    "response"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "complete",
        "blocked",
        "rejected",
        "failed"
      ]
    },
    "response": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    }
  }
}
