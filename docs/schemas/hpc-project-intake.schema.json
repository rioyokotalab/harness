{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rioyokotalab.github.io/harness/schemas/hpc-project-intake.schema.json",
  "title": "HPC project intake",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "status", "project", "software", "environment", "scheduler", "data", "validation", "authority"],
  "properties": {
    "schema": {"const": 1},
    "status": {"enum": ["draft", "ready"]},
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "workload", "target_hosts"],
      "properties": {
        "project_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]{1,64}$"},
        "workload": {"enum": ["llm_training", "scientific_hpc", "both"]},
        "target_hosts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["local", "ab", "ab2", "ri", "al", "rc", "t4"]}
        }
      }
    },
    "software": {
      "type": "object",
      "additionalProperties": false,
      "required": ["framework", "language_standards", "mpi_required", "scientific_libraries"],
      "properties": {
        "framework": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "lock_evidence"],
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "version": {"type": "string", "minLength": 1},
            "lock_evidence": {"type": "string", "minLength": 1}
          }
        },
        "language_standards": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "mpi_required": {"type": "boolean"},
        "scientific_libraries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "features", "abi_constraints"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "features": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "abi_constraints": {"type": "array", "items": {"type": "string", "minLength": 1}}
            }
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mechanism", "artifacts"],
      "properties": {
        "mechanism": {"enum": ["project_lock", "module", "uenv", "container", "composite"]},
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["architecture", "reference", "digest"],
            "properties": {
              "architecture": {"enum": ["x86_64", "aarch64"]},
              "reference": {"type": "string", "minLength": 1},
              "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
            }
          }
        }
      }
    },
    "scheduler": {
      "type": "object",
      "additionalProperties": false,
      "required": ["route_source", "account_confirmed", "resources"],
      "properties": {
        "route_source": {"enum": ["project_script", "reviewed_profile"]},
        "account_confirmed": {"type": "boolean"},
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "required": ["nodes", "tasks_per_node", "cpus_per_task", "accelerators_per_node", "duration", "priority"],
          "properties": {
            "nodes": {"type": "integer", "minimum": 1},
            "tasks_per_node": {"type": "integer", "minimum": 1},
            "cpus_per_task": {"type": "integer", "minimum": 1},
            "accelerators_per_node": {"type": "integer", "minimum": 0},
            "duration": {"type": "string", "pattern": "^[0-9]{2}:[0-9]{2}:[0-9]{2}$"},
            "priority": {"enum": ["default", "explicitly_authorized"]}
          }
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_boundary_ref", "output_boundary_ref", "checkpoint_boundary_ref", "retention_policy_ref"],
      "properties": {
        "input_boundary_ref": {"type": "string", "minLength": 1},
        "output_boundary_ref": {"type": "string", "minLength": 1},
        "checkpoint_boundary_ref": {"type": "string", "minLength": 1},
        "retention_policy_ref": {"type": "string", "minLength": 1}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["correctness_gate", "numerical_contract", "checkpoint_contract", "performance_deferred"],
      "properties": {
        "correctness_gate": {"type": "string", "minLength": 1},
        "numerical_contract": {"type": "string", "minLength": 1},
        "checkpoint_contract": {"type": "string", "minLength": 1},
        "performance_deferred": {"const": true}
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["licenses_reviewed", "external_downloads_authorized", "credential_refs"],
      "properties": {
        "licenses_reviewed": {"type": "boolean"},
        "external_downloads_authorized": {"type": "boolean"},
        "credential_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Za-z0-9._-]{1,64}$"}
        }
      }
    }
  }
}
