+def seal_location_ok(session_root: Path, stage_parent: Path, seal_raw: str) -> Path:
+    """Resolve a seal path and refuse the live session or co-pilot sandbox tree.
+
+    A seal that anchors co-pilot-writable ``stage.json`` must itself sit outside
+    every co-pilot-writable tree. We approximate the co-pilot sandbox as the
+    stage's parent directory (the protocol places each stage directly inside that
+    sandbox) and also refuse the live session. This cannot know arbitrary other
+    writable paths a same-user process might reach, so callers must place the seal
+    in a directory outside any co-pilot-writable tree; that residual is documented,
+    not silently assumed safe.
+    """
+    seal_path = session_path(seal_raw)
+    resolved = seal_path.parent.resolve() / seal_path.name
+    for forbidden in (session_root.resolve(), stage_parent.resolve()):
+        try:
+            resolved.relative_to(forbidden)
+        except ValueError:
+            continue
+        fail("seal must be outside the live session and stage-parent sandbox")
+    return seal_path
+
+
+def load_seal(seal_raw: str, session_root: Path, stage_root: Path) -> dict:
+    seal_path = seal_location_ok(session_root, stage_root.parent, seal_raw)
+    require_owned_kind(seal_path, "file")
+    try:
+        value = json.loads(seal_path.read_text(encoding="utf-8"))
+    except (FileNotFoundError, UnicodeDecodeError) as exc:
+        fail(f"unreadable seal: {exc}")
+    except json.JSONDecodeError as exc:
+        fail(f"invalid seal JSON: {exc}")
+    if not isinstance(value, dict) or set(value) != SEAL_KEYS:
+        fail("seal has unexpected or missing keys")
+    if value["schema_version"] != SEAL_SCHEMA_VERSION:
+        fail("unsupported seal schema version")
+    if not is_sha256(value.get("stage_manifest_sha256")) or not is_sha256(
+        value.get("destination_before_sha256")
+    ):
+        fail("seal has an invalid hash")
+    return value
+
+
