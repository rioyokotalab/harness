#!/bin/sh
set -eu

die() {
    echo "harness: $*" >&2
    exit 2
}

require_safe_id() {
    value=$1
    case "$value" in
        ''|*[!A-Za-z0-9._-]*)
            die "invalid logical host identifier: $value"
            ;;
    esac
}

path_kind() {
    path=$1
    if [ -L "$path" ]; then
        printf '%s\n' symlink
    elif [ -f "$path" ]; then
        printf '%s\n' regular
    elif [ -d "$path" ]; then
        printf '%s\n' directory
    elif [ -e "$path" ]; then
        printf '%s\n' other
    else
        printf '%s\n' absent
    fi
}

usage() {
    echo "Usage: harness inventory [--host LOGICAL_ID] [--format text|json]" >&2
}

logical_host=unassigned
format=text
while [ "$#" -gt 0 ]; do
    case "$1" in
        --host)
            [ "$#" -ge 2 ] || { usage; exit 2; }
            logical_host=$2
            shift 2
            ;;
        --format)
            [ "$#" -ge 2 ] || { usage; exit 2; }
            format=$2
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage
            exit 2
            ;;
    esac
done
require_safe_id "$logical_host"
case "$format" in text|json) ;; *) die "unsupported format: $format" ;; esac

# Managed user tools are part of the portable environment even when a remote
# non-interactive shell omits ~/.local/bin from its inherited PATH.
PATH=$HOME/.local/bin:$PATH

# Site scheduler commands may be installed through login-shell PATH setup that
# a read-only non-interactive probe intentionally does not source. When invoked
# from a checkout, append only explicit, existing absolute directories from the
# logical host profile. Existing user and inherited site commands retain
# precedence.
if [ -n "${HARNESS_ROOT:-}" ]; then
    command_path_profile=$HARNESS_ROOT/profiles/hosts/$logical_host.conf
    if [ -f "$command_path_profile" ]; then
        site_command_paths=$(sed -n 's/^command_paths=//p' "$command_path_profile")
        site_command_path_count=$(printf '%s\n' "$site_command_paths" |
            awk 'NF { n++ } END { print n + 0 }')
        [ "$site_command_path_count" -le 1 ] || die "duplicate command_paths profile key"
        old_ifs=$IFS
        IFS=,
        for site_command_path in $site_command_paths; do
            [ "$site_command_path" = none ] && continue
            case "$site_command_path" in
                /*) ;;
                *) die "site command path must be absolute" ;;
            esac
            case "$site_command_path" in
                *[!A-Za-z0-9._/-]*) die "unsafe site command path" ;;
            esac
            if [ -d "$site_command_path" ] && [ ! -L "$site_command_path" ]; then
                PATH=$PATH:$site_command_path
            fi
        done
        IFS=$old_ifs
    fi
fi
export PATH

safe_value() {
    printf '%s' "$1" | tr -cd 'A-Za-z0-9._+-'
}

command_version() {
    raw_version=$($1 --version 2>/dev/null | sed -n '1p' || true)
    cleaned_version=$(safe_value "$raw_version")
    if [ -n "$cleaned_version" ]; then
        printf '%s\n' "$cleaned_version"
    else
        printf '%s\n' unknown
    fi
}

os_id=unknown
os_version=unknown
if [ -r /etc/os-release ]; then
    raw_id=$(sed -n 's/^ID=//p' /etc/os-release | sed -n '1p' | tr -d '"')
    raw_version=$(sed -n 's/^VERSION_ID=//p' /etc/os-release | sed -n '1p' | tr -d '"')
    [ -n "$raw_id" ] && os_id=$(safe_value "$raw_id")
    [ -n "$raw_version" ] && os_version=$(safe_value "$raw_version")
fi
arch=$(safe_value "$(uname -m 2>/dev/null || echo unknown)")
kernel=$(safe_value "$(uname -r 2>/dev/null || echo unknown)")
raw_shell=${SHELL:-}
login_shell=$(safe_value "${raw_shell##*/}")
[ -n "$login_shell" ] || login_shell=unknown

version_at_least() {
    awk -v have="$1" -v need="$2" 'BEGIN {
        nh = split(have, h, "."); nn = split(need, n, ".")
        if (nh != 3 || nn != 3) exit 1
        for (i = 1; i <= 3; i++) {
            if (h[i] !~ /^[0-9]+$/ || n[i] !~ /^[0-9]+$/) exit 1
            if ((h[i] + 0) > (n[i] + 0)) exit 0
            if ((h[i] + 0) < (n[i] + 0)) exit 1
        }
        exit 0
    }'
}

generate_facts() {
    echo "schema=1"
    echo "logical_host=$logical_host"
    echo "os_id=$os_id"
    echo "os_version=$os_version"
    echo "arch=$arch"
    echo "kernel=$kernel"
    echo "login_shell=$login_shell"

    for command_name in \
        sh bash git vim tmux rg jq tree rsync curl wget htop sqlite3 \
        python3 uv node npm codex claude rclone lftp tectonic shellcheck \
        cc gcc g++ gfortran clang clang++ nvc nvc++ nvfortran \
        make cmake ninja meson pkg-config gdb lldb cuda-gdb valgrind \
        perf strace nsys ncu \
        mpicc mpicxx mpifort mpirun mpiexec git-lfs \
        modulecmd ml uenv yrun ybatch sbatch srun squeue scancel \
        sinfo scontrol qsub qstat qdel qrsh nodestatus \
        singularity apptainer docker podman \
        nvcc nvidia-smi rocminfo rocm-smi
    do
        if command -v "$command_name" >/dev/null 2>&1; then
            if [ "$command_name" = ninja ] &&
                ! "$command_name" --version >/dev/null 2>&1; then
                state=unusable
            elif { [ "$command_name" = singularity ] ||
                    [ "$command_name" = apptainer ] ||
                    [ "$command_name" = docker ] ||
                    [ "$command_name" = podman ]; } &&
                ! "$command_name" --version >/dev/null 2>&1; then
                state=unusable
            elif [ "$command_name" = sqlite3 ] &&
                ! sqlite3 -batch -noheader -init /dev/null :memory: \
                    'select json_valid('"'"'{"ok":1}'"'"'); create virtual table f using fts5(x); create virtual table r using rtree(id,x1,x2); select 1;' \
                    >/dev/null 2>&1; then
                state=unusable
            elif [ "$command_name" = git-lfs ]; then
                lfs_line=$(git-lfs version 2>/dev/null | sed -n '1p' || true)
                lfs_version=${lfs_line#git-lfs/}
                lfs_version=${lfs_version%% *}
                if version_at_least "$lfs_version" 3.7.1; then
                    state=present
                else
                    state=unusable
                fi
            elif [ "$command_name" = shellcheck ] &&
                ! shellcheck --version 2>/dev/null |
                    awk '$0 == "version: 0.11.0" { matched = 1 }
                        END { exit matched ? 0 : 1 }'; then
                state=unusable
            else
                state=present
            fi
        else
            state=absent
        fi
        fact_name=$(printf '%s' "$command_name" | sed 's/+/p/g; s/-/_/g')
        echo "tool_${fact_name}=$state"
    done

    echo "tool_node_version=$(command_version node)"
    echo "tool_npm_version=$(command_version npm)"

    if [ -d "$HOME/harness/.git" ]; then
        echo "harness_checkout=present"
    else
        echo "harness_checkout=absent"
    fi
    echo "link_codex_guidance=$(path_kind "$HOME/.codex/AGENTS.md")"
    echo "link_codex_rules=$(path_kind "$HOME/.codex/rules/default.rules")"
    echo "link_claude_guidance=$(path_kind "$HOME/.claude/CLAUDE.md")"
    echo "startup_bashrc=$(path_kind "$HOME/.bashrc")"
    echo "startup_bash_profile=$(path_kind "$HOME/.bash_profile")"
    echo "startup_bash_login=$(path_kind "$HOME/.bash_login")"
    echo "startup_profile=$(path_kind "$HOME/.profile")"
    echo "startup_bash_logout=$(path_kind "$HOME/.bash_logout")"
}

if [ "$format" = text ]; then
    generate_facts
else
    generate_facts | awk -F= '
        BEGIN { print "{"; first = 1 }
        {
            key = $1
            value = substr($0, length(key) + 2)
            gsub(/\\/, "\\\\", value)
            gsub(/"/, "\\\"", value)
            if (!first) printf ",\n"
            printf "  \"%s\": \"%s\"", key, value
            first = 0
        }
        END { print "\n}" }
    '
fi
