#!/bin/sh
set -eu

SELF_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
HARNESS_ROOT=${HARNESS_ROOT:-$(CDPATH='' cd -- "$SELF_DIR/.." && pwd)}
export HARNESS_ROOT
. "$SELF_DIR/harness-common"

usage() {
    echo "Usage: harness build-tool --host LOGICAL_ID --name TOOL [--facts FILE] [--plan|--apply]" >&2
}

logical_host=
tool_name=
fact_file=
mode=plan
while [ "$#" -gt 0 ]; do
    case "$1" in
        --host) [ "$#" -ge 2 ] || { usage; exit 2; }; logical_host=$2; shift 2 ;;
        --name) [ "$#" -ge 2 ] || { usage; exit 2; }; tool_name=$2; shift 2 ;;
        --facts) [ "$#" -ge 2 ] || { usage; exit 2; }; fact_file=$2; shift 2 ;;
        --plan) mode=plan; shift ;;
        --apply) mode=apply; shift ;;
        *) usage; exit 2 ;;
    esac
done
[ -n "$logical_host" ] && [ -n "$tool_name" ] || { usage; exit 2; }
require_safe_id "$tool_name"
case "$tool_name" in sqlite|tree|tmux|htop) ;; *) die "unsupported source-built tool: $tool_name" ;; esac
[ "$mode" != apply ] || [ -z "$fact_file" ] || die "build-tool apply does not accept captured facts"

profile=$(profile_for "$logical_host")
arch=$(config_get "$profile" arch)
records=$(awk -F'|' -v tool="$tool_name" '$1 == tool && $3 == "linux" && $4 == "any" { print }' \
    "$HARNESS_ROOT/tools/sources.tsv")
count=$(printf '%s\n' "$records" | awk 'NF { n++ } END { print n + 0 }')
[ "$count" -eq 1 ] || die "no unique source record for tool=$tool_name"
IFS='|' read -r record_tool version source_os source_arch format url checksum \
    publisher_sha3 root binary version_prefix <<EOF
$records
EOF
case "$record_tool:$format" in
    sqlite:zip|tree:tar.gz|tmux:tar.gz|htop:tar.xz) ;;
    *) die "source manifest mismatch" ;;
esac
[ "$source_arch" = any ] || die "source manifest architecture mismatch"
for value in "$version" "$root" "$binary"; do require_safe_id "$value"; done
case "$url" in https://*) ;; *) die "source URL must use HTTPS" ;; esac
case "$checksum" in *[!0-9a-f]*) die "invalid source digest" ;; esac
[ "${#checksum}" -eq 64 ] || die "invalid source digest length"
if [ "$publisher_sha3" != none ]; then
    case "$publisher_sha3" in *[!0-9a-f]*) die "invalid publisher source digest" ;; esac
    [ "${#publisher_sha3}" -eq 64 ] || die "invalid publisher source digest length"
fi

dependency_name=none
dependency_version=none
dependency_format=none
dependency_url=none
dependency_checksum=none
dependency_root=none
dependency_entries=0
if [ "$tool_name" = tmux ]; then
    dependency_records=$(awk -F'|' -v tool="$tool_name" '$1 == tool { print }' \
        "$HARNESS_ROOT/tools/source-dependencies.tsv")
    dependency_count=$(printf '%s\n' "$dependency_records" | awk 'NF { n++ } END { print n + 0 }')
    [ "$dependency_count" -eq 1 ] || die "no unique source dependency for tool=$tool_name"
    IFS='|' read -r dependency_tool dependency_name dependency_version \
        dependency_format dependency_url dependency_checksum dependency_root \
        dependency_entries <<EOF
$dependency_records
EOF
    [ "$dependency_tool" = tmux ] && [ "$dependency_name" = libevent ] &&
        [ "$dependency_format" = tar.gz ] || die "source dependency manifest mismatch"
    for value in "$dependency_name" "$dependency_version" "$dependency_root"; do
        require_safe_id "$value"
    done
    case "$dependency_url" in https://*) ;; *) die "dependency URL must use HTTPS" ;; esac
    case "$dependency_checksum" in *[!0-9a-f]*) die "invalid dependency digest" ;; esac
    [ "${#dependency_checksum}" -eq 64 ] || die "invalid dependency digest length"
    case "$dependency_entries" in ''|*[!0-9]*) die "invalid dependency entry count" ;; esac
    [ "$dependency_entries" -gt 0 ] || die "invalid dependency entry count"
fi

install_dir=$HOME/.local/opt/$tool_name/$version/$source_os-$arch
installed_binary=$install_dir/$binary
stable_link=$HOME/.local/bin/$binary

sqlite_healthy() {
    candidate=$1
    "$candidate" -batch -noheader -init /dev/null :memory: \
        'select json_valid('"'"'{"ok":1}'"'"'); create virtual table f using fts5(x); create virtual table r using rtree(id,x1,x2); select 1;' \
        >/dev/null 2>&1
}

tree_healthy() {
    candidate=$1
    version_line=$("$candidate" --version 2>/dev/null | sed -n '1p' || true)
    case "$version_line" in tree\ v[0-9]*) ;;
        *) return 1 ;;
    esac
    LC_ALL=C "$candidate" --noreport --charset=ASCII \
        "$HARNESS_ROOT/bin/harness" >/dev/null 2>&1
}

tmux_healthy() {
    [ "$("$1" -V 2>/dev/null)" = "$version_prefix" ]
}

htop_healthy() {
    observed=$("$1" --version 2>/dev/null | sed -n '1p' || true)
    case "$observed" in "$version_prefix"|"$version_prefix-"*) return 0 ;; *) return 1 ;; esac
}

source_tool_healthy() {
    case "$tool_name" in
        sqlite) sqlite_healthy "$1" ;;
        tree) tree_healthy "$1" ;;
        tmux) tmux_healthy "$1" ;;
        htop) htop_healthy "$1" ;;
    esac
}

managed_exact=0
if [ -L "$stable_link" ] && [ "$(readlink "$stable_link")" = "$installed_binary" ] &&
    [ -f "$installed_binary" ] && [ ! -L "$installed_binary" ] && [ -x "$installed_binary" ]; then
    managed_exact=1
fi
if [ -n "$fact_file" ]; then
    [ "$(fact_get "$fact_file" logical_host)" = "$logical_host" ] || die "captured fact host mismatch"
    fact_command=$(fact_key_for_command "$binary")
    command_state=$(fact_get "$fact_file" "tool_$fact_command")
elif [ "$managed_exact" -eq 1 ]; then
    case "$tool_name" in
        tmux|htop)
            if source_tool_healthy "$installed_binary"; then
                command_state=present
            else
                command_state=invalid-managed
            fi
            ;;
        *)
            observed_version=$("$installed_binary" --version 2>/dev/null | sed -n '1p' || true)
            case "$observed_version" in "$version_prefix "*)
                if source_tool_healthy "$installed_binary"; then command_state=present; else command_state=invalid-managed; fi ;;
                *) command_state=invalid-managed ;;
            esac
            ;;
    esac
elif command -v "$binary" >/dev/null 2>&1; then
    if source_tool_healthy "$binary"; then command_state=present; else command_state=unusable; fi
else
    command_state=absent
fi
case "$command_state" in present|absent|unusable|invalid-managed) ;;
    *) die "unknown command state: $command_state" ;;
esac
command_source=host-provided
if [ -z "$fact_file" ] && [ "$command_state" = present ] && [ "$managed_exact" -eq 1 ]; then
    command_source=managed-source-build
fi

blocked=0
artifact_action=KEEP
link_action=KEEP
if [ "$command_state" = invalid-managed ]; then
    blocked=1; artifact_action=BLOCK; link_action=BLOCK
elif [ "$command_state" = present ]; then
    :
elif [ -e "$install_dir" ] || [ -L "$install_dir" ]; then
    blocked=1; artifact_action=BLOCK
else
    artifact_action=BUILD
fi
if [ "$command_state" != present ]; then
    if [ -L "$stable_link" ]; then
        if [ "$(readlink "$stable_link")" = "$installed_binary" ]; then link_action=KEEP
        else link_action=BLOCK; blocked=1; fi
    elif [ -e "$stable_link" ]; then link_action=BLOCK; blocked=1
    else link_action=CREATE; fi
fi

echo "BUILD_TOOL_PLAN host=$logical_host tool=$tool_name version=$version arch=$arch mode=$mode"
if [ "$command_state" = invalid-managed ]; then
    echo "BLOCK command=$binary reason=managed-build-version-or-health-mismatch"
elif [ "$command_state" = present ]; then
    echo "KEEP command=$binary source=$command_source"
else
    [ "$command_state" != unusable ] || echo "SHADOW command=$binary reason=host-command-unusable strategy=user-path"
    case "$artifact_action" in
        BUILD) echo "BUILD artifact=$install_dir" ;;
        KEEP) echo "KEEP artifact=$install_dir" ;;
        BLOCK) echo "BLOCK artifact=$install_dir reason=existing-unmanaged-or-invalid" ;;
    esac
    case "$link_action" in
        CREATE) echo "CREATE link=$stable_link source=$installed_binary" ;;
        KEEP) echo "KEEP link=$stable_link" ;;
        BLOCK) echo "BLOCK link=$stable_link reason=existing-unmanaged-path" ;;
    esac
    echo "FETCH url=$url sha256=$checksum publisher_sha3_256=$publisher_sha3"
    case "$tool_name" in
        sqlite)
            echo "EXTRACT exact_root=$root files=sqlite3.c,shell.c,sqlite3.h,sqlite3ext.h"
            echo "COMPILE native='cc -O2 -DSQLITE_THREADSAFE=1 -DSQLITE_ENABLE_FTS5 -DSQLITE_ENABLE_RTREE -DSQLITE_ENABLE_JSON1 -DSQLITE_ENABLE_MATH_FUNCTIONS -DHAVE_READLINE=0 shell.c sqlite3.c -pthread -ldl -lm -o sqlite3'"
            ;;
        tree)
            echo "EXTRACT exact_root=$root regular_files=24 compile_files=Makefile,tree.h,13-c-sources"
            echo "COMPILE native='cc -O2 -DLARGEFILE_SOURCE -D_FILE_OFFSET_BITS=64 color.c file.c filter.c hash.c html.c info.c json.c list.c strverscmp.c tree.c unix.c util.c xml.c -o tree'"
            ;;
        tmux)
            echo "EXTRACT exact_root=$root entries=214 types=regular-only"
            echo "DEPENDENCY name=$dependency_name version=$dependency_version entries=$dependency_entries linkage=static"
            echo "FETCH dependency_url=$dependency_url sha256=$dependency_checksum"
            echo "COMPILE native='./configure --prefix=DEST with pinned static libevent && make -j2'"
            ;;
        htop)
            echo "EXTRACT exact_root=$root entries=382 excluded_symlink=README"
            echo "COMPILE native='./configure --prefix=DEST --without-libunwind && make -j2'"
            ;;
    esac
fi
[ "$blocked" -eq 0 ] || die "build-tool plan contains blocked paths"
[ "$mode" = apply ] || { echo "END build-tool host=$logical_host changes=not-applied"; exit 0; }
[ "$command_state" != present ] || { echo "END build-tool host=$logical_host changes=none"; exit 0; }

[ -z "$(git -C "$HARNESS_ROOT" status --porcelain)" ] || die "build-tool apply requires clean harness"
"$HARNESS_ROOT/libexec/harness-doctor" --host "$logical_host" >/dev/null ||
    die "host doctor failed before build-tool apply"
for required in curl sha256sum cc find readlink; do
    command -v "$required" >/dev/null 2>&1 || die "build-tool apply requires command: $required"
done
case "$tool_name" in
    sqlite) required_archive_commands=unzip ;;
    tree) required_archive_commands='tar gzip' ;;
    tmux) required_archive_commands='tar gzip make pkg-config' ;;
    htop) required_archive_commands='tar xz make pkg-config' ;;
esac
for required in $required_archive_commands; do
    command -v "$required" >/dev/null 2>&1 ||
        die "build-tool apply requires command: $required"
done

state_root=$HOME/.local/state/harness/transactions
mkdir -p "$state_root"; chmod 700 "$HOME/.local/state/harness" "$state_root"
transaction_id=$(date -u +%Y%m%dT%H%M%SZ)-$$
transaction_manifest=$state_root/$transaction_id.manifest
: >"$transaction_manifest"; chmod 600 "$transaction_manifest"
printf 'schema=1\nhost=%s\nrevision=%s\n' "$logical_host" \
    "$(git -C "$HARNESS_ROOT" rev-parse HEAD)" >>"$transaction_manifest"
archive=$(mktemp "$state_root/$transaction_id.source.XXXXXX")
entries=$(mktemp "$state_root/$transaction_id.entries.XXXXXX")
archive_verbose=$(mktemp "$state_root/$transaction_id.verbose.XXXXXX")
dependency_archive=
if [ "$tool_name" = tmux ]; then
    dependency_archive=$(mktemp "$state_root/$transaction_id.dependency.XXXXXX")
fi
build_dir=
stage=
install_parent=
complete=0
cleanup() {
    status=$?
    cleanup_failed=0
    rm -f "$archive" || cleanup_failed=1
    rm -f "$entries" || cleanup_failed=1
    rm -f "$archive_verbose" || cleanup_failed=1
    if [ -n "$dependency_archive" ]; then
        rm -f "$dependency_archive" || cleanup_failed=1
    fi
    if [ -n "$build_dir" ]; then
        guarded_delete_tree "$install_parent" "$build_dir" "$state_root" ||
            cleanup_failed=1
    fi
    if [ -n "$stage" ]; then
        guarded_delete_tree "$install_parent" "$stage" "$state_root" ||
            cleanup_failed=1
    fi
    if [ "$complete" -eq 0 ]; then
        awk -F'|' '$1 == "link" { print $2 "|" $3 }' "$transaction_manifest" |
            while IFS='|' read -r destination source; do
                [ -L "$destination" ] && [ "$(readlink "$destination")" = "$source" ] && rm "$destination"
            done
        awk -F'|' '$1 == "artifact" { print $2 "|" $3 "|" $4 }' "$transaction_manifest" |
            while IFS='|' read -r directory relative expected_hash; do
                candidate=$directory/$relative
                if [ -f "$candidate" ] && [ ! -L "$candidate" ] &&
                    [ "$(sha256sum "$candidate" | awk '{print $1}')" = "$expected_hash" ] &&
                    [ "$(find "$directory" -mindepth 1 -maxdepth 1 | wc -l | tr -d ' ')" -eq 1 ]; then
                    rm "$candidate"; rmdir "$directory"
                fi
            done
        echo failed >"$transaction_manifest.status"; chmod 600 "$transaction_manifest.status"
    fi
    if [ "$status" -eq 0 ] && [ "$cleanup_failed" -ne 0 ]; then
        status=2
    fi
    exit "$status"
}
trap cleanup EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

echo "NATIVE curl --proto =https --tlsv1.2 -fL --retry 2 $url -o SOURCE_STAGING"
curl --proto '=https' --tlsv1.2 -fL --retry 2 "$url" -o "$archive"
printf '%s  %s\n' "$checksum" "$archive" | sha256sum -c - >/dev/null
if [ "$tool_name" = tmux ]; then
    echo "NATIVE curl --proto =https --tlsv1.2 -fL --retry 2 $dependency_url -o DEPENDENCY_STAGING"
    curl --proto '=https' --tlsv1.2 -fL --retry 2 "$dependency_url" \
        -o "$dependency_archive"
    printf '%s  %s\n' "$dependency_checksum" "$dependency_archive" |
        sha256sum -c - >/dev/null
fi
install_parent=${install_dir%/*}; mkdir -p "$install_parent"
build_dir=$(mktemp -d "$install_parent/.build.XXXXXX")
stage=$(mktemp -d "$install_parent/.staging.XXXXXX")
case "$tool_name" in
    sqlite)
        unzip -Z1 "$archive" >"$entries"
        [ "$(wc -l <"$entries" | tr -d ' ')" -eq 5 ] || die "source archive entry count mismatch"
        for expected in "$root/" "$root/sqlite3.c" "$root/shell.c" "$root/sqlite3.h" "$root/sqlite3ext.h"; do
            grep -Fx "$expected" "$entries" >/dev/null || die "source archive missing declared entry: $expected"
        done
        for source_file in sqlite3.c shell.c sqlite3.h sqlite3ext.h; do
            unzip -p "$archive" "$root/$source_file" >"$build_dir/$source_file"
        done
        echo "NATIVE cc -O2 -DSQLITE_THREADSAFE=1 -DSQLITE_ENABLE_FTS5 -DSQLITE_ENABLE_RTREE -DSQLITE_ENABLE_JSON1 -DSQLITE_ENABLE_MATH_FUNCTIONS -DHAVE_READLINE=0 shell.c sqlite3.c -pthread -ldl -lm -o sqlite3"
        cc -O2 -DSQLITE_THREADSAFE=1 -DSQLITE_ENABLE_FTS5 -DSQLITE_ENABLE_RTREE \
            -DSQLITE_ENABLE_JSON1 -DSQLITE_ENABLE_MATH_FUNCTIONS -DHAVE_READLINE=0 \
            "$build_dir/shell.c" "$build_dir/sqlite3.c" -pthread -ldl -lm -o "$stage/$binary"
        ;;
    tree)
        tar -tzf "$archive" >"$entries"
        [ "$(wc -l <"$entries" | tr -d ' ')" -eq 24 ] || die "source archive entry count mismatch"
        tar -tvzf "$archive" | awk '$1 !~ /^-/ { exit 1 }' ||
            die "source archive contains a non-regular entry"
        while IFS= read -r expected; do
            grep -Fx "$root/$expected" "$entries" >/dev/null ||
                die "source archive missing declared entry: $root/$expected"
        done <<'EOF'
CHANGES
INSTALL
LICENSE
Makefile
README
TODO
color.c
file.c
filter.c
hash.c
html.c
info.c
json.c
list.c
strverscmp.c
tree.c
tree.h
unix.c
util.c
xml.c
doc/tree.1
doc/xml.dtd
doc/global_info
.gitignore
EOF
        for source_file in Makefile tree.h color.c file.c filter.c hash.c html.c \
            info.c json.c list.c strverscmp.c tree.c unix.c util.c xml.c; do
            tar -xOzf "$archive" "$root/$source_file" >"$build_dir/$source_file"
        done
        echo "NATIVE cc -O2 -DLARGEFILE_SOURCE -D_FILE_OFFSET_BITS=64 color.c file.c filter.c hash.c html.c info.c json.c list.c strverscmp.c tree.c unix.c util.c xml.c -o tree"
        cc -O2 -DLARGEFILE_SOURCE -D_FILE_OFFSET_BITS=64 \
            "$build_dir/color.c" "$build_dir/file.c" "$build_dir/filter.c" \
            "$build_dir/hash.c" "$build_dir/html.c" "$build_dir/info.c" \
            "$build_dir/json.c" "$build_dir/list.c" "$build_dir/strverscmp.c" \
            "$build_dir/tree.c" "$build_dir/unix.c" "$build_dir/util.c" \
            "$build_dir/xml.c" -o "$stage/$binary"
        ;;
    tmux)
        tar -tzf "$archive" >"$entries"
        [ "$(wc -l <"$entries" | tr -d ' ')" -eq 214 ] ||
            die "tmux source archive entry count mismatch"
        awk -v prefix="$root/" '
            index($0, prefix) != 1 || $0 ~ /(^|\/)\.\.(\/|$)/ || $0 ~ /^\// { exit 1 }
        ' "$entries" || die "tmux source archive contains an unsafe path"
        tar -tvzf "$archive" >"$archive_verbose"
        awk 'substr($1, 1, 1) != "-" { exit 1 }' "$archive_verbose" ||
            die "tmux source archive contains a non-regular entry"

        tar -tzf "$dependency_archive" >"$entries"
        [ "$(wc -l <"$entries" | tr -d ' ')" -eq "$dependency_entries" ] ||
            die "dependency source archive entry count mismatch"
        awk -v prefix="$dependency_root/" '
            index($0, prefix) != 1 || $0 ~ /(^|\/)\.\.(\/|$)/ || $0 ~ /^\// { exit 1 }
        ' "$entries" || die "dependency source archive contains an unsafe path"
        tar -tvzf "$dependency_archive" >"$archive_verbose"
        awk 'substr($1, 1, 1) != "-" && substr($1, 1, 1) != "d" { exit 1 }' \
            "$archive_verbose" || die "dependency source archive contains an unsafe type"

        tar -xzf "$dependency_archive" -C "$build_dir" --no-same-owner \
            --no-same-permissions
        dependency_build=$build_dir/$dependency_root
        [ -d "$dependency_build" ] && [ ! -L "$dependency_build" ] ||
            die "dependency extraction did not create the exact root"
        dependency_prefix=$build_dir/libevent-prefix
        echo "NATIVE ./configure --prefix=DEPENDENCY_PREFIX --disable-shared --enable-static --disable-openssl"
        (cd "$dependency_build" &&
            ./configure --prefix="$dependency_prefix" --disable-shared \
                --enable-static --disable-openssl >/dev/null &&
            make -j2 >/dev/null && make install >/dev/null)
        [ "$(find "$dependency_prefix" -type f -name libevent.a | wc -l | tr -d ' ')" -eq 1 ] ||
            die "static libevent dependency build failed"

        tar -xzf "$archive" -C "$build_dir" --no-same-owner --no-same-permissions
        source_build=$build_dir/$root
        [ -d "$source_build" ] && [ ! -L "$source_build" ] ||
            die "tmux extraction did not create the exact root"
        echo "NATIVE PKG_CONFIG_PATH=DEPENDENCY_PREFIX/lib/pkgconfig ./configure --prefix=DEST && make -j2"
        (cd "$source_build" &&
            PKG_CONFIG_PATH="$dependency_prefix/lib/pkgconfig" \
                ./configure --prefix="$install_dir" >/dev/null &&
            make -j2 >/dev/null)
        cp "$source_build/tmux" "$stage/$binary"
        ;;
    htop)
        tar -tJf "$archive" >"$entries"
        [ "$(wc -l <"$entries" | tr -d ' ')" -eq 382 ] ||
            die "htop source archive entry count mismatch"
        awk -v root="$root" -v prefix="$root/" '
            $0 != root "/" && index($0, prefix) != 1 { exit 1 }
            $0 ~ /(^|\/)\.\.(\/|$)/ || $0 ~ /^\// { exit 1 }
        ' "$entries" || die "htop source archive contains an unsafe path"
        tar -tJvf "$archive" >"$archive_verbose"
        awk -v link="$root/README" '
            substr($1, 1, 1) == "-" || substr($1, 1, 1) == "d" { next }
            substr($1, 1, 1) == "l" && $(NF - 2) == link && $(NF - 1) == "->" && $NF == "README.md" { next }
            { exit 1 }
        ' "$archive_verbose" || die "htop source archive contains an unsafe type"
        tar -xJf "$archive" -C "$build_dir" --no-same-owner \
            --no-same-permissions --exclude="$root/README"
        source_build=$build_dir/$root
        [ -d "$source_build" ] && [ ! -L "$source_build" ] ||
            die "htop extraction did not create the exact root"
        echo "NATIVE ./configure --prefix=DEST --without-libunwind && make -j2"
        (cd "$source_build" &&
            ./configure --prefix="$install_dir" --without-libunwind >/dev/null &&
            make -j2 >/dev/null)
        cp "$source_build/htop" "$stage/$binary"
        ;;
esac
[ -f "$stage/$binary" ] && [ ! -L "$stage/$binary" ] && [ -x "$stage/$binary" ] || die "source build did not produce executable"
case "$tool_name" in
    tmux)
        [ "$("$stage/$binary" -V)" = "$version_prefix" ] ||
            die "source-built version verification failed"
        ;;
    *)
        observed_version=$("$stage/$binary" --version | sed -n '1p')
        case "$observed_version" in "$version_prefix"|"$version_prefix "*|"$version_prefix-"*) ;;
            *) die "source-built version verification failed" ;;
        esac
        ;;
esac
source_tool_healthy "$stage/$binary" || die "source-built feature verification failed"
binary_hash=$(sha256sum "$stage/$binary" | awk '{print $1}')
printf 'artifact|%s|%s|%s\n' "$install_dir" "$binary" "$binary_hash" >>"$transaction_manifest"
mv -T "$stage" "$install_dir"; stage=
guarded_delete_tree "$install_parent" "$build_dir" "$state_root" ||
    die "guarded source-build cleanup failed"
build_dir=
mkdir -p "${stable_link%/*}"
printf 'link|%s|%s\n' "$stable_link" "$installed_binary" >>"$transaction_manifest"
ln -s "$installed_binary" "$stable_link"
echo "CALLER native='hash -r' reason=refresh-command-path-cache"
rm -f "$archive"
rm -f "$entries"
rm -f "$archive_verbose"
if [ -n "$dependency_archive" ]; then
    rm -f "$dependency_archive"
fi
echo complete >"$transaction_manifest.status"; chmod 600 "$transaction_manifest.status"
complete=1
trap - EXIT HUP INT TERM
echo "TRANSACTION id=$transaction_id status=complete"
echo "END build-tool host=$logical_host changes=applied"
