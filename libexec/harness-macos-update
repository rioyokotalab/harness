#!/bin/sh
set -eu

SELF_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
HARNESS_ROOT=${HARNESS_ROOT:-$(CDPATH='' cd -- "$SELF_DIR/.." && pwd)}
export HARNESS_ROOT
. "$SELF_DIR/harness-common"
. "$SELF_DIR/harness-macos-common"

usage() {
    cat >&2 <<'EOF'
Usage:
  harness macos-update --host LOGICAL_ID --public-target COMMIT --private-target COMMIT [--plan|--apply]
  harness macos-update --rollback TRANSACTION_ID
EOF
}

checkout_preflight() {
    update_checkout=$1
    update_target=$2
    update_kind=$3
    [ -d "$update_checkout" ] && [ ! -L "$update_checkout" ] ||
        die "$update_kind checkout has unsafe type"
    [ "$(macos_stat_owner "$update_checkout")" = "$current_uid" ] ||
        die "$update_kind checkout has unsafe owner"
    [ "$(git -C "$update_checkout" rev-parse --is-inside-work-tree 2>/dev/null)" = true ] ||
        die "$update_kind checkout is not a Git worktree"
    update_physical=$(CDPATH='' cd -- "$update_checkout" && pwd -P)
    [ "$(git -C "$update_checkout" rev-parse --show-toplevel 2>/dev/null)" = \
        "$update_physical" ] || die "$update_kind Git root is ambiguous"
    [ "$(git -C "$update_checkout" symbolic-ref --quiet --short HEAD 2>/dev/null)" = main ] ||
        die "$update_kind checkout is not on expected branch"
    [ "$(git -C "$update_checkout" config --get branch.main.remote 2>/dev/null)" = origin ] &&
        [ "$(git -C "$update_checkout" config --get branch.main.merge 2>/dev/null)" = \
            refs/heads/main ] || die "$update_kind branch tracking is ambiguous"
    [ "$(git -C "$update_checkout" remote)" = origin ] ||
        die "$update_kind remote selection is ambiguous"
    update_url_count=$(git -C "$update_checkout" config --get-all remote.origin.url 2>/dev/null |
        awk 'NF { count++ } END { print count + 0 }')
    [ "$update_url_count" -eq 1 ] || die "$update_kind origin URL is ambiguous"
    [ -z "$(git -C "$update_checkout" status --porcelain --untracked-files=normal)" ] ||
        die "$update_kind checkout is not clean"
    macos_hash_is_safe "$update_target" || die "$update_kind target is invalid"
    update_resolved=$(git -C "$update_checkout" rev-parse --verify \
        "$update_target^{commit}" 2>/dev/null) || die "$update_kind target is unavailable"
    [ "$update_resolved" = "$update_target" ] || die "$update_kind target is not explicit"
    [ "$(git -C "$update_checkout" rev-parse --verify \
        refs/remotes/origin/main 2>/dev/null)" = "$update_target" ] ||
        die "$update_kind target is not the fetched origin main"
    git -C "$update_checkout" merge-base --is-ancestor HEAD "$update_target" \
        >/dev/null 2>&1 || die "$update_kind target is not a clean fast-forward"
}

checkout_state() {
    [ "$(git -C "$1" rev-parse HEAD)" = "$2" ] &&
        printf '%s\n' current || printf '%s\n' fast-forward
}

export_commit_file() {
    export_checkout=$1
    export_target=$2
    export_path=$3
    export_destination=$4
    git -C "$export_checkout" show "$export_target:$export_path" \
        >"$export_destination" 2>/dev/null ||
        die "target companion contract is unavailable"
    chmod 600 "$export_destination"
}

validate_private_target() {
    target_paths=$(git -C "$private_checkout" ls-tree -r --name-only \
        "$private_target" 2>/dev/null) || die "private target tree is unavailable"
    selected_found=0
    printf '%s\n' "$target_paths" | while IFS= read -r target_path; do
        case "$target_path" in
            companion.conf)
                target_mode=$(git -C "$private_checkout" ls-tree \
                    "$private_target" -- "$target_path" | awk '{ print $1 ":" $2 }')
                [ "$target_mode" = 100644:blob ] ||
                    die "private target tracked layout is invalid"
                ;;
            ssh_config)
                target_mode=$(git -C "$private_checkout" ls-tree \
                    "$private_target" -- "$target_path" | awk '{ print $1 ":" $2 }')
                [ "$target_mode" = 100644:blob ] ||
                    die "private target tracked layout is invalid"
                export_commit_file "$private_checkout" "$private_target" \
                    "$target_path" "$target_ssh_file"
                macos_validate_ssh_config "$target_ssh_file" "$current_uid" 600
                ;;
            ssh/*.conf)
                [ "$target_minimum_engine" -ne 2 ] ||
                    die "private target tracked layout is invalid"
                target_name=${target_path#ssh/}
                target_id=${target_name%.conf}
                if [ "$target_name" != "$target_id.conf" ] ||
                    ! macos_private_id_is_safe "$target_id" ||
                    ! printf '%s\n' "$target_paths" |
                        grep -F -x "hosts/$target_id.conf" >/dev/null; then
                    die "private target tracked layout is invalid"
                fi
                target_mode=$(git -C "$private_checkout" ls-tree \
                    "$private_target" -- "$target_path" | awk '{ print $1 ":" $2 }')
                [ "$target_mode" = 100644:blob ] ||
                    die "private target tracked layout is invalid"
                export_commit_file "$private_checkout" "$private_target" \
                    "$target_path" "$target_ssh_file"
                macos_validate_ssh_config "$target_ssh_file" "$current_uid" 600
                ;;
            bashrc)
                [ "$target_minimum_engine" -ge 2 ] ||
                    die "private target tracked layout is invalid"
                target_mode=$(git -C "$private_checkout" ls-tree \
                    "$private_target" -- "$target_path" | awk '{ print $1 ":" $2 }')
                [ "$target_mode" = 100644:blob ] ||
                    die "private target tracked layout is invalid"
                export_commit_file "$private_checkout" "$private_target" \
                    "$target_path" "$target_bash_file"
                macos_validate_bash_config "$target_bash_file" "$current_uid" 600
                ;;
            tmux.conf)
                [ "$target_minimum_engine" -ge 2 ] ||
                    die "private target tracked layout is invalid"
                target_mode=$(git -C "$private_checkout" ls-tree \
                    "$private_target" -- "$target_path" | awk '{ print $1 ":" $2 }')
                [ "$target_mode" = 100644:blob ] ||
                    die "private target tracked layout is invalid"
                export_commit_file "$private_checkout" "$private_target" \
                    "$target_path" "$target_tmux_file"
                macos_validate_tmux_config "$target_tmux_file" "$current_uid" 600
                ;;
            hosts/*.conf)
                target_name=${target_path#hosts/}
                target_id=${target_name%.conf}
                if [ "$target_name" != "$target_id.conf" ] ||
                    ! macos_private_id_is_safe "$target_id"; then
                    die "private target tracked layout is invalid"
                fi
                target_mode=$(git -C "$private_checkout" ls-tree \
                    "$private_target" -- "$target_path" | awk '{ print $1 ":" $2 }')
                [ "$target_mode" = 100644:blob ] ||
                    die "private target tracked layout is invalid"
                export_commit_file "$private_checkout" "$private_target" \
                    "$target_path" "$target_host_file"
                macos_validate_host_manifest "$target_host_file" "$target_id" \
                    "$target_private_schema" "$target_baseline"
                ;;
            *) die "private target tracked layout is invalid" ;;
        esac
    done
    if printf '%s\n' "$target_paths" |
        grep -F -x "hosts/$logical_host.conf" >/dev/null; then
        selected_found=1
    fi
    [ "$selected_found" -eq 1 ] || die "selected private target profile is unavailable"
    target_ssh_state=absent
    target_bash_state=absent
    target_tmux_state=absent
    target_per_host_any=absent
    printf '%s\n' "$target_paths" | grep -F -x ssh_config >/dev/null &&
        target_ssh_state=present
    printf '%s\n' "$target_paths" | grep -F -x bashrc >/dev/null &&
        target_bash_state=present
    printf '%s\n' "$target_paths" | grep -F -x tmux.conf >/dev/null &&
        target_tmux_state=present
    printf '%s\n' "$target_paths" | grep '^ssh/[^/]*\.conf$' >/dev/null &&
        target_per_host_any=present
    case "$target_minimum_engine:$target_ssh_state:$target_bash_state:$target_tmux_state" in
        1:absent:absent:absent|1:present:absent:absent) ;;
        2:absent:absent:absent|2:present:present:present) ;;
        3:absent:absent:absent) ;;
        *) die "private target payload set is incomplete or incompatible" ;;
    esac
    if [ "$target_minimum_engine" -eq 1 ] &&
        [ "$target_per_host_any" = present ] &&
        [ "$target_ssh_state" != present ]; then
        die "private target payload set is incomplete or incompatible"
    fi
    if [ "$target_minimum_engine" -eq 3 ]; then
        target_host_ids=$(printf '%s\n' "$target_paths" |
            sed -n 's#^hosts/\(.*\)\.conf$#\1#p' | LC_ALL=C sort)
        target_ssh_ids=$(printf '%s\n' "$target_paths" |
            sed -n 's#^ssh/\(.*\)\.conf$#\1#p' | LC_ALL=C sort)
        [ -n "$target_host_ids" ] && [ "$target_host_ids" = "$target_ssh_ids" ] ||
            die "private target payload set is incomplete or incompatible"
    fi
}

validate_state_file() {
    macos_require_private_file "$state_file" "$current_uid"
    macos_validate_manifest "$state_file" \
        schema,logical_id,public_revision,private_revision \
        schema,logical_id,public_revision,private_revision
    [ "$(macos_manifest_get "$state_file" schema)" = 1 ] ||
        die "local Mac state schema is unsupported"
    [ "$(macos_manifest_get "$state_file" logical_id)" = "$logical_host" ] ||
        die "local Mac state identity mismatch"
    if ! macos_hash_is_safe \
        "$(macos_manifest_get "$state_file" public_revision)" ||
        ! macos_hash_is_safe \
        "$(macos_manifest_get "$state_file" private_revision)"; then
        die "local Mac state revision is malformed"
    fi
}

state_plan() {
    if [ ! -e "$state_file" ] && [ ! -L "$state_file" ]; then
        printf '%s\n' initialize
        return
    fi
    validate_state_file
    if [ "$(macos_manifest_get "$state_file" public_revision)" = "$public_target" ] &&
        [ "$(macos_manifest_get "$state_file" private_revision)" = "$private_target" ]; then
        printf '%s\n' current
    else
        printf '%s\n' migrate-v1
    fi
}

ensure_private_state_directory() {
    update_directory=$1
    mkdir -p "$update_directory"
    chmod 700 "$update_directory"
    [ -d "$update_directory" ] && [ ! -L "$update_directory" ] &&
        [ "$(macos_stat_owner "$update_directory")" = "$current_uid" ] &&
        [ "$(macos_stat_mode "$update_directory")" = 700 ] ||
        die "local Mac state directory is unsafe"
}

apply_state() (
    set -eu
    ensure_private_state_directory "$state_root"
    ensure_private_state_directory "$state_directory"
    ensure_private_state_directory "$transaction_root"
    transaction_id=$(date -u +%Y%m%dT%H%M%SZ)-$$
    manifest=$transaction_root/$transaction_id.macos-update.manifest
    status_file=$transaction_root/$transaction_id.macos-update.status
    backup_file=$transaction_root/$transaction_id.macos-update.before
    new_state=$state_directory/.state.$transaction_id.new
    for reserved in "$manifest" "$status_file" "$backup_file" "$new_state"; do
        [ ! -e "$reserved" ] && [ ! -L "$reserved" ] ||
            die "Mac update transaction identifier collision"
    done

    state_apply_complete=0
    cleanup_state_apply() {
        status=$?
        trap - EXIT HUP INT TERM
        if [ -n "${new_state:-}" ] &&
            { [ -e "$new_state" ] || [ -L "$new_state" ]; }; then
            unlink "$new_state"
        fi
        if [ "$state_apply_complete" -eq 0 ] &&
            [ -n "${status_file:-}" ] && [ -f "$status_file" ] &&
            [ ! -L "$status_file" ]; then
            printf '%s\n' failed >"$status_file"
            chmod 600 "$status_file"
        fi
        exit "$status"
    }
    trap cleanup_state_apply EXIT
    trap 'exit 129' HUP
    trap 'exit 130' INT
    trap 'exit 143' TERM

    before=absent
    before_hash=none
    if [ -f "$state_file" ] && [ ! -L "$state_file" ]; then
        validate_state_file
        before=present
        cp -p "$state_file" "$backup_file"
        chmod 600 "$backup_file"
        before_hash=$(macos_checksum_file "$backup_file")
    fi
    printf 'schema=1\nlogical_id=%s\npublic_revision=%s\nprivate_revision=%s\n' \
        "$logical_host" "$public_target" "$private_target" >"$new_state"
    chmod 600 "$new_state"
    after_hash=$(macos_checksum_file "$new_state")
    printf 'schema=1\noperation=macos-update-state\nstate_before=%s\nbefore_hash=%s\nafter_hash=%s\n' \
        "$before" "$before_hash" "$after_hash" >"$manifest"
    chmod 600 "$manifest"
    printf '%s\n' prepared >"$status_file"
    chmod 600 "$status_file"
    mv "$new_state" "$state_file"
    new_state=
    printf '%s\n' complete >"$status_file"
    state_apply_complete=1
    trap - EXIT HUP INT TERM
    printf '%s\n' "TRANSACTION id=$transaction_id status=complete"
)

rollback_state() {
    rollback_id=$1
    macos_private_id_is_safe "$rollback_id" || die "invalid Mac update transaction"
    rollback_manifest=$transaction_root/$rollback_id.macos-update.manifest
    rollback_status=$transaction_root/$rollback_id.macos-update.status
    rollback_backup=$transaction_root/$rollback_id.macos-update.before
    macos_require_private_directory "$state_root" "$current_uid"
    macos_require_private_directory "$state_directory" "$current_uid"
    macos_require_private_directory "$transaction_root" "$current_uid"
    macos_require_private_file "$rollback_manifest" "$current_uid"
    macos_require_private_file "$rollback_status" "$current_uid"
    [ "$(sed -n '1p' "$rollback_status")" = complete ] ||
        die "Mac update transaction is not complete"
    macos_validate_manifest "$rollback_manifest" \
        schema,operation,state_before,before_hash,after_hash \
        schema,operation,state_before,before_hash,after_hash
    [ "$(macos_manifest_get "$rollback_manifest" schema)" = 1 ] &&
        [ "$(macos_manifest_get "$rollback_manifest" operation)" = \
            macos-update-state ] || die "Mac update transaction is incompatible"
    rollback_before=$(macos_manifest_get "$rollback_manifest" state_before)
    rollback_before_hash=$(macos_manifest_get "$rollback_manifest" before_hash)
    rollback_after_hash=$(macos_manifest_get "$rollback_manifest" after_hash)
    macos_hash_is_safe "$rollback_after_hash" ||
        die "Mac update transaction hash is malformed"
    macos_require_private_file "$state_file" "$current_uid"
    [ "$(macos_checksum_file "$state_file")" = "$rollback_after_hash" ] ||
        die "Mac update rollback blocked by changed state"
    rollback_new=$state_directory/.state.$rollback_id.rollback
    [ ! -e "$rollback_new" ] && [ ! -L "$rollback_new" ] ||
        die "Mac update rollback path collision"
    case "$rollback_before" in
        absent)
            [ "$rollback_before_hash" = none ] ||
                die "Mac update transaction before-state is malformed"
            unlink "$state_file"
            ;;
        present)
            macos_hash_is_safe "$rollback_before_hash" ||
                die "Mac update transaction before-hash is malformed"
            macos_require_private_file "$rollback_backup" "$current_uid"
            [ "$(macos_checksum_file "$rollback_backup")" = "$rollback_before_hash" ] ||
                die "Mac update transaction backup changed"
            cp -p "$rollback_backup" "$rollback_new"
            chmod 600 "$rollback_new"
            mv "$rollback_new" "$state_file"
            ;;
        *) die "Mac update transaction before-state is malformed" ;;
    esac
    printf '%s\n' rolled-back >"$rollback_status"
    printf '%s\n' \
        "TRANSACTION id=$rollback_id status=rolled-back repositories=current"
}

logical_host=
public_target=
private_target=
mode=plan
rollback_id=
while [ "$#" -gt 0 ]; do
    case "$1" in
        --host)
            [ "$#" -ge 2 ] || { usage; exit 2; }
            logical_host=$2
            shift 2
            ;;
        --public-target)
            [ "$#" -ge 2 ] || { usage; exit 2; }
            public_target=$2
            shift 2
            ;;
        --private-target)
            [ "$#" -ge 2 ] || { usage; exit 2; }
            private_target=$2
            shift 2
            ;;
        --plan) mode=plan; shift ;;
        --apply) mode=apply; shift ;;
        --rollback)
            [ "$#" -ge 2 ] || { usage; exit 2; }
            mode=rollback
            rollback_id=$2
            shift 2
            ;;
        -h|--help) usage; exit 0 ;;
        *) usage; exit 2 ;;
    esac
done

case ${HOME:-} in /*) ;; *) die "Mac update requires an absolute HOME" ;; esac
current_uid=$(id -u)
private_checkout=$HOME/.config/harness/private
state_root=$HOME/.local/state/harness
state_directory=$state_root/personal-macos
state_file=$state_directory/state.conf
transaction_root=$state_root/transactions

if [ "$mode" = rollback ]; then
    [ -n "$rollback_id" ] && [ -z "$logical_host$public_target$private_target" ] ||
        { usage; exit 2; }
    rollback_state "$rollback_id"
    exit 0
fi

[ -n "$logical_host" ] && [ -n "$public_target" ] &&
    [ -n "$private_target" ] || { usage; exit 2; }
macos_private_id_is_safe "$logical_host" || die "invalid private logical identifier"
public_checkout=$HARNESS_ROOT

checkout_preflight "$public_checkout" "$public_target" public
checkout_preflight "$private_checkout" "$private_target" private
"$SELF_DIR/harness-macos-profile" --host "$logical_host" >/dev/null ||
    die "current public/private companion validation failed"

target_public_file=$(mktemp "${TMPDIR:-/tmp}/harness-macos-public.XXXXXX") ||
    die "cannot allocate public target validation file"
target_formula_policy=$(mktemp "${TMPDIR:-/tmp}/harness-macos-formula-policy.XXXXXX") || {
    unlink "$target_public_file"
    die "cannot allocate formula-policy target validation file"
}
target_companion_file=$(mktemp "${TMPDIR:-/tmp}/harness-macos-companion.XXXXXX") || {
    unlink "$target_public_file"
    unlink "$target_formula_policy"
    die "cannot allocate private target validation file"
}
target_host_file=$(mktemp "${TMPDIR:-/tmp}/harness-macos-host.XXXXXX") || {
    unlink "$target_public_file"
    unlink "$target_formula_policy"
    unlink "$target_companion_file"
    die "cannot allocate host target validation file"
}
target_ssh_file=$(mktemp "${TMPDIR:-/tmp}/harness-macos-ssh.XXXXXX") || {
    unlink "$target_public_file"
    unlink "$target_formula_policy"
    unlink "$target_companion_file"
    unlink "$target_host_file"
    die "cannot allocate SSH target validation file"
}
target_bash_file=$(mktemp "${TMPDIR:-/tmp}/harness-macos-bash-config.XXXXXX") || {
    unlink "$target_public_file"
    unlink "$target_formula_policy"
    unlink "$target_companion_file"
    unlink "$target_host_file"
    unlink "$target_ssh_file"
    die "cannot allocate Bash target validation file"
}
target_tmux_file=$(mktemp "${TMPDIR:-/tmp}/harness-macos-tmux-config.XXXXXX") || {
    unlink "$target_public_file"
    unlink "$target_formula_policy"
    unlink "$target_companion_file"
    unlink "$target_host_file"
    unlink "$target_ssh_file"
    unlink "$target_bash_file"
    die "cannot allocate tmux target validation file"
}
cleanup_target_files() {
    status=$?
    trap - EXIT HUP INT TERM
    [ ! -e "$target_public_file" ] || unlink "$target_public_file"
    [ ! -e "$target_formula_policy" ] || unlink "$target_formula_policy"
    [ ! -e "$target_companion_file" ] || unlink "$target_companion_file"
    [ ! -e "$target_host_file" ] || unlink "$target_host_file"
    [ ! -e "$target_ssh_file" ] || unlink "$target_ssh_file"
    [ ! -e "$target_bash_file" ] || unlink "$target_bash_file"
    [ ! -e "$target_tmux_file" ] || unlink "$target_tmux_file"
    exit "$status"
}
trap cleanup_target_files EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

export_commit_file "$public_checkout" "$public_target" \
    profiles/personal-macos/base.conf "$target_public_file"
macos_validate_public_profile "$target_public_file"
export_commit_file "$public_checkout" "$public_target" \
    profiles/personal-macos/formula-policy-v3.conf "$target_formula_policy"
macos_validate_formula_policy "$target_formula_policy"
target_engine_schema=3
target_private_min=$(macos_manifest_get "$target_public_file" private_schema_min)
target_private_max=$(macos_manifest_get "$target_public_file" private_schema_max)
target_baseline=$(macos_manifest_get "$target_public_file" baseline)

export_commit_file "$private_checkout" "$private_target" companion.conf \
    "$target_companion_file"
macos_validate_companion_manifest "$target_companion_file" \
    "$target_engine_schema" "$target_private_min" "$target_private_max"
target_private_schema=$(macos_manifest_get "$target_companion_file" schema)
target_minimum_engine=$(macos_manifest_get \
    "$target_companion_file" minimum_engine_schema)
validate_private_target

public_action=$(checkout_state "$public_checkout" "$public_target")
private_action=$(checkout_state "$private_checkout" "$private_target")
migration_action=$(state_plan)
printf '%s\n' \
    "MACOS_UPDATE mode=$mode public=$public_action private=$private_action" \
    "COMPAT engine_schema=$target_engine_schema private_schema=$target_private_schema" \
    "MIGRATION state=$migration_action from=local-or-absent to=$target_private_schema"

if [ "$mode" = plan ]; then
    echo 'END macos_update changes=not-applied fetch=explicit-separate-step'
    exit 0
fi

umask 077
git -C "$public_checkout" merge --ff-only "$public_target" >/dev/null 2>&1 ||
    die "public checkout fast-forward failed; no machine state changed"
if [ "$public_action" = fast-forward ] &&
    [ "${HARNESS_MACOS_UPDATE_RESUMED:-0}" != 1 ]; then
    [ ! -e "$target_public_file" ] || unlink "$target_public_file"
    [ ! -e "$target_formula_policy" ] || unlink "$target_formula_policy"
    [ ! -e "$target_companion_file" ] || unlink "$target_companion_file"
    [ ! -e "$target_host_file" ] || unlink "$target_host_file"
    [ ! -e "$target_ssh_file" ] || unlink "$target_ssh_file"
    [ ! -e "$target_bash_file" ] || unlink "$target_bash_file"
    [ ! -e "$target_tmux_file" ] || unlink "$target_tmux_file"
    trap - EXIT HUP INT TERM
    HARNESS_MACOS_UPDATE_RESUMED=1 \
        exec "$HARNESS_ROOT/libexec/harness-macos-update" \
        --host "$logical_host" --public-target "$public_target" \
        --private-target "$private_target" --apply
fi
git -C "$private_checkout" merge --ff-only "$private_target" >/dev/null 2>&1 ||
    die "private checkout fast-forward failed after public update; retry is safe"

"$HARNESS_ROOT/libexec/harness-macos-profile" --host "$logical_host" >/dev/null ||
    die "updated public/private compatibility validation failed; retry is safe"

if [ "$migration_action" = current ]; then
    echo 'END macos_update changes=none'
    exit 0
fi
apply_state
echo 'END macos_update changes=applied package_actions=none'
