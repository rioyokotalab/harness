#!/bin/sh
set -eu

SELF_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
HARNESS_ROOT=${HARNESS_ROOT:-$(CDPATH='' cd -- "$SELF_DIR/.." && pwd)}
export HARNESS_ROOT
. "$SELF_DIR/harness-common"
. "$SELF_DIR/harness-macos-common"

usage() {
    echo "Usage: harness macos-homebrew --host LOGICAL_ID [--plan|--apply]" >&2
}

safe_path_field() {
    case "$1" in
        ''|*'|'*|*'
'*|*//*|*/./*|*/../*|*/.|*/..) return 1 ;;
        *) return 0 ;;
    esac
}

formula_in_list() {
    case " $1 " in *" $2 "*) return 0 ;; *) return 1 ;; esac
}

append_unique_formula() {
    append_list=$1
    append_formula=$2
    if formula_in_list "$append_list" "$append_formula"; then
        printf '%s\n' "$append_list"
    elif [ -n "$append_list" ]; then
        printf '%s %s\n' "$append_list" "$append_formula"
    else
        printf '%s\n' "$append_formula"
    fi
}

formula_count() {
    printf '%s\n' "$1" |
        awk '{ for (i = 1; i <= NF; i++) count++ } END { print count + 0 }'
}

mapping_target() {
    mapping_csv=$1
    mapping_source=$2
    printf '%s\n' "$mapping_csv" | tr ',' '\n' |
        awk -F: -v source="$mapping_source" \
            '$1 == source { print $2; found = 1 } END { exit found ? 0 : 1 }'
}

validate_formula_output() {
    formula_output=$1
    printf '%s\n' "$formula_output" | awk '
        NF == 0 { next }
        $0 !~ /^[A-Za-z0-9][A-Za-z0-9@+._\/-]*$/ { bad = 1 }
        /\// { bad = 1 }
        seen[$0]++ { bad = 1 }
        END { exit bad ? 1 : 0 }
    ' >/dev/null 2>&1 || die "Homebrew returned unsafe or tapped formula scope"
}

validate_version_output() {
    version_formula=$1
    version_output=$2
    printf '%s\n' "$version_output" | awk -v formula="$version_formula" '
        NR != 1 || $1 != formula || NF < 2 || /[|[:cntrl:]]/ { bad = 1 }
        END { exit bad ? 1 : 0 }
    ' >/dev/null 2>&1 || die "Homebrew returned malformed managed version evidence"
}

brew_inventory_versions() {
    inventory_versions_output=$(brew_read list --formula --versions 2>/dev/null) ||
        die "Homebrew installed-formula inventory failed"
    printf '%s\n' "$inventory_versions_output" | awk '
        NF == 0 { next }
        NF < 2 || /[|[:cntrl:]]/ ||
            $1 !~ /^[A-Za-z0-9][A-Za-z0-9@+._-]*$/ || seen[$1]++ { bad = 1 }
        END { exit bad ? 1 : 0 }
    ' >/dev/null 2>&1 || die "Homebrew returned malformed installed-formula evidence"
    printf '%s\n' "$inventory_versions_output" | sed -n '/./p'
}

brew_read() {
    HOMEBREW_NO_AUTO_UPDATE=1 HOMEBREW_NO_ANALYTICS=1 \
        HOMEBREW_NO_ENV_HINTS=1 "$brew_command" "$@"
}

validate_public_checkout() {
    [ "$(uname -s)" = Darwin ] || die "managed Homebrew catch-up requires Darwin"
    [ -d "$HARNESS_ROOT/.git" ] && [ ! -L "$HARNESS_ROOT/.git" ] ||
        die "managed Homebrew catch-up requires a Git harness checkout"
    [ "$(CDPATH='' cd -- "$HARNESS_ROOT" && pwd -P)" = "$HARNESS_ROOT" ] &&
        [ "$(git -C "$HARNESS_ROOT" rev-parse --show-toplevel 2>/dev/null)" = \
            "$HARNESS_ROOT" ] || die "managed Homebrew checkout root is ambiguous"
    [ "$(git -C "$HARNESS_ROOT" symbolic-ref --quiet --short HEAD 2>/dev/null)" = \
        main ] || die "managed Homebrew catch-up requires the main branch"
    [ -z "$(git -C "$HARNESS_ROOT" status --porcelain --untracked-files=normal)" ] ||
        die "managed Homebrew catch-up requires a clean committed harness checkout"
}

resolve_brew() {
    brew_command=$(command -v brew 2>/dev/null || true)
    [ -n "$brew_command" ] && [ -x "$brew_command" ] && [ ! -L "$brew_command" ] ||
        die "managed Homebrew executable is unavailable or unsafe"
    brew_prefix=$(brew_read --prefix 2>/dev/null) ||
        die "managed Homebrew prefix query failed"
    safe_path_field "$brew_prefix" || die "managed Homebrew prefix is unsafe"
    case "$brew_prefix" in /*) ;; *) die "managed Homebrew prefix is unsafe" ;; esac
    [ "$brew_command" = "$brew_prefix/bin/brew" ] ||
        die "active Homebrew executable does not match its prefix"
    case "$(uname -m):$brew_prefix" in
        arm64:/opt/homebrew) prefix_class=apple-silicon-default ;;
        x86_64:/usr/local) prefix_class=intel-default ;;
        arm64:*|x86_64:*) prefix_class=other ;;
        *) die "managed Homebrew architecture is unsupported" ;;
    esac
}

discover_scope() {
    missing_formulae=
    installed_formulae=
    outdated_formulae=
    installed_retired_formulae=
    dependencies=
    unmanaged_dependents=
    unmanaged_installed_formulae=
    retired_dependents=
    retirement_upgrade_dependents=
    cleanup_retired_formulae=
    cleanup_retired_targets=

    # Exact convergence requires one unambiguous installed-formula inventory.
    # In particular, querying old and current versioned names together can make
    # Homebrew emit the current canonical name twice. The no-argument formula
    # inventory preserves the actual installed keg names and excludes casks.
    installed_version_inventory=$(brew_inventory_versions)
    installed_scope=
    while IFS= read -r installed_line; do
        [ -n "$installed_line" ] || continue
        installed_name=${installed_line%% *}
        installed_scope=$(append_unique_formula "$installed_scope" "$installed_name")
    done <<EOF
$installed_version_inventory
EOF

    for formula in $managed_formulae; do
        if formula_in_list "$installed_scope" "$formula"; then
            installed_formulae=$(append_unique_formula "$installed_formulae" "$formula")
        else
            missing_formulae=$(append_unique_formula "$missing_formulae" "$formula")
        fi
    done

    for formula in $retired_formulae; do
        if formula_in_list "$installed_scope" "$formula"; then
            installed_retired_formulae=$(append_unique_formula \
                "$installed_retired_formulae" "$formula")
            dependent_output=$(brew_read uses --installed --recursive --formula \
                "$formula" 2>/dev/null) ||
                die "scoped Homebrew retired dependent query failed"
            validate_formula_output "$dependent_output"
            alias_target=$(mapping_target "$retirement_aliases_csv" \
                "$formula" 2>/dev/null || true)
            for dependent in $dependent_output; do
                formula_in_list "$retired_formulae" "$dependent" ||
                    { [ -n "$alias_target" ] &&
                        formula_in_list "$managed_formulae" "$dependent"; } ||
                    retired_dependents=$(append_unique_formula \
                        "$retired_dependents" "$dependent")
            done
            cleanup_target=$(mapping_target "$cleanup_retirements_csv" \
                "$formula" 2>/dev/null || true)
            if [ -n "$cleanup_target" ]; then
                cleanup_retired_formulae=$(append_unique_formula \
                    "$cleanup_retired_formulae" "$formula")
                cleanup_retired_targets=$(append_unique_formula \
                    "$cleanup_retired_targets" "$cleanup_target")
            fi
        fi
    done

    if [ -n "$installed_formulae" ]; then
        # Formula tokens are schema-restricted and cannot contain shell spaces.
        # shellcheck disable=SC2086
        set -- $installed_formulae
        outdated_status=0
        outdated_output=$(brew_read outdated --formula --quiet "$@" 2>/dev/null) ||
            outdated_status=$?
        case "$outdated_status" in
            0) ;;
            1) [ -n "$outdated_output" ] ||
                die "scoped Homebrew outdated query failed" ;;
            *) die "scoped Homebrew outdated query failed" ;;
        esac
        validate_formula_output "$outdated_output"
        for formula in $outdated_output; do
            formula_in_list "$installed_formulae" "$formula" ||
                die "Homebrew outdated query returned unmanaged scope"
            outdated_formulae=$(append_unique_formula "$outdated_formulae" "$formula")
        done
    fi

    # Homebrew documents --union for multiple dependency roots. Tapped
    # formulae and tapped dependencies are deliberately outside phase 1.
    # shellcheck disable=SC2086
    set -- $managed_formulae
    dependency_output=$(brew_read deps --union --full-name --formula "$@" 2>/dev/null) ||
        die "scoped Homebrew dependency query failed"
    validate_formula_output "$dependency_output"
    for formula in $dependency_output; do
        formula_in_list "$managed_formulae" "$formula" ||
            dependencies=$(append_unique_formula "$dependencies" "$formula")
    done
    allowed_formulae=$managed_formulae
    [ -z "$dependencies" ] || allowed_formulae="$allowed_formulae $dependencies"
    for formula in $installed_scope; do
        formula_in_list "$allowed_formulae" "$formula" ||
            formula_in_list "$retired_formulae" "$formula" ||
            unmanaged_installed_formulae=$(append_unique_formula \
                "$unmanaged_installed_formulae" "$formula")
    done

    # Homebrew may check and upgrade installed dependents of selected roots.
    # Shared dependency users remain outside managed intent; Homebrew's normal
    # installed-dependent linkage checks stay enabled to protect them.
    for formula in $managed_formulae; do
        dependent_output=$(brew_read uses --installed --recursive --formula \
            "$formula" 2>/dev/null) || die "scoped Homebrew dependent query failed"
        validate_formula_output "$dependent_output"
        for dependent in $dependent_output; do
            formula_in_list "$allowed_formulae" "$dependent" ||
                formula_in_list "$retired_formulae" "$dependent" ||
                unmanaged_dependents=$(append_unique_formula \
                    "$unmanaged_dependents" "$dependent")
        done
    done

    blocking_retired_dependents=
    for dependent in $retired_dependents; do
        if formula_in_list "$managed_formulae" "$dependent" &&
            formula_in_list "$outdated_formulae" "$dependent"; then
            retirement_upgrade_dependents=$(append_unique_formula \
                "$retirement_upgrade_dependents" "$dependent")
        else
            blocking_retired_dependents=$(append_unique_formula \
                "$blocking_retired_dependents" "$dependent")
        fi
    done
    retired_dependents=$blocking_retired_dependents
}

validate_dry_run_log() {
    dry_log=$1
    [ -s "$dry_log" ] || die "Homebrew dry-run returned no reviewable output"
    if awk '
        {
            line = tolower($0)
            if (line ~ /(^|[^[:alnum:]_])(cask|service|sudo|license|tap|cleanup|uninstall|autoremove)([^[:alnum:]_]|$)/)
                bad = 1
        }
        END { exit bad ? 0 : 1 }
    ' "$dry_log"; then
        die "Homebrew dry-run reported prohibited scope"
    fi
    for formula in $missing_formulae $outdated_formulae; do
        awk -v formula="$formula" 'index($0, formula) { found = 1 }
            END { exit found ? 0 : 1 }' "$dry_log" ||
            die "Homebrew dry-run omitted a planned managed formula"
    done
}

run_dry_runs() {
    : >"$dry_run_log"
    chmod 600 "$dry_run_log"
    if [ -n "$missing_formulae" ]; then
        # shellcheck disable=SC2086
        set -- $missing_formulae
        env -u HOMEBREW_ASK HOMEBREW_NO_AUTO_UPDATE=1 \
            HOMEBREW_NO_INSTALL_CLEANUP=1 HOMEBREW_NO_ANALYTICS=1 \
            HOMEBREW_NO_ENV_HINTS=1 NONINTERACTIVE=1 \
            "$brew_command" install --formula --dry-run "$@" \
            >>"$dry_run_log" 2>&1 </dev/null ||
            die "managed Homebrew install dry-run failed"
    fi
    if [ -n "$outdated_formulae" ]; then
        # shellcheck disable=SC2086
        set -- $outdated_formulae
        env -u HOMEBREW_ASK HOMEBREW_NO_AUTO_UPDATE=1 \
            HOMEBREW_NO_INSTALL_CLEANUP=1 HOMEBREW_NO_ANALYTICS=1 \
            HOMEBREW_NO_ENV_HINTS=1 NONINTERACTIVE=1 \
            "$brew_command" upgrade --formula --dry-run "$@" \
            >>"$dry_run_log" 2>&1 </dev/null ||
            die "managed Homebrew upgrade dry-run failed"
    fi
    if [ -n "$missing_formulae$outdated_formulae" ]; then
        validate_dry_run_log "$dry_run_log"
    fi
}

run_cleanup_dry_runs() {
    for cleanup_formula in $cleanup_retired_formulae; do
        cleanup_target=$(mapping_target "$cleanup_retirements_csv" \
            "$cleanup_formula") ||
            die "managed Homebrew cleanup mapping changed"
        cleanup_log=$(mktemp "${TMPDIR:-/tmp}/harness-macos-homebrew-cleanup.XXXXXX") ||
            die "cannot allocate managed Homebrew cleanup dry-run log"
        chmod 600 "$cleanup_log"
        if ! env -u HOMEBREW_ASK HOMEBREW_NO_AUTO_UPDATE=1 \
            HOMEBREW_NO_INSTALL_CLEANUP=1 HOMEBREW_NO_ANALYTICS=1 \
            HOMEBREW_NO_ENV_HINTS=1 NONINTERACTIVE=1 \
            "$brew_command" cleanup --dry-run "$cleanup_target" \
            >"$cleanup_log" 2>&1 </dev/null; then
            unlink "$cleanup_log"
            die "managed Homebrew cleanup dry-run failed"
        fi
        [ -s "$cleanup_log" ] &&
            grep -F "$brew_prefix/Cellar/$cleanup_formula/" "$cleanup_log" \
                >/dev/null 2>&1 || {
            unlink "$cleanup_log"
            die "managed Homebrew cleanup dry-run omitted the legacy keg"
        }
        unlink "$cleanup_log"
    done
}

prepare_transaction_root() {
    state_root=$HOME/.local/state/harness
    transaction_root=$state_root/transactions
    for state_path in "$HOME/.local" "$HOME/.local/state" \
        "$state_root" "$transaction_root"; do
        if [ -e "$state_path" ] || [ -L "$state_path" ]; then
            [ -d "$state_path" ] && [ ! -L "$state_path" ] ||
                die "managed Homebrew state path is unsafe"
            [ "$(macos_stat_owner "$state_path")" = "$current_uid" ] ||
                die "managed Homebrew state path owner is unsafe"
            case "$state_path" in
                "$state_root"|"$transaction_root")
                    [ "$(macos_stat_mode "$state_path")" = 700 ] ||
                        die "managed Homebrew state path mode is unsafe"
                    ;;
            esac
        fi
    done
    umask 077
    for state_path in "$HOME/.local" "$HOME/.local/state" \
        "$state_root" "$transaction_root"; do
        if [ ! -e "$state_path" ] && [ ! -L "$state_path" ]; then
            mkdir "$state_path"
            chmod 700 "$state_path"
        fi
    done
}

capture_evidence() {
    evidence_file=$1
    evidence_phase=$2
    : >"$evidence_file"
    chmod 600 "$evidence_file"
    printf 'schema=1\nphase=%s\nprefix=%s\n' \
        "$evidence_phase" "$brew_prefix" >>"$evidence_file"
    evidence_inventory=$(brew_inventory_versions)
    for evidence_kind in selected dependency retired; do
        case "$evidence_kind" in
            selected) evidence_formulae=$managed_formulae ;;
            dependency) evidence_formulae=$dependencies ;;
            retired) evidence_formulae=$retired_formulae ;;
        esac
        for formula in $evidence_formulae; do
            version_output=$(printf '%s\n' "$evidence_inventory" |
                awk -v formula="$formula" '$1 == formula { print; exit }')
            if [ -n "$version_output" ]; then
                validate_version_output "$formula" "$version_output"
                printf '%s|%s|%s\n' "$evidence_kind" "$formula" \
                    "${version_output#"$formula "}" >>"$evidence_file"
            else
                printf '%s|%s|absent\n' "$evidence_kind" "$formula" \
                    >>"$evidence_file"
            fi
        done
    done
}

logical_host=
mode=plan
while [ "$#" -gt 0 ]; do
    case "$1" in
        --host) [ "$#" -ge 2 ] || { usage; exit 2; }; logical_host=$2; shift 2 ;;
        --plan) mode=plan; shift ;;
        --apply) mode=apply; shift ;;
        -h|--help) usage; exit 0 ;;
        *) usage; exit 2 ;;
    esac
done
[ -n "$logical_host" ] || { usage; exit 2; }
macos_private_id_is_safe "$logical_host" || die "invalid private logical identifier"
case ${HOME:-} in /*) ;; *) die "managed Homebrew catch-up requires an absolute HOME" ;; esac
current_uid=$(id -u)
[ -d "$HOME" ] && [ ! -L "$HOME" ] &&
    [ "$(macos_stat_owner "$HOME")" = "$current_uid" ] &&
    [ "$(CDPATH='' cd -- "$HOME" && pwd -P)" = "$HOME" ] ||
    die "managed Homebrew HOME is unsafe or ambiguous"
safe_path_field "$HOME" || die "managed Homebrew path is unsafe"
safe_path_field "$HARNESS_ROOT" || die "managed Homebrew path is unsafe"

validate_public_checkout
"$SELF_DIR/harness-macos-profile" --host "$logical_host" >/dev/null ||
    die "private profile is not ready for managed Homebrew catch-up"
formula_policy=$HARNESS_ROOT/profiles/personal-macos/formula-policy-v4.conf
macos_validate_formula_policy "$formula_policy"
host_manifest=$HOME/.config/harness/private/hosts/$logical_host.conf
public_formulae=$(macos_manifest_get "$formula_policy" managed_formulae)
retired_csv=$(macos_manifest_get "$formula_policy" retired_formulae)
retirement_aliases_csv=$(macos_manifest_get "$formula_policy" retirement_aliases)
cleanup_retirements_csv=$(macos_manifest_get "$formula_policy" cleanup_retirements)
extra_formulae=$(macos_manifest_get "$host_manifest" extra_formulae)
all_formulae=$public_formulae
[ "$extra_formulae" = none ] || all_formulae=$all_formulae,$extra_formulae
printf '%s\n' "$all_formulae" | tr ',' '\n' |
    awk '/\// || seen[$0]++ { exit 1 }' ||
    die "managed Homebrew selection contains a tap or duplicate"
managed_formulae=$(printf '%s\n' "$all_formulae" | tr ',' ' ')
retired_formulae=$(printf '%s\n' "$retired_csv" | tr ',' ' ')
for formula in $retired_formulae; do
    formula_in_list "$managed_formulae" "$formula" &&
        die "managed Homebrew selection includes a retired formula"
done

resolve_brew
initial_prefix=$brew_prefix
dry_run_log=$(mktemp "${TMPDIR:-/tmp}/harness-macos-homebrew-dry.XXXXXX") ||
    die "cannot allocate managed Homebrew dry-run log"
chmod 600 "$dry_run_log"
cleanup_dry_run() {
    status=$?
    trap - EXIT HUP INT TERM
    if [ -e "$dry_run_log" ] || [ -L "$dry_run_log" ]; then unlink "$dry_run_log"; fi
    exit "$status"
}
trap cleanup_dry_run EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

discover_scope
run_dry_runs
run_cleanup_dry_runs
printf 'MACOS_HOMEBREW mode=%s privacy=local-details prefix=%s\n' \
    "$mode" "$prefix_class"
printf "INSTALL count=%s formulae='%s'\n" \
    "$(formula_count "$missing_formulae")" "$missing_formulae"
printf "UPGRADE count=%s formulae='%s'\n" \
    "$(formula_count "$outdated_formulae")" "$outdated_formulae"
printf "RETIRE count=%s formulae='%s'\n" \
    "$(formula_count "$installed_retired_formulae")" \
    "$installed_retired_formulae"
printf "RETIRE_CLEANUP count=%s aliases='%s' targets='%s'\n" \
    "$(formula_count "$cleanup_retired_formulae")" \
    "$cleanup_retired_formulae" "$cleanup_retired_targets"
printf 'DEPENDENCIES count=%s scope=validated shared_users=preserved\n' \
    "$(formula_count "$dependencies")"
printf "UNMANAGED_DEPENDENTS count=%s formulae='%s'\n" \
    "$(formula_count "$unmanaged_dependents")" "$unmanaged_dependents"
printf "UNMANAGED_INSTALLED count=%s formulae='%s'\n" \
    "$(formula_count "$unmanaged_installed_formulae")" \
    "$unmanaged_installed_formulae"
printf "RETIRED_DEPENDENTS count=%s formulae='%s'\n" \
    "$(formula_count "$retired_dependents")" "$retired_dependents"
printf "MIGRATION_DEPENDENTS count=%s formulae='%s' resolution=upgrade-before-retire\n" \
    "$(formula_count "$retirement_upgrade_dependents")" \
    "$retirement_upgrade_dependents"
printf 'DRY_RUN status=validated install=%s upgrade=%s retire=package-manager-no-dry-run\n' \
    "$(formula_count "$missing_formulae")" \
    "$(formula_count "$outdated_formulae")"

[ -z "$unmanaged_dependents" ] || {
    echo 'BLOCK macos_homebrew reason=selected-root-has-unmanaged-dependent'
    echo 'END macos_homebrew applied=no blocked=1 metadata_refresh=separate'
    exit 2
}
[ -z "$unmanaged_installed_formulae" ] || {
    echo 'BLOCK macos_homebrew reason=installed-formula-outside-exact-policy'
    echo 'END macos_homebrew applied=no blocked=1 metadata_refresh=separate'
    exit 2
}
[ -z "$retired_dependents" ] || {
    echo 'BLOCK macos_homebrew reason=retired-formula-has-installed-dependent'
    echo 'END macos_homebrew applied=no blocked=1 metadata_refresh=separate'
    exit 2
}

[ "$mode" = apply ] || {
    echo 'END macos_homebrew applied=no metadata_refresh=separate'
    exit 0
}
[ -n "$missing_formulae$outdated_formulae$installed_retired_formulae" ] || {
    echo 'END macos_homebrew changes=none metadata_refresh=separate'
    exit 0
}

# Repeat desired-state, checkout, prefix, scope, dependent, and dry-run gates
# immediately before the irreversible package-manager stage.
planned_missing=$missing_formulae
planned_outdated=$outdated_formulae
planned_retired=$installed_retired_formulae
planned_dependencies=$dependencies
planned_retirement_upgrade_dependents=$retirement_upgrade_dependents
planned_cleanup_retired_formulae=$cleanup_retired_formulae
planned_cleanup_retired_targets=$cleanup_retired_targets
validate_public_checkout
"$SELF_DIR/harness-macos-profile" --host "$logical_host" >/dev/null ||
    die "private profile changed before managed Homebrew apply"
resolve_brew
[ "$brew_prefix" = "$initial_prefix" ] ||
    die "managed Homebrew prefix changed before apply"
discover_scope
[ -z "$unmanaged_dependents" ] ||
    die "managed Homebrew selected root gained an unmanaged dependent"
[ -z "$unmanaged_installed_formulae" ] ||
    die "managed Homebrew gained an installed formula outside exact policy"
[ -z "$retired_dependents" ] ||
    die "managed Homebrew retired root gained an installed dependent"
[ "$missing_formulae" = "$planned_missing" ] &&
    [ "$outdated_formulae" = "$planned_outdated" ] &&
    [ "$installed_retired_formulae" = "$planned_retired" ] &&
    [ "$dependencies" = "$planned_dependencies" ] &&
    [ "$retirement_upgrade_dependents" = \
        "$planned_retirement_upgrade_dependents" ] &&
    [ "$cleanup_retired_formulae" = "$planned_cleanup_retired_formulae" ] &&
    [ "$cleanup_retired_targets" = "$planned_cleanup_retired_targets" ] ||
    die "managed Homebrew plan changed before apply"
run_dry_runs
run_cleanup_dry_runs

prepare_transaction_root
transaction_id=$(date -u +%Y%m%dT%H%M%SZ)-$$
manifest=$transaction_root/$transaction_id.macos-homebrew.manifest
status_file=$transaction_root/$transaction_id.macos-homebrew.status
pre_file=$transaction_root/$transaction_id.macos-homebrew.pre.tsv
post_file=$transaction_root/$transaction_id.macos-homebrew.post.tsv
delta_file=$transaction_root/$transaction_id.macos-homebrew.delta.diff
apply_log=$transaction_root/$transaction_id.macos-homebrew.apply.log
for transaction_file in "$manifest" "$status_file" "$pre_file" \
    "$post_file" "$delta_file" "$apply_log"; do
    [ ! -e "$transaction_file" ] && [ ! -L "$transaction_file" ] ||
        die "managed Homebrew transaction identifier collision"
done
umask 077
printf 'schema=1\noperation=macos-homebrew\nrevision=%s\nlogical_id=%s\nprefix=%s\n' \
    "$(git -C "$HARNESS_ROOT" rev-parse HEAD)" "$logical_host" \
    "$brew_prefix" >"$manifest"
for formula in $managed_formulae; do printf 'formula=%s\n' "$formula" >>"$manifest"; done
for formula in $retired_formulae; do printf 'retired=%s\n' "$formula" >>"$manifest"; done
printf 'retirement_aliases=%s\ncleanup_retirements=%s\n' \
    "$retirement_aliases_csv" "$cleanup_retirements_csv" >>"$manifest"
chmod 600 "$manifest"
printf '%s\n' prepared >"$status_file"
chmod 600 "$status_file"
: >"$apply_log"
chmod 600 "$apply_log"

apply_complete=0
finish_failed_apply() {
    status=$?
    trap - EXIT HUP INT TERM
    if [ "$apply_complete" -eq 0 ]; then
        (capture_evidence "$post_file" failed-post) >/dev/null 2>&1 || true
        if diff -u "$pre_file" "$post_file" >"$delta_file" 2>/dev/null; then
            :
        else
            # A difference is expected after a partial package-manager run;
            # an evidence error must not mask the original apply failure.
            :
        fi
        chmod 600 "$delta_file" 2>/dev/null || true
        printf '%s\n' failed >"$status_file"
    fi
    [ -e "$dry_run_log" ] || [ -L "$dry_run_log" ] || exit "$status"
    unlink "$dry_run_log"
    exit "$status"
}
trap finish_failed_apply EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

capture_evidence "$pre_file" pre

if [ -n "$missing_formulae" ]; then
    printf 'stage=install count=%s\n' "$(formula_count "$missing_formulae")" \
        >>"$apply_log"
    # shellcheck disable=SC2086
    set -- $missing_formulae
    env -u HOMEBREW_ASK HOMEBREW_NO_AUTO_UPDATE=1 \
        HOMEBREW_NO_INSTALL_CLEANUP=1 HOMEBREW_NO_ANALYTICS=1 \
        HOMEBREW_NO_ENV_HINTS=1 NONINTERACTIVE=1 \
        "$brew_command" install --formula "$@" \
        >>"$apply_log" 2>&1 </dev/null ||
        die "managed Homebrew install failed; automatic rollback is unavailable"
fi
resolve_brew
[ "$brew_prefix" = "$initial_prefix" ] ||
    die "managed Homebrew prefix changed after install"
if [ -n "$outdated_formulae" ]; then
    printf 'stage=upgrade count=%s\n' "$(formula_count "$outdated_formulae")" \
        >>"$apply_log"
    # shellcheck disable=SC2086
    set -- $outdated_formulae
    env -u HOMEBREW_ASK HOMEBREW_NO_AUTO_UPDATE=1 \
        HOMEBREW_NO_INSTALL_CLEANUP=1 HOMEBREW_NO_ANALYTICS=1 \
        HOMEBREW_NO_ENV_HINTS=1 NONINTERACTIVE=1 \
        "$brew_command" upgrade --formula "$@" \
        >>"$apply_log" 2>&1 </dev/null ||
        die "managed Homebrew upgrade failed; automatic rollback is unavailable"
fi
resolve_brew
[ "$brew_prefix" = "$initial_prefix" ] ||
    die "managed Homebrew prefix changed after selected-package apply"
discover_scope
[ -z "$missing_formulae$outdated_formulae" ] ||
    die "managed Homebrew selected-package state did not converge"
[ "$installed_retired_formulae" = "$planned_retired" ] ||
    die "managed Homebrew retirement scope changed after selected-package apply"
[ "$dependencies" = "$planned_dependencies" ] ||
    die "managed Homebrew dependency scope changed during apply"
[ -z "$unmanaged_dependents" ] ||
    die "managed Homebrew selected root gained an unmanaged dependent after apply"
[ -z "$unmanaged_installed_formulae" ] ||
    die "managed Homebrew gained an installed formula outside exact policy after apply"
[ -z "$retired_dependents" ] ||
    die "managed Homebrew retired root retained an installed dependent after upgrade"
[ -z "$retirement_upgrade_dependents" ] ||
    die "managed Homebrew retirement migration remained incomplete after upgrade"

if [ -n "$cleanup_retired_targets" ]; then
    printf 'stage=cleanup-retire count=%s\n' \
        "$(formula_count "$cleanup_retired_targets")" >>"$apply_log"
    for cleanup_target in $cleanup_retired_targets; do
        env -u HOMEBREW_ASK HOMEBREW_NO_AUTO_UPDATE=1 \
            HOMEBREW_NO_ANALYTICS=1 HOMEBREW_NO_ENV_HINTS=1 \
            NONINTERACTIVE=1 "$brew_command" cleanup "$cleanup_target" \
            >>"$apply_log" 2>&1 </dev/null ||
            die "managed Homebrew legacy-keg cleanup failed; automatic rollback is unavailable"
    done
fi
uninstall_retired_formulae=
for formula in $installed_retired_formulae; do
    formula_in_list "$cleanup_retired_formulae" "$formula" ||
        uninstall_retired_formulae=$(append_unique_formula \
            "$uninstall_retired_formulae" "$formula")
done
if [ -n "$uninstall_retired_formulae" ]; then
    printf 'stage=retire count=%s\n' \
        "$(formula_count "$uninstall_retired_formulae")" >>"$apply_log"
    # Homebrew has no uninstall dry-run. Scope is the exact validated public
    # retirement list, and the post-upgrade checkpoint proved that no installed
    # dependent remains outside that same reviewed retirement set.
    # shellcheck disable=SC2086
    set -- $uninstall_retired_formulae
    env -u HOMEBREW_ASK HOMEBREW_NO_AUTO_UPDATE=1 \
        HOMEBREW_NO_INSTALL_CLEANUP=1 HOMEBREW_NO_ANALYTICS=1 \
        HOMEBREW_NO_ENV_HINTS=1 NONINTERACTIVE=1 \
        "$brew_command" uninstall --force --formula "$@" \
        >>"$apply_log" 2>&1 </dev/null ||
        die "managed Homebrew retirement failed; automatic rollback is unavailable"
fi
resolve_brew
[ "$brew_prefix" = "$initial_prefix" ] ||
    die "managed Homebrew prefix changed after retirement"
discover_scope
[ -z "$installed_retired_formulae" ] ||
    die "managed Homebrew retirement state did not converge"
[ "$dependencies" = "$planned_dependencies" ] ||
    die "managed Homebrew dependency scope changed after retirement"
[ -z "$unmanaged_dependents$unmanaged_installed_formulae$retired_dependents$retirement_upgrade_dependents" ] ||
    die "managed Homebrew dependent scope changed after retirement"
repair_missing=$missing_formulae
repair_outdated=$outdated_formulae
if [ -n "$repair_missing$repair_outdated" ]; then
    run_dry_runs
    if [ -n "$repair_missing" ]; then
        printf 'stage=repair-install count=%s\n' \
            "$(formula_count "$repair_missing")" >>"$apply_log"
        # shellcheck disable=SC2086
        set -- $repair_missing
        env -u HOMEBREW_ASK HOMEBREW_NO_AUTO_UPDATE=1 \
            HOMEBREW_NO_INSTALL_CLEANUP=1 HOMEBREW_NO_ANALYTICS=1 \
            HOMEBREW_NO_ENV_HINTS=1 NONINTERACTIVE=1 \
            "$brew_command" install --formula "$@" \
            >>"$apply_log" 2>&1 </dev/null ||
            die "managed Homebrew post-retirement install failed; automatic rollback is unavailable"
    fi
    if [ -n "$repair_outdated" ]; then
        printf 'stage=repair-upgrade count=%s\n' \
            "$(formula_count "$repair_outdated")" >>"$apply_log"
        # shellcheck disable=SC2086
        set -- $repair_outdated
        env -u HOMEBREW_ASK HOMEBREW_NO_AUTO_UPDATE=1 \
            HOMEBREW_NO_INSTALL_CLEANUP=1 HOMEBREW_NO_ANALYTICS=1 \
            HOMEBREW_NO_ENV_HINTS=1 NONINTERACTIVE=1 \
            "$brew_command" upgrade --formula "$@" \
            >>"$apply_log" 2>&1 </dev/null ||
            die "managed Homebrew post-retirement upgrade failed; automatic rollback is unavailable"
    fi
    resolve_brew
    [ "$brew_prefix" = "$initial_prefix" ] ||
        die "managed Homebrew prefix changed after post-retirement repair"
    discover_scope
fi
[ -z "$missing_formulae$outdated_formulae$installed_retired_formulae" ] ||
    die "managed Homebrew post-state did not converge"
[ "$dependencies" = "$planned_dependencies" ] ||
    die "managed Homebrew dependency scope changed after post-retirement repair"
[ -z "$unmanaged_dependents$unmanaged_installed_formulae$retired_dependents$retirement_upgrade_dependents" ] ||
    die "managed Homebrew dependent scope changed after post-retirement repair"
capture_evidence "$post_file" post
if diff -u "$pre_file" "$post_file" >"$delta_file"; then :; else
    [ "$?" -eq 1 ] || die "managed Homebrew evidence diff failed"
fi
chmod 600 "$delta_file"
printf '%s\n' complete >"$status_file"
apply_complete=1
trap - EXIT HUP INT TERM
unlink "$dry_run_log"
printf 'TRANSACTION id=%s status=complete install=%s upgrade=%s retire=%s\n' \
    "$transaction_id" "$(formula_count "$planned_missing")" \
    "$(formula_count "$planned_outdated")" \
    "$(formula_count "$planned_retired")"
printf 'REPAIR install=%s upgrade=%s\n' \
    "$(formula_count "$repair_missing")" "$(formula_count "$repair_outdated")"
echo 'END macos_homebrew applied=yes rollback=manual-review-only metadata_refresh=separate'
