#!/bin/sh
set -eu

SELF_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
HARNESS_ROOT=${HARNESS_ROOT:-$(CDPATH='' cd -- "$SELF_DIR/.." && pwd)}
export HARNESS_ROOT
. "$SELF_DIR/harness-common"

usage() {
    printf '%s\n' 'Usage: harness storage-readiness --host LOGICAL_ID [--write-probe]' >&2
}

logical_host=
write_probe=0
while [ "$#" -gt 0 ]; do
    case $1 in
        --host)
            [ "$#" -ge 2 ] || { usage; exit 2; }
            logical_host=$2
            shift 2
            ;;
        --write-probe) write_probe=1; shift ;;
        -h|--help) usage; exit 0 ;;
        *) usage; exit 2 ;;
    esac
done
[ -n "$logical_host" ] || { usage; exit 2; }
require_safe_id "$logical_host"
profile=$(profile_for "$logical_host")
if [ "${HARNESS_TESTING:-0}" = 1 ] && [ -n "${HARNESS_HOST_PROFILE:-}" ]; then
    profile=$HARNESS_HOST_PROFILE
fi
[ -f "$profile" ] && [ ! -L "$profile" ] || die "invalid host profile"
case ${HARNESS_LOGICAL_HOST:-$logical_host} in
    "$logical_host") ;;
    *) die "logical host does not match this environment" ;;
esac

layout=$HARNESS_ROOT/profiles/home-layout.tsv
if [ "${HARNESS_TESTING:-0}" = 1 ] && [ -n "${HARNESS_HOME_LAYOUT:-}" ]; then
    layout=$HARNESS_HOME_LAYOUT
fi
[ -f "$layout" ] && [ ! -L "$layout" ] || die "invalid home layout declaration"
row=$(awk -F'|' -v host="$logical_host" '
    $0 !~ /^#/ && $1 == host {
        if (NF != 7) exit 2
        print
        count++
    }
    END { if (count != 1) exit 1 }
' "$layout") || die "home layout row is not unique and valid"
IFS='|' read -r row_host persistent_root cache_root _ <<EOF
$row
EOF
[ "$row_host" = "$logical_host" ] || die "home layout host mismatch"
for root in "$persistent_root" "$cache_root"; do
    case $root in
        /*) ;;
        *) die "storage root is not absolute" ;;
    esac
done

uid=$(id -u)
home=$(realpath -e -- "$HOME") || die "current HOME is not canonical"
active_probe=
active_root=
active_root_identity=

cleanup_probe() {
    status=$?
    trap - EXIT HUP INT TERM
    if [ -n "$active_probe" ]; then
        valid=1
        [ -f "$active_probe" ] && [ ! -L "$active_probe" ] || valid=0
        [ "$(dirname -- "$active_probe")" = "$active_root" ] || valid=0
        [ "$(stat -c %d:%i -- "$active_root")" = "$active_root_identity" ] || valid=0
        case ${active_probe##*/} in
            .harness-storage-readiness."$logical_host".*) ;;
            *) valid=0 ;;
        esac
        if [ "$valid" -eq 1 ] && [ "$(stat -c %u -- "$active_probe")" = "$uid" ]; then
            unlink -- "$active_probe" || status=2
        else
            status=2
        fi
    fi
    exit "$status"
}
trap cleanup_probe EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

check_root() {
    label=$1
    declared=$2
    [ -d "$declared" ] && [ ! -L "$declared" ] || die "$label root is not a real directory"
    canonical_root=$(realpath -e -- "$declared") || die "$label root cannot be canonicalized"
    canonical_alias=0
    if [ "$canonical_root" != "$declared" ]; then
        expected_canonical=$(config_get "$profile" "${label}_canonical_root")
        [ "$canonical_root" = "$expected_canonical" ] ||
            die "$label root canonical identity is not explicitly declared"
        canonical_alias=1
    fi
    case $canonical_root in
        "$home"|"$home"/*) die "$label root is inside HOME" ;;
    esac
    root=$declared
    root_identity=$(stat -c %d:%i -- "$root")
    [ "$root_identity" = "$(stat -c %d:%i -- "$canonical_root")" ] ||
        die "$label root canonical object mismatch"
    [ "$(stat -c %u -- "$root")" = "$uid" ] || die "$label root owner mismatch"
    [ -w "$root" ] || die "$label root is not writable"
    filesystem=$(stat -f -c %T -- "$root")
    available_kib=$(df -Pk -- "$root" | awk 'NR == 2 { print $4 }')
    available_inodes=$(df -Pi -- "$root" | awk 'NR == 2 { print $4 }')
    case "$available_kib:$available_inodes" in
        *[!0-9:]*) die "$label capacity probe returned an unsafe value" ;;
    esac
    [ -n "$available_kib" ] && [ -n "$available_inodes" ] ||
        die "$label capacity probe returned no value"
    printf 'STORAGE host=%s label=%s status=ready filesystem=%s available_kib=%s available_inodes=%s outside_home=1 canonical_alias=%s\n' \
        "$logical_host" "$label" "$filesystem" "$available_kib" "$available_inodes" "$canonical_alias"

    [ "$write_probe" -eq 1 ] || return 0
    umask 077
    active_root=$root
    active_root_identity=$root_identity
    active_probe=$(mktemp "$root/.harness-storage-readiness.$logical_host.$label.XXXXXX") ||
        die "$label cannot create exact probe"
    chmod 600 "$active_probe"
    [ -f "$active_probe" ] && [ ! -L "$active_probe" ] || die "$label probe changed type"
    [ "$(stat -c %u -- "$active_probe")" = "$uid" ] || die "$label probe owner mismatch"
    [ "$(stat -c %a -- "$active_probe")" = 600 ] || die "$label probe mode mismatch"
    dd if=/dev/zero of="$active_probe" bs=4096 count=1 conv=fsync status=none
    [ "$(stat -c %s -- "$active_probe")" = 4096 ] || die "$label probe size mismatch"
    [ "$(stat -c %d:%i -- "$active_root")" = "$active_root_identity" ] ||
        die "$label root identity changed before cleanup"
    unlink -- "$active_probe"
    [ ! -e "$active_probe" ] && [ ! -L "$active_probe" ] || die "$label probe remains"
    active_probe=
    active_root=
    active_root_identity=
    printf 'STORAGE_WRITE host=%s label=%s bytes=4096 fsync=pass cleanup=absent\n' \
        "$logical_host" "$label"
}

check_root persistent "$persistent_root"
check_root cache "$cache_root"
