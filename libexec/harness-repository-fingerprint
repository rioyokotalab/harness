#!/bin/sh
set -eu

[ "$#" -eq 1 ] || {
    echo "usage: harness-repository-fingerprint ABSOLUTE_REPOSITORY" >&2
    exit 2
}
root=$1
case "$root" in
    /*) ;;
    *) echo "repository path must be absolute" >&2; exit 2 ;;
esac
[ -d "$root" ] && [ ! -L "$root" ] || {
    echo "repository root must be a non-symlink directory" >&2
    exit 2
}
for directory in data index keys locks snapshots; do
    [ -d "$root/$directory" ] && [ ! -L "$root/$directory" ] || {
        echo "repository structure is incomplete" >&2
        exit 2
    }
done
[ -f "$root/config" ] && [ ! -L "$root/config" ] || {
    echo "repository structure is incomplete" >&2
    exit 2
}
exec python3 - "$root" <<'PY'
import hashlib
import os
import stat
import sys

root = os.fsencode(sys.argv[1])
root_device = os.lstat(root).st_dev
entries = 0
total_bytes = 0
files = []
stack = [(root, b".")]

while stack:
    path, relative = stack.pop()
    metadata = os.lstat(path)
    if stat.S_ISLNK(metadata.st_mode):
        raise SystemExit("repository contains a symlink")
    if metadata.st_dev != root_device:
        raise SystemExit("repository contains a nested filesystem")
    entries += 1
    if stat.S_ISREG(metadata.st_mode):
        total_bytes += metadata.st_size
        files.append((relative, path, metadata.st_size))
    elif stat.S_ISDIR(metadata.st_mode):
        children = []
        with os.scandir(path) as directory:
            for child in directory:
                name = os.fsencode(child.name)
                child_relative = name if relative == b"." else relative + b"/" + name
                children.append((os.fsencode(child.path), child_relative))
        stack.extend(children)

if os.listdir(os.path.join(root, b"locks")):
    raise SystemExit("repository has an active or stale Restic lock")

digest = hashlib.sha256()
for relative, path, size in sorted(files):
    digest.update(len(relative).to_bytes(8, "big"))
    digest.update(relative)
    digest.update(size.to_bytes(8, "big"))
    with open(path, "rb") as source:
        for block in iter(lambda: source.read(1024 * 1024), b""):
            digest.update(block)

print(f"entries={entries};bytes={total_bytes};sha256={digest.hexdigest()}")
PY
