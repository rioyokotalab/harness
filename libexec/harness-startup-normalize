class Refusal(Exception):
    pass


def b(value):
    return value.encode("utf-8")


def rule(name, before, after):
    return {"name": name, "before": b(before), "after": b(after)}


MANAGED_LOCAL = """# >>> harness managed >>>
HARNESS_LOGICAL_HOST=local
export HARNESS_LOGICAL_HOST
