#!/bin/sh
set -eu

SELF_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
HARNESS_ROOT=${HARNESS_ROOT:-$(CDPATH='' cd -- "$SELF_DIR/.." && pwd)}
export HARNESS_ROOT
. "$SELF_DIR/harness-common"
. "$SELF_DIR/harness-macos-common"

usage() {
    echo "Usage: harness macos-doctor --host LOGICAL_ID [--facts FILE]" >&2
}

logical_host=
fact_file=
owned_fact=
while [ "$#" -gt 0 ]; do
    case "$1" in
        --host) [ "$#" -ge 2 ] || { usage; exit 2; }; logical_host=$2; shift 2 ;;
        --facts) [ "$#" -ge 2 ] || { usage; exit 2; }; fact_file=$2; shift 2 ;;
        -h|--help) usage; exit 0 ;;
        *) usage; exit 2 ;;
    esac
done
[ -n "$logical_host" ] || { usage; exit 2; }
macos_private_id_is_safe "$logical_host" || die "invalid private logical identifier"
case ${HOME:-} in /*) ;; *) die "macOS doctor requires an absolute HOME" ;; esac
current_uid=$(id -u)
public_profile=$HARNESS_ROOT/profiles/personal-macos/base.conf
macos_validate_public_profile "$public_profile"
formula_policy=$HARNESS_ROOT/profiles/personal-macos/formula-policy-v4.conf
[ -f "$formula_policy" ] && [ ! -L "$formula_policy" ] ||
    die "public personal-Mac formula policy is unavailable"
macos_validate_formula_policy "$formula_policy"

if [ -z "$fact_file" ]; then
    owned_fact=$(mktemp "${TMPDIR:-/tmp}/harness-macos-doctor-facts.XXXXXX") ||
        die "cannot allocate macOS fact file"
    fact_file=$owned_fact
    "$SELF_DIR/harness-macos-inventory" --host "$logical_host" >"$fact_file"
    chmod 600 "$fact_file"
fi
cleanup_doctor_fact() {
    status=$?
    trap - EXIT HUP INT TERM
    if [ -n "$owned_fact" ] &&
        { [ -e "$owned_fact" ] || [ -L "$owned_fact" ]; }; then
        unlink "$owned_fact"
    fi
    exit "$status"
}
trap cleanup_doctor_fact EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

macos_require_private_file "$fact_file" "$current_uid"
macos_validate_fact_file "$fact_file" "$formula_policy"
[ "$(macos_manifest_get "$fact_file" logical_id)" = "$logical_host" ] ||
    die "personal-Mac fact identity mismatch"

failures=0
warnings=0
echo 'MACOS_DOCTOR privacy=value-free'
for requirement in architecture homebrew command_line_tools private_profile \
    harness_checkout; do
    value=$(macos_manifest_get "$fact_file" "$requirement")
    expected=present
    [ "$requirement" != architecture ] || expected=supported
    [ "$requirement" != private_profile ] || expected=valid
    case "$requirement:$value" in
        architecture:arm64|architecture:x86_64|homebrew:present|\
        command_line_tools:present|private_profile:valid|harness_checkout:present)
            echo "PASS required=$requirement state=$value"
            ;;
        *)
            echo "FAIL required=$requirement state=$value expected=$expected"
            failures=$((failures + 1))
            ;;
    esac
done

case $(macos_manifest_get "$fact_file" homebrew_prefix_class) in
    apple-silicon-default|intel-default) ;;
    *) echo 'WARN optional=homebrew_prefix state=nondefault-or-unknown'; warnings=$((warnings + 1)) ;;
esac

account_shell=$(macos_manifest_get "$fact_file" account_shell)
account_shell_registry=$(macos_manifest_get "$fact_file" account_shell_registry)
if [ "$account_shell" = homebrew-bash ]; then
    echo 'PASS required=account_shell state=homebrew-bash'
else
    echo "FAIL required=account_shell state=$account_shell expected=homebrew-bash"
    failures=$((failures + 1))
fi
if [ "$account_shell_registry" = present ]; then
    echo 'PASS required=account_shell_registry state=present'
else
    echo "FAIL required=account_shell_registry state=$account_shell_registry expected=present"
    failures=$((failures + 1))
fi

for link_name in codex_guidance claude_guidance bash_launcher; do
    value=$(macos_manifest_get "$fact_file" "link_$link_name")
    case "$link_name" in
        codex_guidance)
            link_destination=$HOME/.codex/AGENTS.md
            link_source=$HARNESS_ROOT/.codex/AGENTS.md
            ;;
        claude_guidance)
            link_destination=$HOME/.claude/CLAUDE.md
            link_source=$HARNESS_ROOT/config/agent-clients/claude-sentinel.md
            ;;
        bash_launcher)
            link_destination=$HOME/.local/bin/harness-bash
            link_source=$HARNESS_ROOT/bin/harness-bash
            ;;
    esac
    if [ "$value" = symlink ] && [ -L "$link_destination" ] &&
        [ "$(readlink "$link_destination")" = "$link_source" ]; then
        echo "PASS required=link_$link_name state=symlink"
    else
        echo "FAIL required=link_$link_name state=$value expected=symlink"
        failures=$((failures + 1))
    fi
done

private_root=$HOME/.config/harness/private
ssh_payload_adopted=0
config_bundle_adopted=0
if git -C "$private_root" ls-files --error-unmatch \
        "ssh/$logical_host.conf" >/dev/null 2>&1 ||
    git -C "$private_root" ls-files --error-unmatch ssh_config >/dev/null 2>&1; then
    ssh_payload_adopted=1
fi
if git -C "$private_root" ls-files --error-unmatch ssh_config >/dev/null 2>&1 &&
    git -C "$private_root" ls-files --error-unmatch bashrc >/dev/null 2>&1 &&
    git -C "$private_root" ls-files --error-unmatch tmux.conf >/dev/null 2>&1; then
    config_bundle_adopted=1
fi

if [ "$ssh_payload_adopted" -eq 1 ]; then
    live_ssh=$HOME/.ssh/config
    managed_ssh_fragment=$HOME/.ssh/config.d/harness.conf
    canonical_ssh_fragment=$HARNESS_ROOT/config/ssh/harness.conf
    if (macos_validate_ssh_config "$live_ssh" "$current_uid" 600,644) \
            >/dev/null 2>&1 &&
        [ "$(tail -n 1 "$live_ssh" 2>/dev/null || true)" = \
            'Include ~/.ssh/config.d/harness.conf' ] &&
        [ "$(tail -n 2 "$live_ssh" 2>/dev/null | head -n 1 || true)" = \
            'Match all' ] &&
        [ -f "$managed_ssh_fragment" ] && [ ! -L "$managed_ssh_fragment" ] &&
        [ "$(macos_stat_owner "$managed_ssh_fragment")" = "$current_uid" ] &&
        [ "$(macos_stat_links "$managed_ssh_fragment")" = 1 ] &&
        [ "$(macos_stat_mode "$managed_ssh_fragment")" = 600 ] &&
        cmp -s "$managed_ssh_fragment" "$canonical_ssh_fragment"; then
        echo 'PASS required=ssh_layout state=terminal-include+canonical-regular-fragment'
    else
        echo 'FAIL required=ssh_layout state=missing-or-wrong expected=terminal-include+canonical-regular-fragment'
        failures=$((failures + 1))
    fi
fi

bash_loader_destination=$HOME/.config/harness/managed/personal-macos.bash
if [ "$config_bundle_adopted" -eq 1 ]; then
    bash_loader_source=$HARNESS_ROOT/shell/personal-macos.bash
    if [ -L "$bash_loader_destination" ] &&
        [ "$(readlink "$bash_loader_destination")" = "$bash_loader_source" ]; then
        echo 'PASS required=bash_loader state=symlink'
    else
        echo 'FAIL required=bash_loader state=missing-or-wrong expected=symlink'
        failures=$((failures + 1))
    fi
    bash_startup_block=$HARNESS_ROOT/shell/personal-macos-startup.block
    for bash_startup_name in bash_profile bashrc; do
        bash_startup_path=$HOME/.$bash_startup_name
        if [ -f "$bash_startup_path" ] && [ ! -L "$bash_startup_path" ] &&
            [ "$(macos_stat_owner "$bash_startup_path")" = "$current_uid" ] &&
            [ "$(macos_stat_links "$bash_startup_path")" = 1 ] &&
            macos_file_contains_exact_block_once "$bash_startup_block" "$bash_startup_path"; then
            echo "PASS required=$bash_startup_name state=managed-block-v1"
        else
            echo "FAIL required=$bash_startup_name state=missing-or-wrong expected=managed-block-v1"
            failures=$((failures + 1))
        fi
    done
else
    if [ ! -e "$bash_loader_destination" ] && [ ! -L "$bash_loader_destination" ]; then
        echo 'PASS required=bash_loader state=retired'
    else
        echo 'FAIL required=bash_loader state=present expected=retired'
        failures=$((failures + 1))
    fi
    if [ -e "$HOME/.bash_profile" ] || [ -L "$HOME/.bash_profile" ]; then
        bash_login_name=bash_profile
    elif [ -e "$HOME/.bash_login" ] || [ -L "$HOME/.bash_login" ]; then
        bash_login_name=bash_login
    else
        bash_login_name=profile
    fi
    for bash_startup_name in "$bash_login_name" bashrc; do
        bash_startup_path=$HOME/.$bash_startup_name
        case "$bash_startup_name" in bashrc) bash_suffix=$HARNESS_ROOT/shell/bashrc.block ;; *) bash_suffix=$HARNESS_ROOT/shell/bash_profile.block ;; esac
        if [ "$bash_startup_name" = bash_profile ] &&
            [ "$(macos_stat_owner "$bash_startup_path" 2>/dev/null || true)" = "$current_uid" ] &&
            [ "$(macos_stat_links "$bash_startup_path" 2>/dev/null || true)" = 1 ] &&
            cmp -s "$bash_startup_path" "$HARNESS_ROOT/shell/bash_profile.canonical"; then
            echo "PASS required=$bash_startup_name state=canonical-thin-loader"
        elif [ "$(macos_stat_owner "$bash_startup_path" 2>/dev/null || true)" = "$current_uid" ] &&
            [ "$(macos_stat_links "$bash_startup_path" 2>/dev/null || true)" = 1 ] &&
            macos_file_has_public_bash_layout "$bash_startup_path" "$logical_host" "$bash_suffix"; then
            echo "PASS required=$bash_startup_name state=public-pre-local-public-post"
        else
            echo "FAIL required=$bash_startup_name state=missing-or-wrong expected=public-pre-local-public-post"
            failures=$((failures + 1))
        fi
    done
    tmux_source=$HARNESS_ROOT/config/tmux/tmux.conf
    if [ -L "$HOME/.tmux.conf" ] && [ "$(readlink "$HOME/.tmux.conf")" = "$tmux_source" ]; then
        echo 'PASS required=tmux_config state=public-symlink'
    else
        echo 'FAIL required=tmux_config state=missing-or-wrong expected=public-symlink'
        failures=$((failures + 1))
    fi
fi

public_formulae=$(macos_manifest_get "$formula_policy" managed_formulae)
retired_formulae=$(macos_manifest_get "$formula_policy" retired_formulae)
public_missing=0
for formula in $(printf '%s\n' "$public_formulae" | tr ',' ' '); do
    state=$(macos_manifest_get "$fact_file" \
        "formula_$(macos_formula_key "$formula")")
    [ "$state" = present ] || public_missing=$((public_missing + 1))
done
public_total=$(macos_token_count "$public_formulae")
if [ "$public_missing" -eq 0 ]; then
    echo "PASS required=public_formulae missing=0 total=$public_total"
else
    echo "FAIL required=public_formulae missing=$public_missing total=$public_total"
    failures=$((failures + 1))
fi

retired_present=0
for formula in $(printf '%s\n' "$retired_formulae" | tr ',' ' '); do
    state=$(macos_manifest_get "$fact_file" \
        "formula_$(macos_formula_key "$formula")")
    [ "$state" = absent ] || retired_present=$((retired_present + 1))
done
retired_total=$(macos_token_count "$retired_formulae")
if [ "$retired_present" -eq 0 ]; then
    echo "PASS required=retired_formulae present=0 total=$retired_total"
else
    echo "FAIL required=retired_formulae present=$retired_present total=$retired_total"
    failures=$((failures + 1))
fi

private_missing=0
if "$SELF_DIR/harness-macos-profile" --host "$logical_host" >/dev/null 2>&1; then
    host_manifest=$HOME/.config/harness/private/hosts/$logical_host.conf
    extra_formulae=$(macos_manifest_get "$host_manifest" extra_formulae)
    brew_command=$(command -v brew 2>/dev/null || true)
    if [ "$extra_formulae" != none ]; then
        if [ "$(macos_manifest_get "$fact_file" homebrew)" != present ] ||
            [ -z "$brew_command" ]; then
            private_missing=$(macos_token_count "$extra_formulae")
        else
            for formula in $(printf '%s\n' "$extra_formulae" | tr ',' ' '); do
                if ! HOMEBREW_NO_AUTO_UPDATE=1 HOMEBREW_NO_ANALYTICS=1 \
                    "$brew_command" list --formula --versions "$formula" \
                    >/dev/null 2>&1; then
                    private_missing=$((private_missing + 1))
                fi
            done
        fi
    fi
else
    private_missing=unknown
fi
if [ "$private_missing" = 0 ]; then
    echo 'PASS required=private_formulae missing=0 values=not-emitted'
else
    echo "FAIL required=private_formulae missing=$private_missing values=not-emitted"
    failures=$((failures + 1))
fi

ssh_sync_state=$HOME/.local/state/harness/personal-macos/ssh-sync-status.conf
config_sync_state=$HOME/.local/state/harness/personal-macos/config-sync-status.conf
if [ "$config_bundle_adopted" -eq 1 ]; then
    if [ -f "$config_sync_state" ] && [ ! -L "$config_sync_state" ]; then
        macos_require_private_file "$config_sync_state" "$current_uid"
        macos_validate_manifest "$config_sync_state" schema,class,agreement \
            schema,class,agreement
        config_sync_schema=$(macos_manifest_get "$config_sync_state" schema)
        config_sync_class=$(macos_manifest_get "$config_sync_state" class)
        config_sync_agreement=$(macos_manifest_get "$config_sync_state" agreement)
        [ "$config_sync_schema" = 2 ] || die "Mac config sync status is malformed"
        case "$config_sync_class:$config_sync_agreement" in
            current:yes)
                echo 'PASS required=config_sync class=current agreement=yes payloads=3'
                ;;
            current:no|diverged:no|invalid:no|offline:no|auth-failed:no)
                echo "FAIL required=config_sync class=$config_sync_class agreement=no payloads=3"
                failures=$((failures + 1))
                ;;
            *) die "Mac config sync status is malformed" ;;
        esac
    else
        echo 'FAIL required=config_sync class=invalid agreement=no payloads=3'
        failures=$((failures + 1))
    fi
elif [ "$ssh_payload_adopted" -eq 0 ] &&
    [ ! -e "$ssh_sync_state" ] && [ ! -L "$ssh_sync_state" ]; then
    echo 'PASS optional=ssh_sync class=current agreement=not-adopted'
elif [ -f "$ssh_sync_state" ] && [ ! -L "$ssh_sync_state" ]; then
    macos_require_private_file "$ssh_sync_state" "$current_uid"
    macos_validate_manifest "$ssh_sync_state" schema,class,agreement \
        schema,class,agreement
    ssh_sync_class=$(macos_manifest_get "$ssh_sync_state" class)
    ssh_sync_agreement=$(macos_manifest_get "$ssh_sync_state" agreement)
    case "$ssh_sync_class:$ssh_sync_agreement" in
        current:yes)
            echo 'PASS required=ssh_sync class=current agreement=yes'
            ;;
        current:no|diverged:no|invalid:no|offline:no|auth-failed:no)
            echo "FAIL required=ssh_sync class=$ssh_sync_class agreement=no"
            failures=$((failures + 1))
            ;;
        *) die "Mac SSH sync status is malformed" ;;
    esac
else
    echo 'FAIL required=ssh_sync class=invalid agreement=no'
    failures=$((failures + 1))
fi

if [ "$failures" -eq 0 ]; then
    echo "END macos_doctor status=ready failures=0 warnings=$warnings"
    exit 0
fi
echo "END macos_doctor status=not-ready failures=$failures warnings=$warnings"
exit 1
