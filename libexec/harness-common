#!/bin/sh

die() {
    echo "harness: $*" >&2
    exit 2
}

require_safe_id() {
    value=$1
    case "$value" in
        ''|*[!A-Za-z0-9._-]*)
            die "invalid logical host identifier: $value"
            ;;
    esac
}

config_get() {
    config_file=$1
    config_key=$2
    [ -f "$config_file" ] || die "missing configuration: $config_file"
    value=$(sed -n "s/^${config_key}=//p" "$config_file")
    count=$(printf '%s\n' "$value" | awk 'NF { n++ } END { print n + 0 }')
    [ "$count" -le 1 ] || die "duplicate key $config_key in $config_file"
    printf '%s\n' "$value"
}

fact_get() {
    fact_file=$1
    fact_key=$2
    [ -f "$fact_file" ] || die "missing fact file: $fact_file"
    value=$(sed -n "s/^${fact_key}=//p" "$fact_file")
    count=$(printf '%s\n' "$value" | awk 'NF { n++ } END { print n + 0 }')
    [ "$count" -le 1 ] || die "duplicate fact $fact_key in $fact_file"
    if [ -n "$value" ]; then
        printf '%s\n' "$value"
    else
        printf '%s\n' unknown
    fi
}

fact_key_for_command() {
    printf '%s' "$1" | sed 's/+/p/g; s/-/_/g'
}

profile_for() {
    logical_host=$1
    require_safe_id "$logical_host"
    profile=$HARNESS_ROOT/profiles/hosts/$logical_host.conf
    [ -f "$profile" ] || die "unknown logical host profile: $logical_host"
    printf '%s\n' "$profile"
}

path_kind() {
    path=$1
    if [ -L "$path" ]; then
        printf '%s\n' symlink
    elif [ -f "$path" ]; then
        printf '%s\n' regular
    elif [ -d "$path" ]; then
        printf '%s\n' directory
    elif [ -e "$path" ]; then
        printf '%s\n' other
    else
        printf '%s\n' absent
    fi
}

# Delete one already-identified tree only through the same immutable
# plan/revalidate/apply workflow exposed to agents. The caller supplies an
# existing retained boundary and a separate existing directory for short-lived
# manifest state. A subshell contains failures so transaction traps can retain
# their original status while reporting cleanup failure.
guarded_delete_tree() (
    set -eu
    [ "$#" -eq 3 ] || { echo "harness: guarded_delete_tree requires boundary, target, and state parent" >&2; exit 2; }
    boundary=$1
    target=$2
    state_parent=$3
    platform=$(uname -s)
    canonical_path() {
        case "$platform" in Darwin) realpath "$1" ;; *) realpath -e -- "$1" ;; esac
    }
    path_owner() {
        case "$platform" in Darwin) stat -f '%u' "$1" ;; *) stat -c '%u' -- "$1" ;; esac
    }
    path_mode() {
        case "$platform" in Darwin) stat -f '%Lp' "$1" ;; *) stat -c '%a' -- "$1" ;; esac
    }
    path_id() {
        case "$platform" in Darwin) stat -f '%d:%i' "$1" ;; *) stat -Lc '%d:%i' -- "$1" ;; esac
    }
    authoritative_home() {
        case "$platform" in
            Darwin)
                dscacheutil -q user -a uid "$uid" | awk '
                    $1 == "dir:" { value=$2; count++ }
                    END { if (count != 1 || value == "") exit 1; print value }
                '
                ;;
            *)
                getent passwd "$uid" | awk -F: -v uid="$uid" '
                    $3 == uid { value=$6; count++ }
                    END { if (count != 1 || value == "") exit 1; print value }
                '
                ;;
        esac
    }
    case "$boundary:$target:$state_parent" in
        /*:/*:/*) ;;
        *) echo "harness: guarded_delete_tree paths must be absolute" >&2; exit 2 ;;
    esac
    for required in awk id mktemp realpath rmdir sed stat uname unlink; do
        command -v "$required" >/dev/null 2>&1 || {
            echo "harness: guarded_delete_tree requires command: $required" >&2
            exit 2
        }
    done
    case "$platform" in
        Darwin) required=dscacheutil ;;
        *) required=getent ;;
    esac
    command -v "$required" >/dev/null 2>&1 || {
        echo "harness: guarded_delete_tree requires command: $required" >&2
        exit 2
    }
    [ -d "$boundary" ] && [ ! -L "$boundary" ] || {
        echo "harness: guarded deletion boundary changed type: $boundary" >&2
        exit 2
    }
    [ -d "$target" ] && [ ! -L "$target" ] || {
        echo "harness: guarded deletion target changed type: $target" >&2
        exit 2
    }
    [ -d "$state_parent" ] && [ ! -L "$state_parent" ] || {
        echo "harness: guarded deletion state parent changed type: $state_parent" >&2
        exit 2
    }
    boundary=$(canonical_path "$boundary")
    target=$(canonical_path "$target")
    state_parent=$(canonical_path "$state_parent")
    current_home=$(canonical_path "$HOME") || {
        echo "harness: current HOME is not a canonical directory" >&2
        exit 2
    }
    case "$current_home" in
        "$target"|"$target"/*)
            echo "harness: guarded deletion target is or contains current HOME: $target" >&2
            exit 2
            ;;
    esac

    uid=$(id -u)
    account_home=$(authoritative_home) || {
        echo "harness: cannot resolve authoritative account HOME" >&2; exit 2;
    }
    canonical_account_home=$(canonical_path "$account_home") || {
        echo "harness: authoritative account HOME is unavailable" >&2
        exit 2
    }
    [ "$(path_id "$account_home")" = "$(path_id "$canonical_account_home")" ] || {
        echo "harness: lexical and canonical account HOME identities differ" >&2
        exit 2
    }
    guard=$HARNESS_ROOT/shared/skills/guarded-bulk-delete/scripts/guarded-delete
    [ -x "$guard" ] || { echo "harness: guarded-delete implementation is unavailable" >&2; exit 2; }

    delete_state=$(mktemp -d "$state_parent/.harness-delete.XXXXXX") || {
        echo "harness: cannot allocate guarded deletion state" >&2
        exit 2
    }
    chmod 700 "$delete_state"
    manifest=$delete_state/manifest
    cleanup_delete_state() {
        status=$?
        trap - EXIT HUP INT TERM
        if [ -n "${delete_state:-}" ] && [ -d "$delete_state" ]; then
            if [ -e "$manifest" ] || [ -L "$manifest" ]; then
                echo "harness: preserved failed guarded deletion manifest: $manifest" >&2
            else
                rmdir "$delete_state" 2>/dev/null ||
                    echo "harness: preserved nonempty guarded deletion state: $delete_state" >&2
            fi
        fi
        exit "$status"
    }
    trap cleanup_delete_state EXIT
    trap 'exit 129' HUP
    trap 'exit 130' INT
    trap 'exit 143' TERM

    plan_output=$(HOME="$account_home" "$guard" plan --within "$boundary" \
        --manifest "$manifest" -- "$target")
    printf '%s\n' "$plan_output"
    token=$(printf '%s\n' "$plan_output" | sed -n 's/^TOKEN sha256=//p')
    case "$token" in
        *[!0-9a-f]*|'') echo "harness: guarded deletion plan emitted an invalid token" >&2; exit 2 ;;
    esac
    [ "${#token}" -eq 64 ] || { echo "harness: guarded deletion token length is invalid" >&2; exit 2; }
    HOME="$account_home" "$guard" apply --manifest "$manifest" --token "$token"
    [ -f "$manifest" ] && [ ! -L "$manifest" ] &&
        [ "$(canonical_path "$manifest")" = "$manifest" ] &&
        [ "$(path_owner "$manifest")" = "$uid" ] &&
        [ "$(path_mode "$manifest")" = 600 ] || {
            echo "harness: guarded deletion manifest changed after apply" >&2
            exit 2
        }
    unlink "$manifest"
    rmdir "$delete_state"
    delete_state=
)

make_fact_file() {
    logical_host=$1
    temp_file=$(mktemp "${TMPDIR:-/tmp}/harness-facts.XXXXXX") ||
        die "cannot create temporary fact file"
    "$HARNESS_ROOT/libexec/harness-inventory" --host "$logical_host" >"$temp_file"
    printf '%s\n' "$temp_file"
}

csv_commands() {
    csv=$1
    [ "$csv" = none ] && return
    printf '%s\n' "$csv" | tr ',' '\n'
}

managed_links() {
    printf '%s|%s\n' "$HARNESS_ROOT/bin/harness" "$HOME/.local/bin/harness"
    printf '%s|%s\n' "$HARNESS_ROOT/.codex/AGENTS.md" "$HOME/.codex/AGENTS.md"
    printf '%s|%s\n' "$HARNESS_ROOT/config/agent-clients/claude-sentinel.md" \
        "$HOME/.claude/CLAUDE.md"
}
