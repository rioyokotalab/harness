#!/bin/sh
set -eu

SELF_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
HARNESS_ROOT=${HARNESS_ROOT:-$(CDPATH='' cd -- "$SELF_DIR/.." && pwd)}
export HARNESS_ROOT
. "$SELF_DIR/harness-common"
. "$SELF_DIR/harness-macos-common"

usage() {
    cat >&2 <<'EOF'
Usage:
  harness agent-config [--plan|--apply] [--adopt] [--drill]
  harness agent-config --inventory|--doctor
  harness agent-config --rollback TRANSACTION_ID
EOF
}

mode=plan
adopt=no
drill=no
rollback_id=
while [ "$#" -gt 0 ]; do
    case $1 in
        --plan) mode=plan; shift ;;
        --apply) mode=apply; shift ;;
        --adopt) adopt=yes; shift ;;
        --drill) drill=yes; shift ;;
        --inventory) mode=inventory; shift ;;
        --doctor) mode=doctor; shift ;;
        --rollback)
            [ "$#" -ge 2 ] || { usage; exit 2; }
            mode=rollback; rollback_id=$2; shift 2
            ;;
        -h|--help) usage; exit 0 ;;
        *) usage; exit 2 ;;
    esac
done

current_uid=$(id -u)
codex_sentinel=$HARNESS_ROOT/.codex/AGENTS.md
claude_sentinel=$HARNESS_ROOT/config/agent-clients/claude-sentinel.md
launcher_source=$HARNESS_ROOT/bin/harness-codex
codex_policy=$HARNESS_ROOT/.codex/config.toml
claude_policy=$HARNESS_ROOT/.claude/settings.json
legacy_codex_policy=$HARNESS_ROOT/config/agent-clients/codex.toml
legacy_claude_policy=$HARNESS_ROOT/config/agent-clients/claude.json
legacy_rules=$HARNESS_ROOT/.codex/rules/default.rules
home_layout_file=${HARNESS_HOME_LAYOUT_FILE:-$HARNESS_ROOT/profiles/home-layout.tsv}

require_home() {
    case ${HOME:-} in /*) ;; *) die "agent configuration requires an absolute HOME" ;; esac
    [ -d "$HOME" ] && [ ! -L "$HOME" ] ||
        die "agent configuration HOME is unsafe"
    [ "$(macos_stat_owner "$HOME")" = "$current_uid" ] ||
        die "agent configuration HOME owner is unsafe"
}

validate_checkout() {
    [ -d "$HARNESS_ROOT/.git" ] && [ ! -L "$HARNESS_ROOT/.git" ] ||
        die "agent configuration requires a Git harness checkout"
    physical_root=$(CDPATH='' cd -- "$HARNESS_ROOT" && pwd -P)
    [ "$(git -C "$HARNESS_ROOT" rev-parse --show-toplevel 2>/dev/null)" = "$physical_root" ] ||
        die "agent configuration checkout root is ambiguous"
    [ -z "$(git -C "$HARNESS_ROOT" status --porcelain --untracked-files=normal)" ] ||
        die "agent configuration requires a clean committed checkout"
    if [ "${HARNESS_TEST_ALLOW_NONMAIN:-0}" != 1 ]; then
        [ "$(git -C "$HARNESS_ROOT" symbolic-ref --quiet --short HEAD 2>/dev/null)" = main ] ||
            die "agent configuration requires the main branch"
    fi
}

validate_sources() {
    for tracked in AGENTS.md CLAUDE.md .codex/AGENTS.md .codex/config.toml \
        .codex/rules/default.rules .claude/settings.json \
        config/agent-clients/codex.toml config/agent-clients/claude.json \
        config/agent-clients/claude-sentinel.md bin/harness-codex; do
        [ "$(git -C "$HARNESS_ROOT" ls-files --error-unmatch "$tracked" 2>/dev/null)" = "$tracked" ] ||
            die "agent configuration source is untracked: $tracked"
        [ -f "$HARNESS_ROOT/$tracked" ] && [ ! -L "$HARNESS_ROOT/$tracked" ] ||
            die "agent configuration source has unsafe type: $tracked"
    done
    cmp -s "$codex_policy" "$legacy_codex_policy" ||
        die "project Codex policy differs from its public contract"
    cmp -s "$claude_policy" "$legacy_claude_policy" ||
        die "project Claude policy differs from its public contract"
    [ "$(sed -n '1p' "$HARNESS_ROOT/CLAUDE.md")" = @AGENTS.md ] &&
        [ "$(wc -l <"$HARNESS_ROOT/CLAUDE.md" | tr -d ' ')" = 1 ] ||
        die "root Claude import is invalid"
    command -v jq >/dev/null 2>&1 ||
        die "Claude configuration validator requires jq"
    jq -e '
        type == "object" and
        .permissions == {"defaultMode":"bypassPermissions"} and
        .skipDangerousModePermissionPrompt == true
    ' "$claude_policy" >/dev/null 2>&1 ||
        die "project Claude policy is invalid"
    awk '
        $0 == "approval_policy = \"never\"" { approval++ }
        $0 == "check_for_update_on_startup = false" { update++ }
        $0 == "sandbox_mode = \"danger-full-access\"" { sandbox++ }
        END { exit !(NR == 3 && approval == 1 && update == 1 && sandbox == 1) }
    ' "$codex_policy" >/dev/null 2>&1 ||
        die "project Codex policy is invalid"
    count=0
    for skill in "$HARNESS_ROOT"/shared/skills/*; do
        [ -d "$skill" ] || continue
        [ -f "$skill/SKILL.md" ] && [ ! -L "$skill/SKILL.md" ] ||
            die "canonical skill is invalid"
        name=${skill##*/}
        for link in "$HARNESS_ROOT/.agents/skills/$name" \
            "$HARNESS_ROOT/.claude/skills/$name"; do
            [ -L "$link" ] &&
                [ "$(readlink "$link")" = "../../shared/skills/$name" ] ||
                die "project skill discovery link is invalid: $name"
        done
        count=$((count + 1))
    done
    [ "$count" -gt 0 ] || die "no canonical project skills found"
}

strict_regular_owned() {
    [ -f "$1" ] && [ ! -L "$1" ] &&
        [ "$(macos_stat_owner "$1")" = "$current_uid" ] &&
        [ "$(macos_stat_links "$1")" = 1 ]
}

declared_local_symlink_is_safe() {
    [ "$1" = "$HOME/.local" ] && [ -L "$1" ] || return 1
    logical_host=${HARNESS_LOGICAL_HOST:-}
    case $logical_host in ''|*[!A-Za-z0-9._-]*) return 1 ;; esac
    [ -f "$home_layout_file" ] && [ ! -L "$home_layout_file" ] || return 1
    record=$(awk -F'|' -v host="$logical_host" '
        $1 == host { print; count++ }
        END { if (count != 1) exit 1 }
    ' "$home_layout_file") || return 1
    old_ifs=$IFS
    IFS='|'
    set -- $record
    IFS=$old_ifs
    [ "$#" -ge 4 ] || return 1
    persistent_root=$2
    moved_items=$4
    case ",$moved_items," in *,.local,*) ;; *) return 1 ;; esac
    persistent_physical=$(realpath "$persistent_root" 2>/dev/null) || return 1
    local_physical=$(realpath "$HOME/.local" 2>/dev/null) || return 1
    case $local_physical in "$persistent_physical"/*) ;; *) return 1 ;; esac
    [ -d "$HOME/.local" ] &&
        [ "$(macos_stat_owner "$HOME/.local")" = "$current_uid" ]
}

codex_config_is_legacy_managed() {
    strict_regular_owned "$HOME/.codex/config.toml" || return 1
    awk '
        $0 == "approval_policy = \"never\"" { if (++approval != 1 || section) bad=1; next }
        $0 == "check_for_update_on_startup = false" { if (++update != 1 || section) bad=1; next }
        $0 == "sandbox_mode = \"danger-full-access\"" { if (++sandbox != 1 || section) bad=1; next }
        $0 ~ /^model = "([^"\\]|\\.)*"$/ { if (++model != 1 || section) bad=1; next }
        $0 ~ /^model_reasoning_effort = "([^"\\]|\\.)*"$/ { if (++effort != 1 || section) bad=1; next }
        $0 == "" { next }
        $0 ~ /^\[projects\.\"([^\"\\]|\\.)+\"\]$/ { if (expect) bad=1; expect=1; section="project"; next }
        section == "project" && expect && $0 == "trust_level = \"trusted\"" { expect=0; next }
        $0 == "[tui.model_availability_nux]" { if (expect || ++tui != 1) bad=1; section="tui"; next }
        section == "tui" && $0 ~ /^"[A-Za-z0-9._-]+" = [0-9]+$/ { entries++; next }
        { bad=1 }
        END {
            if (approval != 1 || sandbox != 1 || expect || (tui && !entries)) bad=1
            exit bad ? 1 : 0
        }
    ' "$HOME/.codex/config.toml" >/dev/null 2>&1
}

records() {
    printf 'link|codex-sentinel|%s|%s|%s\n' \
        "$HOME/.codex/AGENTS.md" "$codex_sentinel" "$HARNESS_ROOT/codex/AGENTS.md"
    printf 'link|claude-sentinel|%s|%s|%s\n' \
        "$HOME/.claude/CLAUDE.md" "$claude_sentinel" "$HARNESS_ROOT/.claude/CLAUDE.md"
    printf 'link|launcher|%s|%s|-\n' \
        "$HOME/.local/bin/harness-codex" "$launcher_source"
    printf 'remove|codex-config|%s|regular-codex|-\n' "$HOME/.codex/config.toml"
    printf 'remove|claude-settings|%s|%s|-\n' \
        "$HOME/.claude/settings.json" "$legacy_claude_policy"
    printf 'remove|codex-rules|%s|%s|%s\n' \
        "$HOME/.codex/rules/default.rules" "$legacy_rules" "$HARNESS_ROOT/codex/rules/default.rules"
    for skill in "$HARNESS_ROOT"/shared/skills/*; do
        [ -f "$skill/SKILL.md" ] || continue
        name=${skill##*/}
        printf 'remove|codex-skill-%s|%s|%s|-\n' \
            "$name" "$HOME/.codex/skills/$name" "$skill"
        printf 'remove|agents-skill-%s|%s|%s|-\n' \
            "$name" "$HOME/.agents/skills/$name" "$skill"
        printf 'remove|claude-skill-%s|%s|%s|-\n' \
            "$name" "$HOME/.claude/skills/$name" "$skill"
    done
}

path_state() {
    kind=$1; label=$2; destination=$3; expected=$4; legacy=$5
    if [ "$kind" = link ]; then
        if [ -L "$destination" ]; then
            observed=$(readlink "$destination")
            if [ "$observed" = "$expected" ]; then printf current
            elif [ "$legacy" != - ] && [ "$observed" = "$legacy" ]; then printf legacy
            else printf collision
            fi
        elif [ -e "$destination" ]; then printf collision
        else printf absent
        fi
        return
    fi
    if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
        printf current
    elif [ "$expected" = regular-codex ] && codex_config_is_legacy_managed; then
        printf removable-regular
    elif [ -L "$destination" ]; then
        observed=$(readlink "$destination")
        if [ "$observed" = "$expected" ] ||
            { [ "$legacy" != - ] && [ "$observed" = "$legacy" ]; }; then
            printf removable-link
        else
            printf collision
        fi
    else
        printf collision
    fi
}

ensure_directory() (
    directory=$1
    [ "$directory" = "$HOME" ] && return
    case $directory in "$HOME"/*) ;; *) die "agent configuration parent is unsafe" ;; esac
    if [ -e "$directory" ] || [ -L "$directory" ]; then
        if [ -L "$directory" ]; then
            declared_local_symlink_is_safe "$directory" ||
                die "agent configuration parent is unsafe"
        else
            [ -d "$directory" ] &&
                [ "$(macos_stat_owner "$directory")" = "$current_uid" ] ||
                die "agent configuration parent is unsafe"
        fi
    else
        ensure_directory "${directory%/*}"
        mkdir "$directory"
        chmod 700 "$directory"
    fi
)

ensure_parent() {
    ensure_directory "${1%/*}"
}

prepare_state() {
    state_root=$HOME/.local/state/harness
    transaction_root=$state_root/transactions
    umask 077
    for directory in "$HOME/.local" "$HOME/.local/state" "$state_root" "$transaction_root"; do
        if [ -e "$directory" ] || [ -L "$directory" ]; then
            if [ -L "$directory" ]; then
                declared_local_symlink_is_safe "$directory" ||
                    die "agent configuration state path is unsafe"
            else
                [ -d "$directory" ] &&
                    [ "$(macos_stat_owner "$directory")" = "$current_uid" ] ||
                    die "agent configuration state path is unsafe"
            fi
        else
            mkdir "$directory"
            chmod 700 "$directory"
        fi
    done
}

restore_manifest() {
    restore_manifest_file=$1
    awk -F'|' '$1 == "path" { line[++n]=$0 } END { for (i=n; i; i--) print line[i] }' \
        "$restore_manifest_file" |
    while IFS='|' read -r marker kind label destination expected legacy prior backup prior_mode; do
        [ "$marker" = path ] || die "agent configuration manifest is malformed"
        post=$(path_state "$kind" "$label" "$destination" "$expected" "$legacy")
        case $prior in
            current)
                [ "$post" = current ] ||
                    die "agent configuration rollback blocked by changed live path: $label"
                ;;
            absent)
                case $post in
                    absent) ;;
                    current) unlink "$destination" ;;
                    *) die "agent configuration rollback blocked by changed live path: $label" ;;
                esac
                ;;
            legacy|removable-link)
                if [ "$post" = "$prior" ]; then continue; fi
                [ "$post" = current ] ||
                    die "agent configuration rollback blocked by changed live path: $label"
                [ "$kind" != link ] || unlink "$destination"
                target=$(sed -n '1p' "$backup")
                [ -n "$target" ] || die "agent configuration symlink backup is invalid"
                ln -s "$target" "$destination"
                ;;
            removable-regular)
                if [ "$post" = "$prior" ]; then continue; fi
                [ "$post" = current ] ||
                    die "agent configuration rollback blocked by changed live path: $label"
                cp "$backup" "$destination"
                chmod "$prior_mode" "$destination"
                ;;
            *) die "agent configuration manifest prior state is invalid" ;;
        esac
    done
}

rollback_transaction() {
    transaction=$1
    macos_private_id_is_safe "$transaction" ||
        die "invalid agent configuration transaction"
    prepare_state
    manifest=$transaction_root/$transaction.agent-config.manifest
    status_file=$transaction_root/$transaction.agent-config.status
    macos_require_private_file "$manifest" "$current_uid"
    macos_require_private_file "$status_file" "$current_uid"
    [ "$(sed -n '1p' "$status_file")" = complete ] ||
        die "agent configuration transaction is not complete"
    [ "$(sed -n '1p' "$manifest")" = schema=2 ] &&
        [ "$(sed -n '2p' "$manifest")" = operation=agent-config ] ||
        die "agent configuration transaction manifest is malformed"
    restore_manifest "$manifest"
    printf '%s\n' rolled-back >"$status_file"
    printf 'AGENT_CONFIG action=rolled-back transaction=%s activation=new-sessions\n' "$transaction"
}

require_home
validate_checkout
validate_sources
[ "$mode" = apply ] || [ "$drill" = no ] || { usage; exit 2; }

if [ "$mode" = rollback ]; then
    [ -n "$rollback_id" ] && [ "$adopt" = no ] || { usage; exit 2; }
    rollback_transaction "$rollback_id"
    exit 0
fi

record_file=$(mktemp "${TMPDIR:-/tmp}/agent-config-records.XXXXXX")
chmod 600 "$record_file"
trap 'unlink "$record_file"' EXIT HUP INT TERM
records >"$record_file"
blocked=0
changes=0
while IFS='|' read -r kind label destination expected legacy; do
    state=$(path_state "$kind" "$label" "$destination" "$expected" "$legacy")
    case $kind:$state in
        link:current|remove:current) action=none ;;
        link:absent|link:legacy) action=install; changes=$((changes + 1)) ;;
        remove:removable-link|remove:removable-regular)
            action=remove; changes=$((changes + 1))
            ;;
        *) action=blocked; blocked=$((blocked + 1)) ;;
    esac
    printf 'AGENT_CONFIG_PATH label=%s scope=user state=%s action=%s\n' \
        "$label" "$state" "$action"
done <"$record_file"
printf 'PROJECT_AGENT_CONFIG codex=ready claude=ready skills=%s\n' \
    "$(find "$HARNESS_ROOT/shared/skills" -mindepth 1 -maxdepth 1 -type d | wc -l | tr -d ' ')"

if [ "$mode" = inventory ]; then
    printf 'END agent_config_inventory schema=2 privacy=value-free blocked=%s changes=%s\n' \
        "$blocked" "$changes"
    exit 0
fi
if [ "$mode" = doctor ]; then
    if [ "$blocked" -eq 0 ] && [ "$changes" -eq 0 ]; then
        echo 'END agent_config_doctor schema=2 status=ready failures=0'
        exit 0
    fi
    printf 'END agent_config_doctor schema=2 status=not-ready failures=%s\n' \
        "$((blocked + changes))"
    exit 1
fi
printf 'AGENT_CONFIG schema=2 mode=%s adopt=%s blocked=%s changes=%s activation=new-sessions\n' \
    "$mode" "$adopt" "$blocked" "$changes"
[ "$blocked" -eq 0 ] || die "agent configuration plan contains blocked paths"
[ "$mode" = apply ] || { echo 'END agent_config apply=not-requested'; exit 0; }
[ "$changes" -gt 0 ] || {
    echo 'END agent_config action=none activation=unchanged'
    [ "$drill" = no ] || echo 'AGENT_CONFIG_DRILL rollback=not-needed reapply=no-op'
    exit 0
}

prepare_state
transaction_id=$(date -u +%Y%m%dT%H%M%SZ)-$$
manifest=$transaction_root/$transaction_id.agent-config.manifest
status_file=$transaction_root/$transaction_id.agent-config.status
umask 077
printf 'schema=2\noperation=agent-config\nrevision=%s\n' \
    "$(git -C "$HARNESS_ROOT" rev-parse HEAD)" >"$manifest"
printf '%s\n' prepared >"$status_file"
chmod 600 "$manifest" "$status_file"

while IFS='|' read -r kind label destination expected legacy; do
    ensure_parent "$destination"
    prior=$(path_state "$kind" "$label" "$destination" "$expected" "$legacy")
    backup=absent
    prior_mode=absent
    case $prior in
        current|absent) ;;
        legacy|removable-link)
            backup=$transaction_root/$transaction_id.agent-config.$label.before
            readlink "$destination" >"$backup"
            chmod 600 "$backup"
            ;;
        removable-regular)
            backup=$transaction_root/$transaction_id.agent-config.$label.before
            cp "$destination" "$backup"
            chmod 600 "$backup"
            prior_mode=$(macos_stat_mode "$destination")
            ;;
        *) die "agent configuration changed before apply: $label" ;;
    esac
    printf 'path|%s|%s|%s|%s|%s|%s|%s|%s\n' \
        "$kind" "$label" "$destination" "$expected" "$legacy" "$prior" "$backup" "$prior_mode" \
        >>"$manifest"
done <"$record_file"

complete=0
cleanup_apply() {
    status=$?
    trap - EXIT HUP INT TERM
    if [ "$complete" -eq 0 ]; then
        restore_manifest "$manifest" >/dev/null 2>&1 || true
        printf '%s\n' failed >"$status_file"
    fi
    unlink "$record_file"
    exit "$status"
}
trap cleanup_apply EXIT HUP INT TERM

while IFS='|' read -r kind label destination expected legacy; do
    state=$(path_state "$kind" "$label" "$destination" "$expected" "$legacy")
    case $kind:$state in
        link:current|remove:current) continue ;;
        link:absent) ln -s "$expected" "$destination" ;;
        link:legacy)
            unlink "$destination"
            ln -s "$expected" "$destination"
            ;;
        remove:removable-link|remove:removable-regular) unlink "$destination" ;;
        *) die "agent configuration changed during apply: $label" ;;
    esac
done <"$record_file"

while IFS='|' read -r kind label destination expected legacy; do
    [ "$(path_state "$kind" "$label" "$destination" "$expected" "$legacy")" = current ] ||
        die "agent configuration verification failed: $label"
done <"$record_file"
printf '%s\n' complete >"$status_file"
complete=1
trap - EXIT HUP INT TERM
unlink "$record_file"
printf 'AGENT_CONFIG action=applied transaction=%s rollback=available activation=new-sessions\n' \
    "$transaction_id"
if [ "$drill" = yes ]; then
    "$SELF_DIR/harness-agent-config" --rollback "$transaction_id"
    "$SELF_DIR/harness-agent-config" --apply
    printf 'AGENT_CONFIG_DRILL rollback=%s reapply=accepted\n' "$transaction_id"
    "$SELF_DIR/harness-agent-config" --doctor
fi
