#!/bin/sh
set -eu

SELF_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
HARNESS_ROOT=${HARNESS_ROOT:-$(CDPATH='' cd -- "$SELF_DIR/.." && pwd)}
export HARNESS_ROOT
. "$SELF_DIR/harness-common"

usage() {
    echo "Usage: harness rollback TRANSACTION_ID" >&2
}

agent_tree_hash() {
    rollback_tree=$1
    rollback_archive=$(mktemp "${TMPDIR:-/tmp}/harness-agent-tree.XXXXXX")
    tar --sort=name --mtime=@0 --owner=0 --group=0 --numeric-owner \
        -cf "$rollback_archive" -C "$rollback_tree" .
    rollback_hash=$(sha256sum "$rollback_archive" | awk '{print $1}')
    unlink "$rollback_archive"
    printf '%s\n' "$rollback_hash"
}

valid_codex_tree_path() {
    validation_tree=$1
    validation_prefix=$HOME/.local/opt/agents/codex/
    case "$validation_tree" in "$validation_prefix"*) ;; *) return 1 ;; esac
    validation_relative=${validation_tree#"$validation_prefix"}
    validation_version=${validation_relative%%/*}
    validation_target=${validation_relative#*/}
    case "$validation_target" in linux-x86_64|linux-aarch64) ;; *) return 1 ;; esac
    awk -v version="$validation_version" 'BEGIN {
        if (version !~ /^[0-9]+\.[0-9]+\.[0-9]+$/) exit 1
        if (split(version, part, ".") != 3) exit 1
        for (i = 1; i <= 3; i++)
            if (part[i] !~ /^(0|[1-9][0-9]*)$/) exit 1
    }'
}

[ "$#" -eq 1 ] || { usage; exit 2; }
transaction_id=$1
require_safe_id "$transaction_id"
manifest=$HOME/.local/state/harness/transactions/$transaction_id.manifest
[ -f "$manifest" ] || die "unknown transaction: $transaction_id"

records=$(mktemp "${TMPDIR:-/tmp}/harness-rollback.XXXXXX")
trap 'rm -f "$records"' EXIT HUP INT TERM
awk -F'|' '$1 == "link" || $1 == "managed-link-new" || $1 == "managed-link-replaced" || $1 == "shell" || $1 == "shell-new" || $1 == "shell-prefix" || $1 == "patch" || $1 == "artifact" || $1 == "runtime" || $1 == "python" || $1 == "agent" || $1 == "agent-replaced" { line[NR] = $0 } END { for (i = NR; i >= 1; i--) if (line[i] != "") print line[i] }' \
    "$manifest" >"$records"

# Validate every path before mutating any path.
while IFS='|' read -r record destination field3 field4 field5 field6 field7 field8; do
    case "$destination" in "$HOME"/*) ;; *) die "unsafe transaction path" ;; esac
    if [ "$record" = managed-link-new ]; then
        source=$field3
        if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
            continue
        fi
        [ -L "$destination" ] && [ "$(readlink "$destination")" = "$source" ] ||
            die "rollback blocked: managed link changed after apply: $destination"
    elif [ "$record" = managed-link-replaced ]; then
        source=$field3; backup=$field4; original_hash=$field5
        case "$backup" in "$HOME/.local/state/harness/transactions/"*) ;; *) die "rollback blocked: unsafe managed-link backup path" ;; esac
        [ -f "$backup" ] && [ ! -L "$backup" ] &&
            [ "$(sha256sum "$backup" | awk '{print $1}')" = "$original_hash" ] ||
            die "rollback blocked: managed-link backup changed"
        if [ -f "$destination" ] && [ ! -L "$destination" ] &&
            [ "$(sha256sum "$destination" | awk '{print $1}')" = "$original_hash" ]; then
            continue
        fi
        [ -L "$destination" ] && [ "$(readlink "$destination")" = "$source" ] ||
            die "rollback blocked: replaced managed link changed: $destination"
    elif [ "$record" = shell-new ]; then
        bytes=$field4; payload=$field5
        case "$payload" in "$HOME/.local/state/harness/transactions/"*) ;; *) die "rollback blocked: unsafe new-shell payload path" ;; esac
        [ -f "$payload" ] && [ ! -L "$payload" ] ||
            die "rollback blocked: missing new-shell payload"
        [ "$(wc -c <"$payload" | tr -d ' ')" -eq "$bytes" ] ||
            die "rollback blocked: new-shell payload size changed"
        if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
            continue
        fi
        [ -f "$destination" ] && [ ! -L "$destination" ] &&
            cmp -s "$destination" "$payload" ||
            die "rollback blocked: new shell file changed after apply: $destination"
    elif [ "$record" = shell ]; then
        original=$field3; bytes=$field4; payload=$field5
        current=$(wc -c <"$destination" | tr -d ' ')
        expected=$((original + bytes))
        if [ "$current" -eq "$original" ]; then
            continue
        fi
        if [ "$current" -ne "$expected" ] ||
            ! tail -c "$bytes" "$destination" | cmp -s - "$payload"; then
            die "rollback blocked: shell file changed after apply: $destination"
        fi
    elif [ "$record" = shell-prefix ]; then
        bytes=$field4; payload=$field5; lines=$field6
        case "$payload" in "$HOME/.local/state/harness/transactions/"*) ;; *) die "rollback blocked: unsafe shell-prefix payload path" ;; esac
        [ -f "$payload" ] && [ ! -L "$payload" ] || die "rollback blocked: missing shell-prefix payload"
        [ "$(wc -c <"$payload" | tr -d ' ')" -eq "$bytes" ] || die "rollback blocked: shell-prefix payload size changed"
        [ "$lines" -gt 0 ] 2>/dev/null || die "rollback blocked: invalid shell-prefix line count"
        [ -f "$destination" ] && [ ! -L "$destination" ] || die "rollback blocked: prefixed shell file changed type"
        if ! head -c "$bytes" "$destination" | cmp -s - "$payload" &&
            awk 'NR == 1 && $0 == "# >>> harness early managed >>>" { found=1 } END { exit found ? 0 : 1 }' "$destination"; then
            die "rollback blocked: shell prefix changed after apply: $destination"
        fi
    elif [ "$record" = patch ]; then
        offset=$field3; original_size=$field4; bytes=$field5
        original_payload=$field6; applied_payload=$field7
        case "$original_payload:$applied_payload" in
            "$HOME/.local/state/harness/transactions/"*:"$HOME/.local/state/harness/transactions/"*) ;;
            *) die "rollback blocked: unsafe patch payload path" ;;
        esac
        [ -f "$original_payload" ] && [ ! -L "$original_payload" ] &&
            [ -f "$applied_payload" ] && [ ! -L "$applied_payload" ] ||
            die "rollback blocked: missing patch payload"
        [ "$(wc -c <"$original_payload" | tr -d ' ')" -eq "$bytes" ] &&
            [ "$(wc -c <"$applied_payload" | tr -d ' ')" -eq "$bytes" ] ||
            die "rollback blocked: patch payload size changed"
        [ -f "$destination" ] && [ ! -L "$destination" ] ||
            die "rollback blocked: patched file changed type: $destination"
        current_size=$(wc -c <"$destination" | tr -d ' ')
        [ "$current_size" -eq "$original_size" ] ||
            die "rollback blocked: patched file size changed: $destination"
        if dd if="$destination" bs=1 skip="$offset" count="$bytes" 2>/dev/null |
            cmp -s - "$original_payload"; then
            continue
        fi
        dd if="$destination" bs=1 skip="$offset" count="$bytes" 2>/dev/null |
            cmp -s - "$applied_payload" ||
            die "rollback blocked: reviewed patch changed after apply: $destination"
    elif [ "$record" = python ]; then
        expected_hash=$field3
        case "$destination" in "$HOME/.local/opt/python/"*) ;; *) die "unsafe Python path" ;; esac
        if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
            continue
        fi
        [ -d "$destination" ] && [ ! -L "$destination" ] ||
            die "rollback blocked: Python tree changed type: $destination"
        tree_archive=$(mktemp "${TMPDIR:-/tmp}/harness-python-tree.XXXXXX")
        tar --sort=name --mtime=@0 --owner=0 --group=0 --numeric-owner \
            --exclude='*/__pycache__' --exclude='*.pyc' --exclude='*.pyo' \
            -cf "$tree_archive" -C "$destination" .
        observed_hash=$(sha256sum "$tree_archive" | awk '{print $1}')
        rm "$tree_archive"
        [ "$observed_hash" = "$expected_hash" ] ||
            die "rollback blocked: Python tree changed: $destination expected=$expected_hash observed=$observed_hash"
    elif [ "$record" = agent-replaced ]; then
        new_tree=$destination; new_hash=$field3; stable_link=$field4
        new_command=$field5; old_tree=$field6; old_hash=$field7
        old_command=$field8
        valid_codex_tree_path "$new_tree" && valid_codex_tree_path "$old_tree" ||
            die "rollback blocked: unsafe replaced agent tree path"
        [ "$new_tree" != "$old_tree" ] ||
            die "rollback blocked: ambiguous replaced agent trees"
        [ "$stable_link" = "$HOME/.local/bin/codex" ] &&
            [ "$new_command" = "$new_tree/node_modules/@openai/codex/bin/codex.js" ] &&
            [ "$old_command" = "$old_tree/node_modules/@openai/codex/bin/codex.js" ] ||
            die "rollback blocked: unsafe replaced agent link declaration"
        for expected_hash in "$new_hash" "$old_hash"; do
            case "$expected_hash" in *[!0-9a-f]*|'')
                die "rollback blocked: invalid replaced agent digest" ;; esac
            [ "${#expected_hash}" -eq 64 ] ||
                die "rollback blocked: invalid replaced agent digest length"
        done
        [ -d "$old_tree" ] && [ ! -L "$old_tree" ] &&
            [ -x "$old_command" ] ||
            die "rollback blocked: predecessor agent tree is unavailable"
        [ "$(agent_tree_hash "$old_tree")" = "$old_hash" ] ||
            die "rollback blocked: predecessor agent tree changed"
        new_parent=${new_tree%/*}
        if [ -e "$new_tree" ] || [ -L "$new_tree" ]; then
            [ -d "$new_tree" ] && [ ! -L "$new_tree" ] &&
                [ -x "$new_command" ] ||
                die "rollback blocked: replacement agent tree changed type"
            [ "$(agent_tree_hash "$new_tree")" = "$new_hash" ] ||
                die "rollback blocked: replacement agent tree changed"
            [ -d "$new_parent" ] && [ ! -L "$new_parent" ] &&
                [ "$(find "$new_parent" -mindepth 1 -maxdepth 1 | wc -l | tr -d ' ')" -eq 1 ] ||
                die "rollback blocked: replacement version directory changed"
        elif [ -e "$new_parent" ] || [ -L "$new_parent" ]; then
            die "rollback blocked: replacement version directory remains"
        fi
        [ -L "$stable_link" ] ||
            die "rollback blocked: replaced agent link changed type"
        rollback_link_target=$(readlink "$stable_link")
        [ "$rollback_link_target" = "$new_command" ] ||
            [ "$rollback_link_target" = "$old_command" ] ||
            die "rollback blocked: replaced agent link changed"
        rollback_candidate=${stable_link%/*}/.${stable_link##*/}.rollback-$transaction_id
        if [ -e "$rollback_candidate" ] || [ -L "$rollback_candidate" ]; then
            [ -L "$rollback_candidate" ] &&
                [ "$(readlink "$rollback_candidate")" = "$old_command" ] ||
                die "rollback blocked: replaced agent rollback candidate changed"
        fi
    elif [ "$record" = agent ]; then
        expected_hash=$field3
        case "$destination" in "$HOME/.local/opt/agents/"*) ;; *) die "unsafe agent path" ;; esac
        if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
            continue
        fi
        [ -d "$destination" ] && [ ! -L "$destination" ] ||
            die "rollback blocked: agent tree changed type: $destination"
        observed_hash=$(agent_tree_hash "$destination")
        [ "$observed_hash" = "$expected_hash" ] ||
            die "rollback blocked: agent tree changed: $destination"
    elif [ "$record" = runtime ]; then
        expected_hash=$field3
        case "$destination" in "$HOME/.local/opt/node/"*) ;; *) die "unsafe runtime path" ;; esac
        if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
            continue
        fi
        [ -d "$destination" ] && [ ! -L "$destination" ] ||
            die "rollback blocked: runtime changed type: $destination"
        tree_archive=$(mktemp "${TMPDIR:-/tmp}/harness-runtime-tree.XXXXXX")
        tar -cf "$tree_archive" -C "$destination" .
        observed_hash=$(sha256sum "$tree_archive" | awk '{print $1}')
        rm "$tree_archive"
        [ "$observed_hash" = "$expected_hash" ] ||
            die "rollback blocked: runtime tree changed: $destination"
    elif [ "$record" = artifact ]; then
        relative=$field3; expected_hash=$field4
        case "$relative" in ''|*/*|.|..) die "unsafe artifact relative path" ;; esac
        case "$destination" in "$HOME/.local/opt/"*) ;; *) die "unsafe artifact path" ;; esac
        if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
            continue
        fi
        [ -d "$destination" ] && [ ! -L "$destination" ] ||
            die "rollback blocked: artifact changed type: $destination"
        candidate=$destination/$relative
        [ -f "$candidate" ] && [ ! -L "$candidate" ] ||
            die "rollback blocked: artifact binary changed type: $candidate"
        [ "$(find "$destination" -mindepth 1 -maxdepth 1 | wc -l | tr -d ' ')" -eq 1 ] ||
            die "rollback blocked: artifact directory changed: $destination"
        [ "$(sha256sum "$candidate" | awk '{print $1}')" = "$expected_hash" ] ||
            die "rollback blocked: artifact binary changed: $candidate"
    elif [ -L "$destination" ]; then
        [ "$(readlink "$destination")" = "$field3" ] ||
            die "rollback blocked: link changed after apply: $destination"
    elif [ -e "$destination" ]; then
        die "rollback blocked: managed path changed type: $destination"
    fi
done <"$records"

while IFS='|' read -r record destination field3 field4 field5 field6 field7 field8; do
        case "$destination" in "$HOME"/*) ;; *) die "unsafe transaction path" ;; esac
        if [ "$record" = managed-link-new ]; then
            if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
                echo "KEEP link=$destination state=already-rolled-back"
            else
                echo "REMOVE link=$destination"
                rm "$destination"
            fi
        elif [ "$record" = managed-link-replaced ]; then
            source=$field3; backup=$field4; original_hash=$field5; original_mode=$field6
            if [ -f "$destination" ] && [ ! -L "$destination" ] &&
                [ "$(sha256sum "$destination" | awk '{print $1}')" = "$original_hash" ]; then
                echo "KEEP file=$destination state=already-rolled-back"
            else
                echo "RESTORE file=$destination source=transaction-backup"
                rm "$destination"
                cp "$backup" "$destination"
                chmod "$original_mode" "$destination"
            fi
        elif [ "$record" = shell-new ]; then
            if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
                echo "KEEP file=$destination state=already-rolled-back"
            else
                echo "REMOVE file=$destination"
                rm "$destination"
            fi
        elif [ "$record" = shell ]; then
            original=$field3; bytes=$field4; payload=$field5
            current=$(wc -c <"$destination" | tr -d ' ')
            if [ "$current" -eq "$original" ]; then
                echo "KEEP file=$destination state=already-rolled-back"
            else
                echo "TRUNCATE file=$destination bytes=$original"
                truncate -s "$original" "$destination"
            fi
        elif [ "$record" = shell-prefix ]; then
            bytes=$field4; payload=$field5; lines=$field6
            if head -c "$bytes" "$destination" | cmp -s - "$payload"; then
                before=$(wc -c <"$destination" | tr -d ' ')
                echo "REMOVE-PREFIX file=$destination bytes=$bytes"
                ex -n -u NONE -U NONE -i NONE -N -es "$destination" <<EOF
set nobackup nowritebackup noswapfile
1,${lines}delete
write
quit
EOF
                after=$(wc -c <"$destination" | tr -d ' ')
                [ "$after" -eq $((before - bytes)) ] || die "shell-prefix rollback size verification failed"
            else
                echo "KEEP file=$destination prefix=already-rolled-back"
            fi
        elif [ "$record" = patch ]; then
            offset=$field3; bytes=$field5
            original_payload=$field6; applied_payload=$field7
            if dd if="$destination" bs=1 skip="$offset" count="$bytes" 2>/dev/null |
                cmp -s - "$original_payload"; then
                echo "KEEP file=$destination patch=already-rolled-back"
            else
                echo "RESTORE file=$destination patch=reviewed-exact-bytes"
                dd if="$original_payload" of="$destination" bs=1 seek="$offset" \
                    conv=notrunc 2>/dev/null
            fi
        elif [ "$record" = python ]; then
            if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
                echo "KEEP python=$destination state=already-absent"
            else
                echo "REMOVE python=$destination"
                guarded_delete_tree "${destination%/*}" "$destination" \
                    "$HOME/.local/state/harness/transactions" ||
                    die "guarded Python rollback cleanup failed"
            fi
        elif [ "$record" = agent-replaced ]; then
            new_tree=$destination; stable_link=$field4
            new_command=$field5; old_tree=$field6; old_command=$field8
            rollback_candidate=${stable_link%/*}/.${stable_link##*/}.rollback-$transaction_id
            if [ "$(readlink "$stable_link")" = "$new_command" ]; then
                echo "RESTORE agent-link=$stable_link source=$old_command"
                if [ ! -L "$rollback_candidate" ]; then
                    ln -s "$old_command" "$rollback_candidate"
                fi
                mv -T "$rollback_candidate" "$stable_link"
                [ -L "$stable_link" ] &&
                    [ "$(readlink "$stable_link")" = "$old_command" ] ||
                    die "replaced agent link rollback verification failed"
            else
                echo "KEEP agent-link=$stable_link state=already-rolled-back"
                [ ! -L "$rollback_candidate" ] || unlink "$rollback_candidate"
            fi
            if [ -d "$new_tree" ]; then
                echo "REMOVE agent=$new_tree predecessor=$old_tree"
                guarded_delete_tree "${new_tree%/*}" "$new_tree" \
                    "$HOME/.local/state/harness/transactions" ||
                    die "guarded replaced-agent rollback cleanup failed"
                rmdir "${new_tree%/*}" ||
                    die "replaced-agent version directory cleanup failed"
            else
                echo "KEEP agent=$new_tree state=already-absent"
            fi
        elif [ "$record" = agent ]; then
            if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
                echo "KEEP agent=$destination state=already-absent"
            else
                echo "REMOVE agent=$destination"
                guarded_delete_tree "${destination%/*}" "$destination" \
                    "$HOME/.local/state/harness/transactions" ||
                    die "guarded agent rollback cleanup failed"
            fi
        elif [ "$record" = runtime ]; then
            if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
                echo "KEEP runtime=$destination state=already-absent"
            else
                echo "REMOVE runtime=$destination"
                guarded_delete_tree "${destination%/*}" "$destination" \
                    "$HOME/.local/state/harness/transactions" ||
                    die "guarded runtime rollback cleanup failed"
            fi
        elif [ "$record" = artifact ]; then
            relative=$field3
            if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
                echo "KEEP artifact=$destination state=already-absent"
            else
                echo "REMOVE artifact=$destination"
                rm "$destination/$relative"
                rmdir "$destination"
            fi
        elif [ -L "$destination" ] && [ "$(readlink "$destination")" = "$field3" ]; then
            echo "REMOVE link=$destination"
            rm "$destination"
        elif [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
            echo "KEEP link=$destination state=already-absent"
        else
            echo "BLOCK link=$destination reason=changed-after-apply" >&2
            exit 1
        fi
done <"$records"
echo rolled-back >"$manifest.status"
chmod 600 "$manifest.status"
echo "TRANSACTION id=$transaction_id status=rolled-back"
