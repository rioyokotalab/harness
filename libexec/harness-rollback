#!/bin/sh
set -eu

SELF_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
HARNESS_ROOT=${HARNESS_ROOT:-$(CDPATH= cd -- "$SELF_DIR/.." && pwd)}
export HARNESS_ROOT
. "$SELF_DIR/harness-common"

usage() {
    echo "Usage: harness rollback TRANSACTION_ID" >&2
}

[ "$#" -eq 1 ] || { usage; exit 2; }
transaction_id=$1
require_safe_id "$transaction_id"
manifest=$HOME/.local/state/harness/transactions/$transaction_id.manifest
[ -f "$manifest" ] || die "unknown transaction: $transaction_id"

records=$(mktemp "${TMPDIR:-/tmp}/harness-rollback.XXXXXX")
trap 'rm -f "$records"' EXIT HUP INT TERM
awk -F'|' '$1 == "link" || $1 == "shell" || $1 == "patch" || $1 == "artifact" || $1 == "runtime" || $1 == "python" { line[NR] = $0 } END { for (i = NR; i >= 1; i--) if (line[i] != "") print line[i] }' \
    "$manifest" >"$records"

# Validate every path before mutating any path.
while IFS='|' read -r record destination field3 field4 field5 field6 field7; do
    case "$destination" in "$HOME"/*) ;; *) die "unsafe transaction path" ;; esac
    if [ "$record" = shell ]; then
        original=$field3; bytes=$field4; payload=$field5
        current=$(wc -c <"$destination" | tr -d ' ')
        expected=$((original + bytes))
        if [ "$current" -eq "$original" ]; then
            continue
        fi
        [ "$current" -eq "$expected" ] && tail -c "$bytes" "$destination" | cmp -s - "$payload" ||
            die "rollback blocked: shell file changed after apply: $destination"
    elif [ "$record" = patch ]; then
        offset=$field3; original_size=$field4; bytes=$field5
        original_payload=$field6; applied_payload=$field7
        case "$original_payload:$applied_payload" in
            "$HOME/.local/state/harness/transactions/"*:"$HOME/.local/state/harness/transactions/"*) ;;
            *) die "rollback blocked: unsafe patch payload path" ;;
        esac
        [ -f "$original_payload" ] && [ ! -L "$original_payload" ] &&
            [ -f "$applied_payload" ] && [ ! -L "$applied_payload" ] ||
            die "rollback blocked: missing patch payload"
        [ "$(wc -c <"$original_payload" | tr -d ' ')" -eq "$bytes" ] &&
            [ "$(wc -c <"$applied_payload" | tr -d ' ')" -eq "$bytes" ] ||
            die "rollback blocked: patch payload size changed"
        [ -f "$destination" ] && [ ! -L "$destination" ] ||
            die "rollback blocked: patched file changed type: $destination"
        current_size=$(wc -c <"$destination" | tr -d ' ')
        [ "$current_size" -eq "$original_size" ] ||
            die "rollback blocked: patched file size changed: $destination"
        if dd if="$destination" bs=1 skip="$offset" count="$bytes" 2>/dev/null |
            cmp -s - "$original_payload"; then
            continue
        fi
        dd if="$destination" bs=1 skip="$offset" count="$bytes" 2>/dev/null |
            cmp -s - "$applied_payload" ||
            die "rollback blocked: reviewed patch changed after apply: $destination"
    elif [ "$record" = python ]; then
        expected_hash=$field3
        case "$destination" in "$HOME/.local/opt/python/"*) ;; *) die "unsafe Python path" ;; esac
        if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
            continue
        fi
        [ -d "$destination" ] && [ ! -L "$destination" ] ||
            die "rollback blocked: Python tree changed type: $destination"
        tree_archive=$(mktemp "${TMPDIR:-/tmp}/harness-python-tree.XXXXXX")
        tar --sort=name --mtime=@0 --owner=0 --group=0 --numeric-owner \
            --exclude='*/__pycache__' --exclude='*.pyc' --exclude='*.pyo' \
            -cf "$tree_archive" -C "$destination" .
        observed_hash=$(sha256sum "$tree_archive" | awk '{print $1}')
        rm "$tree_archive"
        [ "$observed_hash" = "$expected_hash" ] ||
            die "rollback blocked: Python tree changed: $destination expected=$expected_hash observed=$observed_hash"
    elif [ "$record" = runtime ]; then
        expected_hash=$field3
        case "$destination" in "$HOME/.local/opt/node/"*) ;; *) die "unsafe runtime path" ;; esac
        if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
            continue
        fi
        [ -d "$destination" ] && [ ! -L "$destination" ] ||
            die "rollback blocked: runtime changed type: $destination"
        tree_archive=$(mktemp "${TMPDIR:-/tmp}/harness-runtime-tree.XXXXXX")
        tar -cf "$tree_archive" -C "$destination" .
        observed_hash=$(sha256sum "$tree_archive" | awk '{print $1}')
        rm "$tree_archive"
        [ "$observed_hash" = "$expected_hash" ] ||
            die "rollback blocked: runtime tree changed: $destination"
    elif [ "$record" = artifact ]; then
        relative=$field3; expected_hash=$field4
        case "$relative" in ''|*/*|.|..) die "unsafe artifact relative path" ;; esac
        case "$destination" in "$HOME/.local/opt/"*) ;; *) die "unsafe artifact path" ;; esac
        if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
            continue
        fi
        [ -d "$destination" ] && [ ! -L "$destination" ] ||
            die "rollback blocked: artifact changed type: $destination"
        candidate=$destination/$relative
        [ -f "$candidate" ] && [ ! -L "$candidate" ] ||
            die "rollback blocked: artifact binary changed type: $candidate"
        [ "$(find "$destination" -mindepth 1 -maxdepth 1 | wc -l | tr -d ' ')" -eq 1 ] ||
            die "rollback blocked: artifact directory changed: $destination"
        [ "$(sha256sum "$candidate" | awk '{print $1}')" = "$expected_hash" ] ||
            die "rollback blocked: artifact binary changed: $candidate"
    elif [ -L "$destination" ]; then
        [ "$(readlink "$destination")" = "$field3" ] ||
            die "rollback blocked: link changed after apply: $destination"
    elif [ -e "$destination" ]; then
        die "rollback blocked: managed path changed type: $destination"
    fi
done <"$records"

while IFS='|' read -r record destination field3 field4 field5 field6 field7; do
        case "$destination" in "$HOME"/*) ;; *) die "unsafe transaction path" ;; esac
        if [ "$record" = shell ]; then
            original=$field3; bytes=$field4; payload=$field5
            current=$(wc -c <"$destination" | tr -d ' ')
            if [ "$current" -eq "$original" ]; then
                echo "KEEP file=$destination state=already-rolled-back"
            else
                echo "TRUNCATE file=$destination bytes=$original"
                truncate -s "$original" "$destination"
            fi
        elif [ "$record" = patch ]; then
            offset=$field3; bytes=$field5
            original_payload=$field6; applied_payload=$field7
            if dd if="$destination" bs=1 skip="$offset" count="$bytes" 2>/dev/null |
                cmp -s - "$original_payload"; then
                echo "KEEP file=$destination patch=already-rolled-back"
            else
                echo "RESTORE file=$destination patch=reviewed-exact-bytes"
                dd if="$original_payload" of="$destination" bs=1 seek="$offset" \
                    conv=notrunc 2>/dev/null
            fi
        elif [ "$record" = python ]; then
            if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
                echo "KEEP python=$destination state=already-absent"
            else
                echo "REMOVE python=$destination"
                rm -rf "$destination"
            fi
        elif [ "$record" = runtime ]; then
            if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
                echo "KEEP runtime=$destination state=already-absent"
            else
                echo "REMOVE runtime=$destination"
                rm -rf "$destination"
            fi
        elif [ "$record" = artifact ]; then
            relative=$field3
            if [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
                echo "KEEP artifact=$destination state=already-absent"
            else
                echo "REMOVE artifact=$destination"
                rm "$destination/$relative"
                rmdir "$destination"
            fi
        elif [ -L "$destination" ] && [ "$(readlink "$destination")" = "$field3" ]; then
            echo "REMOVE link=$destination"
            rm "$destination"
        elif [ ! -e "$destination" ] && [ ! -L "$destination" ]; then
            echo "KEEP link=$destination state=already-absent"
        else
            echo "BLOCK link=$destination reason=changed-after-apply" >&2
            exit 1
        fi
done <"$records"
echo rolled-back >"$manifest.status"
chmod 600 "$manifest.status"
echo "TRANSACTION id=$transaction_id status=rolled-back"
