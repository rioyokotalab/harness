#!/bin/sh
set -eu

SELF_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
HARNESS_ROOT=${HARNESS_ROOT:-$(CDPATH='' cd -- "$SELF_DIR/.." && pwd)}
export HARNESS_ROOT
. "$SELF_DIR/harness-common"

usage() {
    echo "Usage: harness macos-profile --host LOGICAL_ID" >&2
}

private_id_is_safe() {
    case "$1" in
        ''|*[!A-Za-z0-9._-]*) return 1 ;;
        .|..|.*|*-private|*secret*|*credential*) return 1 ;;
        *) return 0 ;;
    esac
}

stat_owner() {
    case $(uname -s) in
        Darwin) stat -f '%u' -- "$1" ;;
        *) stat -c '%u' -- "$1" ;;
    esac
}

stat_mode() {
    case $(uname -s) in
        Darwin) stat -f '%Lp' -- "$1" ;;
        *) stat -c '%a' -- "$1" ;;
    esac
}

require_private_directory() {
    private_directory=$1
    [ -d "$private_directory" ] && [ ! -L "$private_directory" ] ||
        die "private companion directory has unsafe type"
    [ "$(stat_owner "$private_directory")" = "$current_uid" ] ||
        die "private companion directory has unsafe owner"
    [ "$(stat_mode "$private_directory")" = 700 ] ||
        die "private companion directory has unsafe mode"
}

require_private_file() {
    private_file=$1
    [ -f "$private_file" ] && [ ! -L "$private_file" ] ||
        die "private companion manifest has unsafe type"
    [ "$(stat_owner "$private_file")" = "$current_uid" ] ||
        die "private companion manifest has unsafe owner"
    [ "$(stat_mode "$private_file")" = 600 ] ||
        die "private companion manifest has unsafe mode"
}

validate_manifest() {
    manifest=$1
    allowed_keys=$2
    required_keys=$3
    awk -F= -v allowed="$allowed_keys" -v required="$required_keys" '
        BEGIN {
            split(allowed, values, ",")
            for (i in values) allowed_key[values[i]] = 1
            split(required, values, ",")
            for (i in values) required_key[values[i]] = 1
        }
        $0 == "" { next }
        {
            if ($0 !~ /^[A-Za-z][A-Za-z0-9_]*=[^=[:cntrl:]]*$/) bad = 1
            key = $1
            if (!(key in allowed_key)) bad = 1
            if (++seen[key] != 1) bad = 1
        }
        END {
            for (key in required_key)
                if (!(key in seen) || seen[key] != 1) bad = 1
            exit bad ? 1 : 0
        }
    ' "$manifest" >/dev/null 2>&1 || die "private companion manifest is malformed"
}

manifest_get() {
    manifest=$1
    manifest_key=$2
    awk -F= -v key="$manifest_key" '$1 == key { print substr($0, length(key) + 2) }' \
        "$manifest"
}

validate_token_csv() {
    token_csv=$1
    token_kind=$2
    [ "$token_csv" = none ] && return 0
    printf '%s\n' "$token_csv" | awk -F, -v kind="$token_kind" '
        NF == 0 { exit 1 }
        {
            for (i = 1; i <= NF; i++) {
                token = $i
                if (token == "" || seen[token]++) exit 1
                if (kind == "group") {
                    if (token !~ /^[A-Za-z][A-Za-z0-9._-]*$/) exit 1
                } else {
                    if (token !~ /^[A-Za-z0-9][A-Za-z0-9@+._\/-]*$/ ||
                        token ~ /\.\./ || token ~ /\/\// || token ~ /\/$/)
                        exit 1
                }
            }
        }
    ' >/dev/null 2>&1 || die "private companion token list is malformed"
}

token_count() {
    [ "$1" = none ] && { printf '%s\n' 0; return; }
    printf '%s\n' "$1" | awk -F, '{ print NF }'
}

logical_host=
while [ "$#" -gt 0 ]; do
    case "$1" in
        --host)
            [ "$#" -ge 2 ] || { usage; exit 2; }
            logical_host=$2
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage
            exit 2
            ;;
    esac
done
[ -n "$logical_host" ] || { usage; exit 2; }
private_id_is_safe "$logical_host" || die "invalid private logical identifier"

case ${HOME:-} in
    /*) ;;
    *) die "private companion requires an absolute HOME" ;;
esac

public_profile=$HARNESS_ROOT/profiles/personal-macos/base.conf
[ -f "$public_profile" ] && [ ! -L "$public_profile" ] ||
    die "public personal-Mac baseline is unavailable"
validate_manifest "$public_profile" \
    schema,family,private_schema_min,private_schema_max,baseline,managed_formulae \
    schema,family,private_schema_min,private_schema_max,baseline,managed_formulae

public_schema=$(manifest_get "$public_profile" schema)
family=$(manifest_get "$public_profile" family)
private_schema_min=$(manifest_get "$public_profile" private_schema_min)
private_schema_max=$(manifest_get "$public_profile" private_schema_max)
public_baseline=$(manifest_get "$public_profile" baseline)
managed_formulae=$(manifest_get "$public_profile" managed_formulae)
[ "$public_schema" = 1 ] && [ "$family" = personal-macos ] &&
    [ "$private_schema_min" = 1 ] && [ "$private_schema_max" = 1 ] &&
    [ "$public_baseline" = macos-cli-v1 ] ||
    die "public personal-Mac baseline is incompatible"
validate_token_csv "$managed_formulae" formula
[ "$managed_formulae" = bash,git,git-lfs,tmux,ripgrep,jq,tree,shellcheck ] ||
    die "public personal-Mac formula baseline is incompatible"

private_root=$HOME/.config/harness/private
private_git=$private_root/.git
private_hosts=$private_root/hosts
companion_manifest=$private_root/companion.conf
host_manifest=$private_hosts/$logical_host.conf
current_uid=$(id -u)

require_private_directory "$private_root"
require_private_directory "$private_git"
require_private_directory "$private_hosts"
require_private_file "$companion_manifest"
require_private_file "$host_manifest"

validate_manifest "$companion_manifest" schema,minimum_engine_schema \
    schema,minimum_engine_schema
validate_manifest "$host_manifest" \
    schema,logical_id,baseline,capability_groups,extra_formulae \
    schema,logical_id,baseline,capability_groups,extra_formulae

private_schema=$(manifest_get "$companion_manifest" schema)
minimum_engine_schema=$(manifest_get "$companion_manifest" minimum_engine_schema)
host_schema=$(manifest_get "$host_manifest" schema)
host_id=$(manifest_get "$host_manifest" logical_id)
host_baseline=$(manifest_get "$host_manifest" baseline)
capability_groups=$(manifest_get "$host_manifest" capability_groups)
extra_formulae=$(manifest_get "$host_manifest" extra_formulae)

[ "$private_schema" = 1 ] && [ "$host_schema" = "$private_schema" ] &&
    [ "$minimum_engine_schema" = 1 ] &&
    [ "$private_schema" -ge "$private_schema_min" ] &&
    [ "$private_schema" -le "$private_schema_max" ] ||
    die "private companion schema is incompatible"
[ "$host_id" = "$logical_host" ] || die "private logical identifier mismatch"
[ "$host_baseline" = "$public_baseline" ] ||
    die "private baseline selection is incompatible"
validate_token_csv "$capability_groups" group
validate_token_csv "$extra_formulae" formula

printf '%s\n' \
    "MACOS_PRIVATE_PROFILE status=valid schema=$private_schema engine_schema=$public_schema" \
    "SELECTION baseline=$public_baseline capability_groups=$(token_count "$capability_groups") extra_formulae=$(token_count "$extra_formulae")" \
    "PUBLIC_FORMULAE count=$(token_count "$managed_formulae")" \
    'END private_profile values=not-emitted'
