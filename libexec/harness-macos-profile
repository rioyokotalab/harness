#!/bin/sh
set -eu

SELF_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
HARNESS_ROOT=${HARNESS_ROOT:-$(CDPATH='' cd -- "$SELF_DIR/.." && pwd)}
export HARNESS_ROOT
. "$SELF_DIR/harness-common"
. "$SELF_DIR/harness-macos-common"

usage() {
    echo "Usage: harness macos-profile --host LOGICAL_ID" >&2
}

logical_host=
while [ "$#" -gt 0 ]; do
    case "$1" in
        --host)
            [ "$#" -ge 2 ] || { usage; exit 2; }
            logical_host=$2
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage
            exit 2
            ;;
    esac
done
[ -n "$logical_host" ] || { usage; exit 2; }
macos_private_id_is_safe "$logical_host" || die "invalid private logical identifier"

case ${HOME:-} in
    /*) ;;
    *) die "private companion requires an absolute HOME" ;;
esac

public_profile=$HARNESS_ROOT/profiles/personal-macos/base.conf
[ -f "$public_profile" ] && [ ! -L "$public_profile" ] ||
    die "public personal-Mac baseline is unavailable"
macos_validate_public_profile "$public_profile"
formula_policy=$HARNESS_ROOT/profiles/personal-macos/formula-policy-v2.conf
[ -f "$formula_policy" ] && [ ! -L "$formula_policy" ] ||
    die "public personal-Mac formula policy is unavailable"
macos_validate_formula_policy "$formula_policy"

engine_schema=3
family=$(macos_manifest_get "$public_profile" family)
private_schema_min=$(macos_manifest_get "$public_profile" private_schema_min)
private_schema_max=$(macos_manifest_get "$public_profile" private_schema_max)
public_baseline=$(macos_manifest_get "$public_profile" baseline)
managed_formulae=$(macos_manifest_get "$formula_policy" managed_formulae)
retired_formulae=$(macos_manifest_get "$formula_policy" retired_formulae)
[ "$family" = personal-macos ] || die "public personal-Mac baseline is incompatible"

private_root=$HOME/.config/harness/private
private_git=$private_root/.git
private_hosts=$private_root/hosts
private_ssh=$private_root/ssh
companion_manifest=$private_root/companion.conf
host_manifest=$private_hosts/$logical_host.conf
legacy_ssh_payload=$private_root/ssh_config
current_uid=$(id -u)
case ${HARNESS_ALLOW_LEGACY_SSH_LAYOUT:-0} in
    0) ssh_layout_validation=strict ;;
    1) ssh_layout_validation=legacy-terminal-include ;;
    *) die "private profile SSH layout compatibility mode is invalid" ;;
esac

macos_require_private_directory "$private_root" "$current_uid"
macos_require_private_directory "$private_git" "$current_uid"
macos_require_private_directory "$private_hosts" "$current_uid"
macos_require_private_file "$companion_manifest" "$current_uid"
macos_require_private_file "$host_manifest" "$current_uid"

macos_validate_companion_manifest "$companion_manifest" "$engine_schema" \
    "$private_schema_min" "$private_schema_max"

private_schema=$(macos_manifest_get "$companion_manifest" schema)
minimum_engine_schema=$(macos_manifest_get "$companion_manifest" minimum_engine_schema)

[ "$minimum_engine_schema" -le "$engine_schema" ] ||
    die "private companion schema is incompatible"

git -C "$private_root" rev-parse --is-inside-work-tree >/dev/null 2>&1 ||
    die "private companion is not a Git checkout"
[ "$(git -C "$private_root" rev-parse --show-toplevel 2>/dev/null)" = \
    "$(CDPATH='' cd -- "$private_root" && pwd -P)" ] ||
    die "private companion Git root is ambiguous"

ssh_payload_state=absent
legacy_ssh_state=absent
per_host_ssh_state=absent
per_host_ssh_any=absent
bash_payload_state=absent
tmux_payload_state=absent
git -C "$private_root" ls-files | while IFS= read -r tracked_path; do
    case "$tracked_path" in
        companion.conf) ;;
        ssh_config)
            macos_validate_ssh_config "$legacy_ssh_payload" "$current_uid" 600 \
                "$ssh_layout_validation"
            ;;
        ssh/*.conf)
            [ "$minimum_engine_schema" -ne 2 ] ||
                die "private companion tracked layout is invalid"
            tracked_name=${tracked_path#ssh/}
            tracked_id=${tracked_name%.conf}
            if [ "$tracked_name" != "$tracked_id.conf" ] ||
                ! macos_private_id_is_safe "$tracked_id" ||
                ! git -C "$private_root" ls-files --error-unmatch \
                    "hosts/$tracked_id.conf" >/dev/null 2>&1; then
                die "private companion tracked layout is invalid"
            fi
            macos_require_private_directory "$private_ssh" "$current_uid"
            macos_validate_ssh_config "$private_root/$tracked_path" \
                "$current_uid" 600 "$ssh_layout_validation"
            ;;
        bashrc)
            [ "$minimum_engine_schema" -ge 2 ] ||
                die "private companion tracked layout is invalid"
            macos_validate_bash_config "$private_root/bashrc" "$current_uid" 600
            ;;
        tmux.conf)
            [ "$minimum_engine_schema" -ge 2 ] ||
                die "private companion tracked layout is invalid"
            macos_validate_tmux_config "$private_root/tmux.conf" "$current_uid" 600
            ;;
        hosts/*.conf)
            tracked_name=${tracked_path#hosts/}
            tracked_id=${tracked_name%.conf}
            if [ "$tracked_name" != "$tracked_id.conf" ] ||
                ! macos_private_id_is_safe "$tracked_id"; then
                die "private companion tracked layout is invalid"
            fi
            tracked_file=$private_root/$tracked_path
            macos_require_private_file "$tracked_file" "$current_uid"
            macos_validate_host_manifest "$tracked_file" "$tracked_id" \
                "$private_schema" "$public_baseline"
            ;;
        *) die "private companion tracked layout is invalid" ;;
    esac
done
if git -C "$private_root" ls-files --error-unmatch ssh_config \
    >/dev/null 2>&1; then
    legacy_ssh_state=present
fi
if git -C "$private_root" ls-files --error-unmatch \
    "ssh/$logical_host.conf" >/dev/null 2>&1; then
    per_host_ssh_state=present
fi
if [ -n "$(git -C "$private_root" ls-files 'ssh/*.conf')" ]; then
    per_host_ssh_any=present
fi
if [ "$per_host_ssh_state" = present ] || [ "$legacy_ssh_state" = present ]; then
    ssh_payload_state=present
fi
if git -C "$private_root" ls-files --error-unmatch bashrc \
    >/dev/null 2>&1; then
    bash_payload_state=present
fi
if git -C "$private_root" ls-files --error-unmatch tmux.conf \
    >/dev/null 2>&1; then
    tmux_payload_state=present
fi
case "$minimum_engine_schema:$legacy_ssh_state:$bash_payload_state:$tmux_payload_state" in
    1:absent:absent:absent|1:present:absent:absent) ;;
    2:absent:absent:absent|2:present:present:present) ;;
    3:absent:absent:absent) ;;
    *) die "private companion payload set is incomplete or incompatible" ;;
esac
if [ "$minimum_engine_schema" -eq 1 ] &&
    [ "$per_host_ssh_any" = present ] && [ "$legacy_ssh_state" != present ]; then
    die "private companion payload set is incomplete or incompatible"
fi
if [ "$minimum_engine_schema" -eq 3 ]; then
    tracked_host_ids=$(git -C "$private_root" ls-files 'hosts/*.conf' |
        sed -n 's#^hosts/\(.*\)\.conf$#\1#p' | LC_ALL=C sort)
    tracked_ssh_ids=$(git -C "$private_root" ls-files 'ssh/*.conf' |
        sed -n 's#^ssh/\(.*\)\.conf$#\1#p' | LC_ALL=C sort)
    [ -n "$tracked_host_ids" ] && [ "$tracked_host_ids" = "$tracked_ssh_ids" ] ||
        die "private companion payload set is incomplete or incompatible"
fi
[ -z "$(git -C "$private_root" status --porcelain --untracked-files=normal)" ] ||
    die "private companion checkout is not clean"

macos_validate_host_manifest "$host_manifest" "$logical_host" \
    "$private_schema" "$public_baseline"
capability_groups=$(macos_manifest_get "$host_manifest" capability_groups)
extra_formulae=$(macos_manifest_get "$host_manifest" extra_formulae)
if [ "$extra_formulae" != none ]; then
    printf '%s\n' "$managed_formulae,$retired_formulae,$extra_formulae" |
        tr ',' '\n' | awk 'seen[$0]++ { exit 1 }' ||
        die "private formula selection overlaps public policy"
fi

printf '%s\n' \
    "MACOS_PRIVATE_PROFILE status=valid schema=$private_schema engine_schema=$engine_schema" \
    "SELECTION baseline=$public_baseline capability_groups=$(macos_token_count "$capability_groups") extra_formulae=$(macos_token_count "$extra_formulae")" \
    "PUBLIC_FORMULAE count=$(macos_token_count "$managed_formulae")" \
    "SSH_PAYLOAD state=$ssh_payload_state values=not-emitted" \
    "BASH_PAYLOAD state=$bash_payload_state values=not-emitted" \
    "TMUX_PAYLOAD state=$tmux_payload_state values=not-emitted" \
    'END private_profile values=not-emitted'
