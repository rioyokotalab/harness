#!/bin/sh

macos_private_id_is_safe() {
    case "$1" in
        ''|*[!A-Za-z0-9._-]*|.|..|.*) return 1 ;;
        *) return 0 ;;
    esac
}

macos_stat_owner() {
    case $(uname -s) in
        Darwin) stat -f '%u' -- "$1" ;;
        *) stat -c '%u' -- "$1" ;;
    esac
}

macos_stat_mode() {
    case $(uname -s) in
        Darwin) stat -f '%Lp' -- "$1" ;;
        *) stat -c '%a' -- "$1" ;;
    esac
}

macos_stat_links() {
    case $(uname -s) in
        Darwin) stat -f '%l' -- "$1" ;;
        *) stat -c '%h' -- "$1" ;;
    esac
}

macos_file_contains_exact_block_once() {
    macos_exact_block=$1
    macos_exact_file=$2
    awk '
        NR == FNR { block[++block_lines] = $0; next }
        { file[++file_lines] = $0 }
        END {
            for (start = 1; start <= file_lines - block_lines + 1; start++) {
                exact = 1
                for (offset = 1; offset <= block_lines; offset++)
                    if (file[start + offset - 1] != block[offset]) exact = 0
                if (exact) matches++
            }
            exit matches == 1 ? 0 : 1
        }
    ' "$macos_exact_block" "$macos_exact_file" >/dev/null 2>&1
}

macos_file_has_public_bash_layout() {
    macos_layout_file=$1
    macos_layout_host=$2
    macos_layout_suffix=$3
    [ -f "$macos_layout_file" ] && [ ! -L "$macos_layout_file" ] || return 1
    awk -v host="$macos_layout_host" '
        NR == 1 && $0 != "# >>> harness early managed >>>" { bad = 1 }
        NR == 2 && $0 != "HARNESS_LOGICAL_HOST=" host { bad = 1 }
        NR == 3 && $0 != "export HARNESS_LOGICAL_HOST" { bad = 1 }
        NR == 4 && $0 != "if [ -r \"$HOME/harness/shell/early-cache.sh\" ]; then" { bad = 1 }
        NR == 5 && $0 != "    . \"$HOME/harness/shell/early-cache.sh\"" { bad = 1 }
        NR == 6 && $0 != "fi" { bad = 1 }
        NR == 7 && $0 != "# <<< harness early managed <<<" { bad = 1 }
        END { exit NR >= 7 && !bad ? 0 : 1 }
    ' "$macos_layout_file" >/dev/null 2>&1 || return 1
    macos_layout_suffix_bytes=$(wc -c <"$macos_layout_suffix" | tr -d ' ')
    [ "$(wc -c <"$macos_layout_file" | tr -d ' ')" -ge "$macos_layout_suffix_bytes" ] &&
        tail -c "$macos_layout_suffix_bytes" "$macos_layout_file" |
            cmp -s - "$macos_layout_suffix"
}

macos_require_private_directory() {
    macos_private_directory=$1
    macos_expected_uid=$2
    [ -d "$macos_private_directory" ] && [ ! -L "$macos_private_directory" ] ||
        die "private companion directory has unsafe type"
    [ "$(macos_stat_owner "$macos_private_directory")" = "$macos_expected_uid" ] ||
        die "private companion directory has unsafe owner"
    [ "$(macos_stat_mode "$macos_private_directory")" = 700 ] ||
        die "private companion directory has unsafe mode"
}

macos_require_private_file() {
    macos_private_file=$1
    macos_expected_uid=$2
    [ -f "$macos_private_file" ] && [ ! -L "$macos_private_file" ] ||
        die "private companion manifest has unsafe type"
    [ "$(macos_stat_owner "$macos_private_file")" = "$macos_expected_uid" ] ||
        die "private companion manifest has unsafe owner"
    [ "$(macos_stat_mode "$macos_private_file")" = 600 ] ||
        die "private companion manifest has unsafe mode"
}

macos_validate_manifest() {
    macos_manifest=$1
    macos_allowed_keys=$2
    macos_required_keys=$3
    awk -F= -v allowed="$macos_allowed_keys" -v required="$macos_required_keys" '
        BEGIN {
            split(allowed, values, ",")
            for (i in values) allowed_key[values[i]] = 1
            split(required, values, ",")
            for (i in values) required_key[values[i]] = 1
        }
        $0 == "" { next }
        {
            if ($0 !~ /^[A-Za-z][A-Za-z0-9_]*=[^=[:cntrl:]]*$/) bad = 1
            key = $1
            if (!(key in allowed_key)) bad = 1
            if (++seen[key] != 1) bad = 1
        }
        END {
            for (key in required_key)
                if (!(key in seen) || seen[key] != 1) bad = 1
            exit bad ? 1 : 0
        }
    ' "$macos_manifest" >/dev/null 2>&1 ||
        die "private companion manifest is malformed"
}

macos_manifest_get() {
    macos_manifest=$1
    macos_manifest_key=$2
    awk -F= -v key="$macos_manifest_key" \
        '$1 == key { print substr($0, length(key) + 2) }' "$macos_manifest"
}

macos_validate_token_csv() {
    macos_token_csv=$1
    macos_token_kind=$2
    [ "$macos_token_csv" = none ] && return 0
    printf '%s\n' "$macos_token_csv" | awk -F, -v kind="$macos_token_kind" '
        NF == 0 { exit 1 }
        {
            for (i = 1; i <= NF; i++) {
                token = $i
                if (token == "" || seen[token]++) exit 1
                if (kind == "group") {
                    if (token !~ /^[A-Za-z][A-Za-z0-9._-]*$/) exit 1
                } else {
                    if (token !~ /^[A-Za-z0-9][A-Za-z0-9@+._\/-]*$/ ||
                        token ~ /\.\./ || token ~ /\/\// || token ~ /\/$/)
                        exit 1
                }
            }
        }
    ' >/dev/null 2>&1 || die "private companion token list is malformed"
}

macos_token_count() {
    [ "$1" = none ] && { printf '%s\n' 0; return; }
    printf '%s\n' "$1" | awk -F, '{ print NF }'
}

macos_hash_is_safe() {
    case "$1" in
        *[!0-9a-f]*|'') return 1 ;;
    esac
    [ "${#1}" -eq 40 ] || [ "${#1}" -eq 64 ]
}

macos_checksum_file() {
    if command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$1" | awk '{ print $1 }'
    elif command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" | awk '{ print $1 }'
    else
        die "no SHA-256 command is available"
    fi
}

macos_validate_ssh_config() {
    macos_ssh_file=$1
    macos_ssh_uid=$2
    macos_ssh_modes=$3
    macos_ssh_layout_mode=${4:-strict}
    case "$macos_ssh_layout_mode" in
        strict|legacy-terminal-include) ;;
        *) die "SSH configuration validation mode is invalid" ;;
    esac
    [ -f "$macos_ssh_file" ] && [ ! -L "$macos_ssh_file" ] ||
        die "SSH configuration has unsafe type"
    [ "$(macos_stat_owner "$macos_ssh_file")" = "$macos_ssh_uid" ] ||
        die "SSH configuration has unsafe owner"
    [ "$(macos_stat_links "$macos_ssh_file")" = 1 ] ||
        die "SSH configuration has unsafe link count"
    macos_ssh_mode=$(macos_stat_mode "$macos_ssh_file")
    case ",$macos_ssh_modes," in
        *,"$macos_ssh_mode",*) ;;
        *) die "SSH configuration has unsafe mode" ;;
    esac
    macos_ssh_size=$(wc -c <"$macos_ssh_file" | tr -d ' ')
    case "$macos_ssh_size" in ''|*[!0-9]*) die "SSH configuration size is invalid" ;; esac
    [ "$macos_ssh_size" -gt 0 ] && [ "$macos_ssh_size" -le 1048576 ] ||
        die "SSH configuration size is invalid"
    if LC_ALL=C grep -E 'BEGIN ([A-Z0-9 ]+ )?PRIVATE KEY' \
        "$macos_ssh_file" >/dev/null 2>&1; then
        die "SSH configuration contains prohibited credential material"
    fi
    macos_ssh_all_includes=$(LC_ALL=C grep -E -i -c \
        '^[[:space:]]*Include([[:space:]]|$)' "$macos_ssh_file" || true)
    macos_ssh_managed_includes=$(LC_ALL=C grep -E -c \
        '^Include ~/\.ssh/config\.d/harness\.conf$' "$macos_ssh_file" || true)
    case "$macos_ssh_all_includes:$macos_ssh_managed_includes" in
        0:0)
            macos_ssh_has_managed_include=0
            macos_ssh_strip_lines=0
            ;;
        1:1)
            [ "$(tail -n 1 "$macos_ssh_file")" = \
                'Include ~/.ssh/config.d/harness.conf' ] ||
                die "SSH configuration contains a nonterminal managed Include"
            if [ "$(tail -n 2 "$macos_ssh_file" | head -n 1)" = 'Match all' ]; then
                macos_ssh_strip_lines=2
            elif [ "$macos_ssh_layout_mode" = legacy-terminal-include ]; then
                macos_ssh_strip_lines=1
            else
                die "SSH configuration has a managed Include without a global context reset"
            fi
            macos_ssh_has_managed_include=1
            ;;
        *) die "SSH configuration contains a prohibited or duplicate Include" ;;
    esac
    if LC_ALL=C grep -E -i \
        '^[[:space:]]*Match[[:space:]].*([[:space:]]|^)exec([[:space:]]|$)|(^|[^[:alnum:]_])(token|password)[[:space:]=:]' \
        "$macos_ssh_file" >/dev/null 2>&1; then
        die "SSH configuration contains prohibited external or credential material"
    fi
    command -v ssh >/dev/null 2>&1 || die "SSH configuration validator is unavailable"
    if [ "$macos_ssh_has_managed_include" -eq 1 ]; then
        if [ "$macos_ssh_strip_lines" -eq 2 ]; then
            sed '$d' "$macos_ssh_file" | sed '$d'
        else
            sed '$d' "$macos_ssh_file"
        fi
    else
        cat "$macos_ssh_file"
    fi | ssh -o CanonicalizeHostname=no -G -F /dev/stdin \
        harness-validation.invalid >/dev/null 2>&1 ||
        die "SSH configuration grammar is invalid"
}

macos_validate_private_config_file() {
    macos_config_label=$1
    macos_config_file=$2
    macos_config_uid=$3
    macos_config_modes=$4
    [ -f "$macos_config_file" ] && [ ! -L "$macos_config_file" ] ||
        die "$macos_config_label configuration has unsafe type"
    [ "$(macos_stat_owner "$macos_config_file")" = "$macos_config_uid" ] ||
        die "$macos_config_label configuration has unsafe owner"
    [ "$(macos_stat_links "$macos_config_file")" = 1 ] ||
        die "$macos_config_label configuration has unsafe link count"
    macos_config_mode=$(macos_stat_mode "$macos_config_file")
    case ",$macos_config_modes," in
        *,"$macos_config_mode",*) ;;
        *) die "$macos_config_label configuration has unsafe mode" ;;
    esac
    macos_config_size=$(wc -c <"$macos_config_file" | tr -d ' ')
    case "$macos_config_size" in
        ''|*[!0-9]*) die "$macos_config_label configuration size is invalid" ;;
    esac
    [ "$macos_config_size" -le 1048576 ] ||
        die "$macos_config_label configuration size is invalid"
    if LC_ALL=C grep -E 'BEGIN ([A-Z0-9 ]+ )?PRIVATE KEY' \
        "$macos_config_file" >/dev/null 2>&1; then
        die "$macos_config_label configuration contains prohibited credential material"
    fi
    if LC_ALL=C grep -E -i \
        '(^|[[:space:]])(export[[:space:]]+)?[A-Za-z_][A-Za-z0-9_]*(token|password|secret|api[_-]?key)[A-Za-z0-9_]*[[:space:]]*=' \
        "$macos_config_file" >/dev/null 2>&1; then
        die "$macos_config_label configuration contains prohibited credential material"
    fi
}

macos_validate_bash_config() {
    macos_bash_file=$1
    macos_bash_uid=$2
    macos_bash_modes=$3
    macos_validate_private_config_file Bash "$macos_bash_file" \
        "$macos_bash_uid" "$macos_bash_modes"
    command -v bash >/dev/null 2>&1 ||
        die "Bash configuration validator is unavailable"
    bash --noprofile --norc -n "$macos_bash_file" >/dev/null 2>&1 ||
        die "Bash configuration grammar is invalid"
}

macos_validate_tmux_config() {
    macos_tmux_file=$1
    macos_tmux_uid=$2
    macos_tmux_modes=$3
    macos_validate_private_config_file tmux "$macos_tmux_file" \
        "$macos_tmux_uid" "$macos_tmux_modes"
    # An empty file is the canonical explicit "use tmux defaults" payload.
    # Some tmux releases reject source-file -n when it parses no commands,
    # even though an empty ~/.tmux.conf is valid at normal server startup.
    [ -s "$macos_tmux_file" ] || return 0
    command -v tmux >/dev/null 2>&1 ||
        die "tmux configuration validator is unavailable"
    (
        umask 077
        # tmux's Unix socket path has a small platform limit.  Darwin's
        # default TMPDIR is already long enough that adding tmux's uid and
        # socket components can exceed it, so keep this isolated root short.
        macos_tmux_temp=$(mktemp -d /tmp/harness-tmux-validate.XXXXXX) ||
            exit 1
        macos_tmux_socket=harness-validate-$$
        macos_tmux_socket_directory=$macos_tmux_temp/tmux-$(id -u)
        macos_tmux_socket_path=$macos_tmux_socket_directory/$macos_tmux_socket
        macos_tmux_status=0
        TMUX_TMPDIR=$macos_tmux_temp tmux -L "$macos_tmux_socket" \
            -f /dev/null new-session -d -s harness-validate /bin/sleep 30 \
            >/dev/null 2>&1 || macos_tmux_status=$?
        if [ "$macos_tmux_status" -eq 0 ]; then
            TMUX_TMPDIR=$macos_tmux_temp tmux -L "$macos_tmux_socket" \
                source-file -n "$macos_tmux_file" >/dev/null 2>&1 ||
                macos_tmux_status=$?
        fi
        TMUX_TMPDIR=$macos_tmux_temp tmux -L "$macos_tmux_socket" \
            kill-server >/dev/null 2>&1 || true
        [ ! -S "$macos_tmux_socket_path" ] || unlink "$macos_tmux_socket_path"
        [ ! -d "$macos_tmux_socket_directory" ] ||
            rmdir "$macos_tmux_socket_directory"
        rmdir "$macos_tmux_temp"
        exit "$macos_tmux_status"
    ) || die "tmux configuration grammar is invalid"
}

macos_validate_public_profile() {
    macos_public_profile=$1
    macos_validate_manifest "$macos_public_profile" \
        schema,family,private_schema_min,private_schema_max,baseline,managed_formulae \
        schema,family,private_schema_min,private_schema_max,baseline,managed_formulae
    [ "$(macos_manifest_get "$macos_public_profile" schema)" = 1 ] &&
        [ "$(macos_manifest_get "$macos_public_profile" family)" = personal-macos ] &&
        [ "$(macos_manifest_get "$macos_public_profile" private_schema_min)" = 1 ] &&
        [ "$(macos_manifest_get "$macos_public_profile" private_schema_max)" = 1 ] &&
        [ "$(macos_manifest_get "$macos_public_profile" baseline)" = macos-cli-v1 ] &&
        [ "$(macos_manifest_get "$macos_public_profile" managed_formulae)" = \
            bash,git,git-lfs,tmux,ripgrep,jq,tree,shellcheck ] ||
        die "public personal-Mac baseline is incompatible"
    macos_validate_token_csv \
        "$(macos_manifest_get "$macos_public_profile" managed_formulae)" formula
}

macos_validate_formula_policy() {
    macos_formula_policy=$1
    macos_validate_manifest "$macos_formula_policy" \
        schema,family,managed_formulae,retired_formulae,retirement_aliases,cleanup_retirements \
        schema,family,managed_formulae,retired_formulae,retirement_aliases,cleanup_retirements
    [ "$(macos_manifest_get "$macos_formula_policy" schema)" = 3 ] &&
        [ "$(macos_manifest_get "$macos_formula_policy" family)" = personal-macos ] &&
        [ "$(macos_manifest_get "$macos_formula_policy" managed_formulae)" = \
            ada-url,bash,bash-completion@2,bash-git-prompt,brotli,c-ares,ca-certificates,fmt,gettext,gh,git,git-lfs,gmp,hdrhistogram_c,icu4c@78,jq,json-c,libevent,libffi,libidn2,libnghttp2,libnghttp3,libngtcp2,libpsl,libunistring,libuv,llhttp,lz4,merve,mpdecimal,mpfr,nbytes,ncurses,node,oniguruma,openssl@3,pcre2,readline,ripgrep,shellcheck,simdjson,simdutf,sqlite,tmux,tree,utf8proc,uv,uvwasi,wget,xz,zstd ] &&
        [ "$(macos_manifest_get "$macos_formula_policy" retired_formulae)" = \
            aom,bash-completion,cairo,expat,fontconfig,freetype,fribidi,gcc,gdk-pixbuf,gemini-cli,giflib,glib,go,graphite2,harfbuzz,highway,icu4c,icu4c@76,icu4c@77,imagemagick,imath,isl,jasper,jemalloc,jpeg-turbo,jpeg-xl,libdatrie,libde265,libdeflate,libev,libheif,liblqr,libmpc,libomp,libpng,libraw,librsvg,libthai,libtiff,libtommath,libtool,libultrahdr,libvmaf,libx11,libxau,libxcb,libxdmcp,libxext,libxrender,libzip,little-cms2,lzo,m4,nghttp2,openexr,openjpeg,openjph,openssl@1.1,pango,pixman,pyenv,python-tk@3.13,python@3.13,python@3.14,shared-mime-info,tcl-tk,webp,x265,xorgproto,zbar ] &&
        [ "$(macos_manifest_get "$macos_formula_policy" retirement_aliases)" = \
            icu4c:icu4c@78,nghttp2:libnghttp2 ] &&
        [ "$(macos_manifest_get "$macos_formula_policy" cleanup_retirements)" = \
            icu4c:icu4c@78 ] ||
        die "public personal-Mac formula policy is incompatible"
    macos_validate_token_csv \
        "$(macos_manifest_get "$macos_formula_policy" managed_formulae)" formula
    macos_validate_token_csv \
        "$(macos_manifest_get "$macos_formula_policy" retired_formulae)" formula
    macos_public_selected=$(macos_manifest_get \
        "$macos_formula_policy" managed_formulae)
    macos_public_retired=$(macos_manifest_get \
        "$macos_formula_policy" retired_formulae)
    printf '%s\n' "$macos_public_selected,$macos_public_retired" | tr ',' '\n' |
        awk 'seen[$0]++ { exit 1 }' ||
        die "public personal-Mac formula policy overlaps"
}

macos_validate_companion_manifest() {
    macos_companion_manifest=$1
    macos_engine_schema=$2
    macos_private_min=$3
    macos_private_max=$4
    macos_validate_manifest "$macos_companion_manifest" \
        schema,minimum_engine_schema schema,minimum_engine_schema
    macos_private_schema=$(macos_manifest_get "$macos_companion_manifest" schema)
    macos_minimum_engine=$(macos_manifest_get \
        "$macos_companion_manifest" minimum_engine_schema)
    case "$macos_private_schema:$macos_minimum_engine:$macos_engine_schema:$macos_private_min:$macos_private_max" in
        *[!0-9:]*) die "private companion schema is incompatible" ;;
    esac
    [ "$macos_private_schema" -ge "$macos_private_min" ] &&
        [ "$macos_private_schema" -le "$macos_private_max" ] &&
        [ "$macos_minimum_engine" -ge 1 ] &&
        [ "$macos_minimum_engine" -le "$macos_engine_schema" ] ||
        die "private companion schema is incompatible"
}

macos_validate_host_manifest() {
    macos_host_manifest=$1
    macos_expected_id=$2
    macos_expected_schema=$3
    macos_expected_baseline=$4
    macos_validate_manifest "$macos_host_manifest" \
        schema,logical_id,baseline,capability_groups,extra_formulae \
        schema,logical_id,baseline,capability_groups,extra_formulae
    [ "$(macos_manifest_get "$macos_host_manifest" schema)" = \
        "$macos_expected_schema" ] || die "private host schema is incompatible"
    [ "$(macos_manifest_get "$macos_host_manifest" logical_id)" = \
        "$macos_expected_id" ] || die "private logical identifier mismatch"
    [ "$(macos_manifest_get "$macos_host_manifest" baseline)" = \
        "$macos_expected_baseline" ] || die "private baseline selection is incompatible"
    macos_validate_token_csv \
        "$(macos_manifest_get "$macos_host_manifest" capability_groups)" group
    macos_validate_token_csv \
        "$(macos_manifest_get "$macos_host_manifest" extra_formulae)" formula
}

macos_formula_key() {
    printf '%s' "$1" | sed 's/+/p/g; s/[-@.]/_/g'
}

macos_value_is_one_of() {
    macos_candidate=$1
    shift
    for macos_allowed_value do
        [ "$macos_candidate" != "$macos_allowed_value" ] || return 0
    done
    return 1
}

macos_validate_fact_file() {
    macos_fact_file=$1
    macos_fact_policy=$2
    macos_fact_keys=schema,family,logical_id,architecture,account_shell,account_shell_registry,homebrew,homebrew_prefix_class,command_line_tools,private_profile,harness_checkout,link_codex_guidance,link_codex_rules,link_claude_guidance,link_bash_launcher
    macos_fact_formulae=$(macos_manifest_get "$macos_fact_policy" managed_formulae),$(macos_manifest_get "$macos_fact_policy" retired_formulae)
    for macos_fact_formula in $(printf '%s\n' "$macos_fact_formulae" | tr ',' ' '); do
        macos_fact_formula_key=formula_$(macos_formula_key "$macos_fact_formula")
        case ,$macos_fact_keys, in
            *,$macos_fact_formula_key,*)
                die "public personal-Mac formula policy has a fact-key collision"
                ;;
        esac
        macos_fact_keys=$macos_fact_keys,$macos_fact_formula_key
    done
    macos_validate_manifest "$macos_fact_file" "$macos_fact_keys" "$macos_fact_keys"
    [ "$(macos_manifest_get "$macos_fact_file" schema)" = 1 ] &&
        [ "$(macos_manifest_get "$macos_fact_file" family)" = personal-macos ] ||
        die "personal-Mac fact schema is incompatible"
    macos_private_id_is_safe \
        "$(macos_manifest_get "$macos_fact_file" logical_id)" ||
        die "personal-Mac fact identity is malformed"
    macos_value_is_one_of \
        "$(macos_manifest_get "$macos_fact_file" architecture)" \
        arm64 x86_64 other || die "personal-Mac architecture fact is malformed"
    macos_value_is_one_of \
        "$(macos_manifest_get "$macos_fact_file" account_shell)" \
        homebrew-bash apple-bash zsh other || die "personal-Mac shell fact is malformed"
    macos_value_is_one_of \
        "$(macos_manifest_get "$macos_fact_file" account_shell_registry)" \
        present absent duplicate unknown ||
        die "personal-Mac shell-registry fact is malformed"
    macos_value_is_one_of "$(macos_manifest_get "$macos_fact_file" homebrew)" \
        present absent unusable || die "personal-Mac Homebrew fact is malformed"
    macos_value_is_one_of \
        "$(macos_manifest_get "$macos_fact_file" homebrew_prefix_class)" \
        apple-silicon-default intel-default other none unknown ||
        die "personal-Mac Homebrew prefix fact is malformed"
    macos_value_is_one_of \
        "$(macos_manifest_get "$macos_fact_file" command_line_tools)" \
        present absent || die "personal-Mac developer-tools fact is malformed"
    macos_value_is_one_of \
        "$(macos_manifest_get "$macos_fact_file" private_profile)" \
        valid absent invalid || die "personal-Mac private-profile fact is malformed"
    macos_value_is_one_of \
        "$(macos_manifest_get "$macos_fact_file" harness_checkout)" \
        present invalid || die "personal-Mac checkout fact is malformed"
    for macos_fact_link in link_codex_guidance link_codex_rules \
        link_claude_guidance link_bash_launcher; do
        macos_value_is_one_of \
            "$(macos_manifest_get "$macos_fact_file" "$macos_fact_link")" \
            symlink regular directory other absent ||
            die "personal-Mac link fact is malformed"
    done
    printf '%s\n' "$macos_fact_formulae" | tr ',' '\n' |
        while IFS= read -r macos_fact_formula; do
            macos_fact_formula_key=formula_$(macos_formula_key "$macos_fact_formula")
            macos_value_is_one_of \
                "$(macos_manifest_get "$macos_fact_file" \
                    "$macos_fact_formula_key")" present absent unknown ||
                die "personal-Mac formula fact is malformed"
        done
}
