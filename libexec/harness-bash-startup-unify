#!/usr/bin/env python3
"""Transactionally make .bashrc canonical and .bash_profile a thin loader."""

from __future__ import annotations

import argparse
import filecmp
import json
import os
from pathlib import Path
import re
import shutil
import stat
import subprocess
import sys
import tempfile
import time


def die(message: str) -> "NoReturn":
    print(f"harness: {message}", file=sys.stderr)
    raise SystemExit(2)


def safe_id(value: str) -> bool:
    return bool(value) and all(c.isalnum() or c in "._-" for c in value)


def require_regular(path: Path, uid: int) -> os.stat_result:
    try:
        info = path.lstat()
    except FileNotFoundError:
        die(f"required startup file is absent: {path.name}")
    if not stat.S_ISREG(info.st_mode) or info.st_uid != uid or info.st_nlink != 1:
        die(f"startup file has unsafe type, owner, or link count: {path.name}")
    return info


def read_public(path: Path) -> bytes:
    if not path.is_file() or path.is_symlink():
        die(f"public startup block is unavailable: {path}")
    return path.read_bytes()


def split_managed(data: bytes, prefix: bytes, suffix: bytes, name: str) -> bytes:
    if not data.startswith(prefix) or not data.endswith(suffix):
        die(f"{name} is not the exact managed pre/local/post layout")
    middle = data[len(prefix):len(data) - len(suffix)]
    forbidden = (
        b"# >>> harness early managed >>>",
        b"# <<< harness early managed <<<",
        b"# >>> harness managed >>>",
        b"# <<< harness managed <<<",
        b"# >>> harness login-only local >>>",
        b"# <<< harness login-only local <<<",
    )
    if any(marker in middle for marker in forbidden):
        die(f"{name} contains ambiguous managed markers")
    return middle


def prefix_for(host: str) -> bytes:
    return (
        "# >>> harness early managed >>>\n"
        f"HARNESS_LOGICAL_HOST={host}\n"
        "export HARNESS_LOGICAL_HOST\n"
        'if [ -r "$HOME/harness/shell/early-cache.sh" ]; then\n'
        '    . "$HOME/harness/shell/early-cache.sh"\n'
        "fi\n"
        "# <<< harness early managed <<<\n"
    ).encode()


def login_section(middle: bytes) -> bytes:
    payload = middle
    if payload and not payload.endswith(b"\n"):
        payload += b"\n"
    return (
        b"# >>> harness login-only local >>>\n"
        b"if shopt -q login_shell; then\n" + payload +
        b"fi\n"
        b"# <<< harness login-only local <<<\n"
    )


def remove_redundant_bashrc_loaders(middle: bytes) -> tuple[bytes, int]:
    """Drop conventional profile loaders for the now-canonical .bashrc."""
    loader = re.compile(
        rb'^[ \t]*(?:source|\.)[ \t]+(?:"?\$HOME/\.bashrc"?|"?~/\.bashrc"?)'
        rb'[ \t]*(?:#[^\r\n]*)?(?:\r?\n)?$'
    )
    guard = re.compile(
        rb'^[ \t]*if[ \t]+\[[ \t]+-[erf][ \t]+'
        rb'(?:"?\$HOME/\.bashrc"?|"?~/\.bashrc"?)[ \t]+\][ \t]*;?'
        rb'[ \t]*then[ \t]*(?:#[^\r\n]*)?(?:\r?\n)?$'
    )
    closing = re.compile(rb'^[ \t]*fi[ \t]*(?:#[^\r\n]*)?(?:\r?\n)?$')
    lines = middle.splitlines(keepends=True)
    kept = []
    removed = 0
    index = 0
    while index < len(lines):
        if index + 2 < len(lines) and guard.match(lines[index]) and \
                loader.match(lines[index + 1]) and closing.match(lines[index + 2]):
            removed += 1
            index += 3
        elif loader.match(lines[index]):
            removed += 1
            index += 1
        else:
            kept.append(lines[index])
            index += 1
    return b"".join(kept), removed


def bash_syntax(path: Path) -> None:
    result = subprocess.run(
        ["/bin/bash", "--noprofile", "--norc", "-n", str(path)],
        stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL, check=False,
    )
    if result.returncode != 0:
        die("combined Bash startup candidate has invalid grammar")


def copy_metadata(source: Path, destination: Path) -> None:
    result = subprocess.run(
        ["cp", "-p", str(source), str(destination)],
        stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL, check=False,
    )
    if result.returncode != 0:
        die("cannot preserve startup file metadata")


def write_candidate(source: Path, destination: Path, payload: bytes) -> None:
    copy_metadata(source, destination)
    with destination.open("wb") as stream:
        stream.write(payload)
        stream.flush()
        os.fsync(stream.fileno())


def validate_checkout(root: Path) -> None:
    if not (root / ".git").is_dir() or (root / ".git").is_symlink():
        die("Bash startup unification requires a Git harness checkout")
    status = subprocess.check_output(
        ["git", "-C", str(root), "status", "--porcelain", "--untracked-files=normal"],
        text=True,
    )
    if status:
        die("Bash startup unification requires a clean committed checkout")
    if os.environ.get("HARNESS_TEST_ALLOW_NONMAIN", "0") != "1":
        branch = subprocess.run(
            ["git", "-C", str(root), "symbolic-ref", "--quiet", "--short", "HEAD"],
            text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, check=False,
        )
        if branch.returncode or branch.stdout.strip() != "main":
            die("Bash startup unification requires the main branch")


def prepare_state(home: Path, uid: int) -> Path:
    current = home
    for part in (".local", "state", "harness", "transactions"):
        current /= part
        if current.exists() or current.is_symlink():
            info = current.lstat()
            if not stat.S_ISDIR(info.st_mode) or info.st_uid != uid:
                die("Bash startup transaction path is unsafe")
        else:
            current.mkdir(mode=0o700)
        os.chmod(current, 0o700)
    return current


def exact_equal(left: Path, right: Path) -> bool:
    return left.is_file() and not left.is_symlink() and filecmp.cmp(left, right, shallow=False)


def rollback(root: Path, home: Path, transaction: str) -> None:
    if not safe_id(transaction):
        die("invalid Bash startup transaction identifier")
    uid = os.getuid()
    txroot = prepare_state(home, uid)
    manifest_path = txroot / f"{transaction}.bash-startup-unify.json"
    status_path = txroot / f"{transaction}.bash-startup-unify.status"
    require_regular(manifest_path, uid)
    require_regular(status_path, uid)
    if status_path.read_text(encoding="ascii").strip() != "complete":
        die("Bash startup transaction is not complete")
    manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
    if manifest.get("schema") != 1 or manifest.get("operation") != "bash-startup-unify":
        die("Bash startup transaction manifest is malformed")
    records = manifest.get("files")
    if not isinstance(records, list) or len(records) != 2:
        die("Bash startup transaction manifest is malformed")
    for record in records:
        path = Path(record["path"])
        post = Path(record["post"])
        backup = Path(record["backup"])
        if path.parent != home or txroot not in backup.parents or txroot not in post.parents:
            die("Bash startup rollback path is unsafe")
        require_regular(path, uid)
        require_regular(post, uid)
        require_regular(backup, uid)
        if not exact_equal(path, post):
            die(f"Bash startup rollback blocked by changed file: {path.name}")
    for record in records:
        path = Path(record["path"])
        backup = Path(record["backup"])
        candidate = txroot / f".{transaction}.{path.name}.rollback"
        copy_metadata(backup, candidate)
        os.replace(candidate, path)
    status_path.write_text("rolled-back\n", encoding="ascii")
    os.chmod(status_path, 0o600)
    print(f"BASH_STARTUP_UNIFY action=rolled-back transaction={transaction} activation=new-shells")


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--host")
    parser.add_argument("--plan", action="store_true")
    parser.add_argument("--apply", action="store_true")
    parser.add_argument("--rollback")
    args = parser.parse_args()
    if sum(bool(value) for value in (args.plan, args.apply, args.rollback)) != 1:
        die("select exactly one of --plan, --apply, or --rollback")

    root = Path(os.environ.get("HARNESS_ROOT", Path(__file__).resolve().parent.parent))
    home_text = os.environ.get("HOME", "")
    if not home_text.startswith("/"):
        die("Bash startup unification requires an absolute HOME")
    home = Path(home_text)
    uid = os.getuid()
    home_info = home.lstat()
    if not stat.S_ISDIR(home_info.st_mode) or home_info.st_uid != uid:
        die("Bash startup HOME is unsafe")
    validate_checkout(root)
    if args.rollback:
        if args.host:
            die("rollback does not accept --host")
        rollback(root, home, args.rollback)
        return 0
    if not args.host or not safe_id(args.host):
        die("a safe logical host is required")
    public_profile = root / "profiles" / "hosts" / f"{args.host}.conf"
    if not public_profile.is_file():
        if os.uname().sysname != "Darwin":
            die("unknown logical host profile")
        private_check = subprocess.run(
            [str(root / "libexec" / "harness-macos-profile"), "--host", args.host],
            stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL, check=False, env=os.environ.copy(),
        )
        if private_check.returncode != 0:
            die("private Mac logical profile is not valid and current")

    bashrc = home / ".bashrc"
    profile = home / ".bash_profile"
    bashrc_info = require_regular(bashrc, uid)
    profile_info = require_regular(profile, uid)
    prefix = prefix_for(args.host)
    bashrc_block = root / "shell" / f"bashrc.{args.host}.block"
    profile_block = root / "shell" / f"bash_profile.{args.host}.block"
    if not bashrc_block.exists():
        bashrc_block = root / "shell" / "bashrc.block"
    if not profile_block.exists():
        profile_block = root / "shell" / "bash_profile.block"
    bashrc_suffix = read_public(bashrc_block)
    profile_suffix = read_public(profile_block)
    bashrc_data = bashrc.read_bytes()
    profile_data = profile.read_bytes()

    thin_profile = read_public(root / "shell" / "bash_profile.canonical")
    current = profile_data == thin_profile and bashrc_data.startswith(prefix) and \
        bashrc_data.endswith(bashrc_suffix) and \
        bashrc_data.count(b"# >>> harness login-only local >>>") == 1 and \
        bashrc_data.count(b"# <<< harness login-only local <<<") == 1
    mode = "apply" if args.apply else "plan"
    if current:
        print(f"BASH_STARTUP_UNIFY mode={mode} host={args.host} state=current action=none")
        return 0

    bashrc_middle = split_managed(bashrc_data, prefix, bashrc_suffix, ".bashrc")
    profile_middle = split_managed(profile_data, prefix, profile_suffix, ".bash_profile")
    migrated_profile_middle, redundant_loaders = remove_redundant_bashrc_loaders(profile_middle)
    new_bashrc = prefix + login_section(migrated_profile_middle) + bashrc_middle + bashrc_suffix
    print(
        f"BASH_STARTUP_UNIFY mode={mode} host={args.host} state=merge "
        f"profile_local_bytes={len(profile_middle)} bashrc_local_bytes={len(bashrc_middle)} "
        f"redundant_profile_loaders={redundant_loaders} "
        "action=canonical-bashrc+thin-profile"
    )
    if args.plan:
        print("END bash_startup_unify changes=not-applied")
        return 0

    txroot = prepare_state(home, uid)
    transaction = time.strftime("%Y%m%dT%H%M%SZ", time.gmtime()) + f"-{os.getpid()}"
    manifest_path = txroot / f"{transaction}.bash-startup-unify.json"
    status_path = txroot / f"{transaction}.bash-startup-unify.status"
    records = []
    candidates = []
    for path, info, payload in (
        (bashrc, bashrc_info, new_bashrc),
        (profile, profile_info, thin_profile),
    ):
        backup = txroot / f"{transaction}.{path.name}.backup"
        post = txroot / f"{transaction}.{path.name}.post"
        candidate = txroot / f".{transaction}.{path.name}.candidate"
        copy_metadata(path, backup)
        os.chmod(backup, 0o600)
        write_candidate(path, post, payload)
        os.chmod(post, 0o600)
        write_candidate(path, candidate, payload)
        bash_syntax(candidate)
        records.append({"path": str(path), "backup": str(backup), "post": str(post), "mode": stat.S_IMODE(info.st_mode)})
        candidates.append((path, candidate, post, backup))
    manifest = {"schema": 1, "operation": "bash-startup-unify", "host": args.host, "files": records}
    manifest_path.write_text(json.dumps(manifest, sort_keys=True) + "\n", encoding="utf-8")
    status_path.write_text("prepared\n", encoding="ascii")
    os.chmod(manifest_path, 0o600)
    os.chmod(status_path, 0o600)

    replaced = []
    try:
        for index, (path, candidate, post, _backup) in enumerate(candidates, 1):
            os.replace(candidate, path)
            replaced.append(index - 1)
            if not exact_equal(path, post):
                raise RuntimeError("postimage verification failed")
            if os.environ.get("HARNESS_TEST_FAIL_AFTER", "") == str(index):
                raise RuntimeError("injected startup replacement failure")
    except Exception as error:
        for index in reversed(replaced):
            path, _candidate, _post, backup = candidates[index]
            recovery = txroot / f".{transaction}.{path.name}.recovery"
            copy_metadata(backup, recovery)
            os.replace(recovery, path)
        status_path.write_text("failed\n", encoding="ascii")
        os.chmod(status_path, 0o600)
        die(f"Bash startup apply failed and prior files were restored: {error}")
    status_path.write_text("complete\n", encoding="ascii")
    os.chmod(status_path, 0o600)
    print(f"BASH_STARTUP_UNIFY action=applied transaction={transaction} rollback=available activation=new-shells")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
