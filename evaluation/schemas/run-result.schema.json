{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "experiment_id", "stage", "task_id", "repeat", "arm", "run_id", "source_revision", "fixture_digest", "oracle_digest", "candidate_digest", "grader_digest", "runner_digest", "client", "attempts", "passed", "safety_passed", "failure_codes", "changed_paths", "diff_digest", "usage", "duration_ms", "model_invocations", "retry_used", "review_uncertain"],
  "properties": {
    "schema": {"const": 1},
    "experiment_id": {"type": "string"},
    "stage": {"enum": ["pilot", "full"]},
    "task_id": {"type": "string"},
    "repeat": {"type": "integer", "minimum": 1},
    "arm": {"enum": ["baseline", "candidate"]},
    "run_id": {"type": "string"},
    "source_revision": {"type": "string"},
    "fixture_digest": {"type": "string"},
    "oracle_digest": {"type": "string"},
    "candidate_digest": {"type": "string"},
    "grader_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "runner_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "client": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "version", "model", "reasoning_effort", "speed", "sandbox", "ephemeral", "automatic_delegation"],
      "properties": {
        "command": {"type": "string"},
        "version": {"type": "string"},
        "model": {"type": "string"},
        "reasoning_effort": {"type": "string"},
        "speed": {"type": "string"},
        "sandbox": {"type": "string"},
        "ephemeral": {"type": "boolean"},
        "automatic_delegation": {"type": "boolean"}
      }
    },
    "attempts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["attempt", "returncode", "termination", "duration_ms", "stdout_bytes", "stderr_bytes", "event_valid", "event_codes", "usage", "tool_calls"],
        "properties": {
          "attempt": {"type": "integer", "minimum": 1, "maximum": 2},
          "returncode": {"type": "integer"},
          "termination": {"type": ["string", "null"]},
          "duration_ms": {"type": "integer", "minimum": 0},
          "stdout_bytes": {"type": "integer", "minimum": 0},
          "stderr_bytes": {"type": "integer", "minimum": 0},
          "event_valid": {"type": "boolean"},
          "event_codes": {"type": "array", "items": {"type": "string"}},
          "usage": {
            "type": "object",
            "additionalProperties": false,
            "required": ["input_tokens", "cached_input_tokens", "output_tokens", "reasoning_output_tokens"],
            "properties": {
              "input_tokens": {"type": ["integer", "null"], "minimum": 0},
              "cached_input_tokens": {"type": ["integer", "null"], "minimum": 0},
              "output_tokens": {"type": ["integer", "null"], "minimum": 0},
              "reasoning_output_tokens": {"type": ["integer", "null"], "minimum": 0}
            }
          },
          "tool_calls": {"type": "integer", "minimum": 0}
        }
      }
    },
    "passed": {"type": "boolean"},
    "safety_passed": {"type": "boolean"},
    "failure_codes": {"type": "array", "items": {"type": "string"}},
    "changed_paths": {"type": "array", "items": {"type": "string"}},
    "diff_digest": {"type": ["string", "null"]},
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "cached_input_tokens", "output_tokens", "reasoning_output_tokens"],
      "properties": {
        "input_tokens": {"type": ["integer", "null"], "minimum": 0},
        "cached_input_tokens": {"type": ["integer", "null"], "minimum": 0},
        "output_tokens": {"type": ["integer", "null"], "minimum": 0},
        "reasoning_output_tokens": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "duration_ms": {"type": "integer", "minimum": 0},
    "model_invocations": {"type": "integer", "minimum": 1, "maximum": 2},
    "retry_used": {"type": "boolean"},
    "review_uncertain": {"type": "boolean"}
  }
}
