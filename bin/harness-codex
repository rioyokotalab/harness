#!/bin/sh
set -eu

launcher_path=$0
if [ -L "$launcher_path" ]; then
    launcher_target=$(readlink "$launcher_path")
    case "$launcher_target" in
        /*) launcher_path=$launcher_target ;;
        *) launcher_path=${launcher_path%/*}/$launcher_target ;;
    esac
fi
SELF_DIR=$(CDPATH='' cd -- "$(dirname -- "$launcher_path")" 2>/dev/null && pwd -P)
HARNESS_ROOT=${HARNESS_ROOT:-$(CDPATH='' cd -- "$SELF_DIR/.." 2>/dev/null && pwd -P)}

if project_root=$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null); then
    project_root=$(CDPATH='' cd -- "$project_root" 2>/dev/null && pwd -P) || {
        echo "harness-codex: current project root is unavailable" >&2
        exit 2
    }
else
    project_root=$(pwd -P)
fi
case "$project_root" in
    *'"'*|*'\'*|*'
'*) echo "harness-codex: current project root cannot be encoded safely" >&2; exit 2 ;;
esac

native_codex=$HOME/.local/bin/codex
if [ "$(uname -s)" = Darwin ] && command -v brew >/dev/null 2>&1; then
    brew_prefix=$(brew --prefix 2>/dev/null || true)
    case "$brew_prefix" in
        /opt/homebrew|/usr/local) brew_codex=$brew_prefix/bin/codex ;;
        *)
            if [ "${HARNESS_TEST_ALLOW_NONMAIN:-0}" = 1 ]; then
                brew_codex=$brew_prefix/bin/codex
            fi
            ;;
    esac
    if [ -n "${brew_codex:-}" ] && [ -x "$brew_codex" ]; then
        brew_codex_physical=$(realpath "$brew_codex" 2>/dev/null || true)
        case "$brew_codex_physical" in
            "$HOME/.codex/packages/standalone/"*) native_codex=$brew_codex ;;
        esac
    fi
fi
[ -x "$native_codex" ] || {
    echo "harness-codex: relocated native codex command is unavailable" >&2
    exit 2
}

exec "$native_codex" --ask-for-approval never --sandbox danger-full-access \
    "$@"
