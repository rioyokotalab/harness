#!/bin/sh
set -eu

find_root() {
    candidate=$(CDPATH='' cd -- "$(dirname -- "$0")/.." 2>/dev/null && pwd)
    if [ -x "$candidate/libexec/harness-inventory" ]; then
        printf '%s\n' "$candidate"
        return
    fi

    if command -v readlink >/dev/null 2>&1; then
        # Prefer the link's lexical target before canonicalizing it. Some HPC
        # filesystems expose the same home through multiple mount paths. Links
        # created through one valid path must not drift merely because -f
        # selects another path on a different login node.
        target=$(readlink -- "$0" 2>/dev/null || true)
        if [ -n "$target" ]; then
            case "$target" in
                /*) resolved=$target ;;
                *) resolved=$(dirname -- "$0")/$target ;;
            esac
            candidate=$(CDPATH='' cd -- "$(dirname -- "$resolved")/.." 2>/dev/null && pwd || true)
            if [ -n "$candidate" ] && [ -x "$candidate/libexec/harness-inventory" ]; then
                printf '%s\n' "$candidate"
                return
            fi
        fi

        resolved=$(readlink -f -- "$0" 2>/dev/null || true)
        if [ -n "$resolved" ]; then
            candidate=$(CDPATH='' cd -- "$(dirname -- "$resolved")/.." && pwd)
            if [ -x "$candidate/libexec/harness-inventory" ]; then
                printf '%s\n' "$candidate"
                return
            fi
        fi
    fi

    echo "cannot locate harness repository from $0" >&2
    exit 2
}

usage() {
    cat <<'EOF'
Usage: harness COMMAND [OPTIONS]

Read-only phase-1 commands:
  inventory   emit value-free host capability facts
  plan        compare facts with a logical host profile
  doctor      validate required invariants and report optional gaps
  macos-inventory  emit value-minimized personal-Mac capability facts
  macos-plan   render a read-only personal-Mac convergence plan
  macos-doctor validate personal-Mac required and optional readiness
  macos-profile  validate a private personal-Mac desired-state profile
  macos-update  plan/apply clean public and private Mac fast-forwards
  macos-ssh-supervisor  manage legacy Mac SSH launch agents
  macos-tunnel-supervisor stage/activate/inspect dedicated Mac tunnel agents
  macos-codex-bootstrap  install/launch Codex for one Mac onboarding
  macos-ssh-sync  reconcile one private whole-file Mac SSH configuration
  macos-config-sync  reconcile the atomic private Mac configuration bundle
  macos-config-migrate  retire private Bash/tmux payloads through a guarded bridge
  tmux-config   plan/apply/rollback the shared public tmux configuration
  agent-config  plan/apply/doctor/rollback public Codex and Claude configuration
  codex-arg0-housekeeping  classify/quarantine guarded Codex helper residue
  codex-arg0-wrapper  plan/apply/doctor/rollback the Linux NFS workaround
  agent-config-catch-up  explicitly catch up and reconcile one local node
  agent-config-fleet  sequentially reconcile local and managed Linux nodes
  storage-readiness  validate declared large/cache storage; optionally probe writes

Transactional commands:
  macos-pilot-plan  curate and plan the first private Mac configuration bundle
  macos-control  plan/apply/rollback personal-Mac discovery links
  macos-homebrew plan/apply bounded personal-Mac managed formula catch-up
  macos-login-shell transactionally select managed Homebrew Bash for login
  macos-bash     plan/apply/rollback personal-Mac Bash integration
  macos-bash-hooks  wrap Mac-local Bash bytes in shared public pre/post hooks
  bash-startup-unify  make .bashrc canonical and .bash_profile a thin loader
  replica     plan or create one immutable encrypted-repository generation
  apply       plan or apply managed control-plane links
  remediate   plan or apply an exact reviewed host remediation
  shell       plan or append managed shell-loader blocks
  cache-bootstrap  plan or prepend silent cache variables before user startup
  startup-normalize  plan, apply, or roll back reviewed Bash/SSH simplification
  dotfiles    plan or apply canonical Vim and shared SSH configuration
  ssh-config-layout  move shared SSH stanzas into the terminal included fragment
  tool        plan or install one checksum-pinned portable tool
  runtime     plan or install one checksum-pinned portable runtime
  python      plan or install one uv-managed Python minor
  agent       plan or install one checksum-pinned agent command
  build-tool  plan or build one checksum-pinned source tool
  rollback    reverse one unchanged managed transaction
  restic-primary   validate or create one declared hidden-home snapshot
  restic-schedule  inspect or operate the node-local weekly scheduler chain
  fleet-sync  plan or apply a guarded fast-forward to clean mirrored nodes
  connection-monitor  observe/recover managed Mac SSH route pairs
  ssh-config-mirror  explicitly mirror local SSH configuration only to t4
  terminfo   plan/apply/rollback the canonical AL user terminfo entry

Safety commands:
  guarded-delete  plan, execute, and verify bounded recursive deletion

Other commands:
  restic      execute Restic from PATH or the managed user installation
  help        show this help
  version     show the command schema version
EOF
}

ROOT=$(find_root)
export HARNESS_ROOT="$ROOT"

command_name=${1:-help}
if [ "$#" -gt 0 ]; then
    shift
fi

case "$command_name" in
    inventory|plan|doctor|macos-inventory|macos-plan|macos-doctor|macos-profile|macos-update|macos-ssh-supervisor|macos-tunnel-supervisor|macos-codex-bootstrap|macos-ssh-sync|macos-config-sync|macos-config-migrate|macos-pilot-plan|macos-control|macos-homebrew|macos-login-shell|macos-bash|macos-bash-hooks|bash-startup-unify|tmux-config|agent-config|agent-config-catch-up|agent-config-fleet|codex-arg0-housekeeping|codex-arg0-wrapper|storage-readiness|replica|apply|remediate|shell|cache-bootstrap|startup-normalize|dotfiles|ssh-config-layout|tool|runtime|python|agent|build-tool|rollback|restic|restic-primary|restic-schedule|fleet-sync|connection-monitor|ssh-config-mirror|terminfo)
        exec "$ROOT/libexec/harness-$command_name" "$@"
        ;;
    guarded-delete)
        exec "$ROOT/shared/skills/guarded-bulk-delete/scripts/guarded-delete" "$@"
        ;;
    help|-h|--help)
        usage
        ;;
    version|--version)
        echo "harness schema 1"
        ;;
    *)
        echo "unknown harness command: $command_name" >&2
        usage >&2
        exit 2
        ;;
esac
